function updateCrewCountdown() {
  const crewCountdown = document.getElementById("crewCountdown");
  if (!crewCountdown) return;
  if (!crewMembershipActive) {
    crewCountdown.textContent = "";
    crewCountdown.classList.add("hidden");
    return;
  }
  if (!crewNextChargeAt || crewNextChargeAt <= 0) {
    crewNextChargeAt = Date.now() + CREW_CHARGE_INTERVAL_MS;
    saveCrewMembership();
  }
  const now = Date.now();
  if (now >= crewNextChargeAt) {
    const cycles = Math.floor((now - crewNextChargeAt) / CREW_CHARGE_INTERVAL_MS) + 1;
    crewNextChargeAt += cycles * CREW_CHARGE_INTERVAL_MS;
    saveCrewMembership();
  }
  const remaining = Math.max(0, crewNextChargeAt - now);
  crewCountdown.textContent = `Naechste Zahlung in ${formatCrewCountdown(remaining)}`;
  crewCountdown.classList.remove("hidden");
}

