    function normalizeCustomLobbyBackgroundEntry(entry = {}) {
      const rawId = String(entry.id || "").trim().toLowerCase();
      const videoId = String(entry.youtubeId || "").trim();
      const id = rawId || `yt_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 7)}`;
      if (!/^[a-z0-9_-]+$/.test(id)) return null;
      if (!/^[A-Za-z0-9_-]{11}$/.test(videoId)) return null;
      const safeNameRaw = String(entry.name || "YouTube Hintergrund").trim();
      const safeName = safeNameRaw.slice(0, 42) || "YouTube Hintergrund";
      return {
        id,
        youtubeId: videoId,
        name: safeName,
        image: `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`,
        rarity: "epic",
        sourceType: "custom",
        sourceLabel: "YouTube",
        dynamic: true,
        tintA: "rgba(111, 92, 212, 0.2)",
        tintB: "rgba(252, 89, 89, 0.12)",
        tintC1: "rgba(76, 58, 165, 0.22)",
        tintC2: "rgba(42, 33, 108, 0.2)",
        tintC3: "rgba(25, 19, 70, 0.42)",
        dynamicAccent: "rgba(140, 199, 255, 0.35)"
      };
    }

    function extractYouTubeVideoId(input = "") {
      const raw = String(input || "").trim();
      if (!raw) return "";
      if (/^[A-Za-z0-9_-]{11}$/.test(raw)) return raw;
      try {
        const parsed = new URL(raw);
        const host = parsed.hostname.replace(/^www\./i, "").toLowerCase();
        const pathParts = parsed.pathname.split("/").filter(Boolean);
        if (host === "youtu.be" && pathParts[0] && /^[A-Za-z0-9_-]{11}$/.test(pathParts[0])) return pathParts[0];
        if (host.endsWith("youtube.com")) {
          const fromQuery = parsed.searchParams.get("v");
          if (fromQuery && /^[A-Za-z0-9_-]{11}$/.test(fromQuery)) return fromQuery;
          const namedIndex = ["embed", "shorts", "live"].includes(pathParts[0]) ? 1 : -1;
          if (namedIndex > 0 && pathParts[namedIndex] && /^[A-Za-z0-9_-]{11}$/.test(pathParts[namedIndex])) return pathParts[namedIndex];
        }
      } catch {}
      return "";
    }

    function getLobbyBackgroundData(id) {
