async function loadMaintenanceStateFromSupabase() {
  if (!supabaseClient) {
    setMaintenanceMode(false);
    return false;
  }

  try {
    let { data, error } = await supabaseClient
      .from(GAME_STATE_TABLE)
      .select("maintenance_active, mode_state, mode_solo_enabled, mode_rift_enabled, mode_creative_enabled, emergency_state, emergency_shop, emergency_battle_pass, emergency_quests, emergency_creator, emergency_twitch, live_event_state, event_xp_boost, event_pass_boost, event_community_boost, event_shop_discount, hearts_warning_state, hearts_warning_active, hearts_warning_text, hearts_warning_scope, global_shop_discount, shop_state, community_event_state")
      .eq("id", GAME_STATE_ID)
      .maybeSingle();

    if (!error && !data) {
      const fallback = await supabaseClient
        .from(GAME_STATE_TABLE)
        .select("maintenance_active, mode_state, mode_solo_enabled, mode_rift_enabled, mode_creative_enabled, emergency_state, emergency_shop, emergency_battle_pass, emergency_quests, emergency_creator, emergency_twitch, live_event_state, event_xp_boost, event_pass_boost, event_community_boost, event_shop_discount, hearts_warning_state, hearts_warning_active, hearts_warning_text, hearts_warning_scope, global_shop_discount, shop_state, community_event_state")
        .order("id", { ascending: true })
        .limit(1)
        .maybeSingle();
      data = fallback.data;
      error = fallback.error;
    }

    if (error) {
      console.error("Fehler beim Laden aus Supabase:", error);
      setMaintenanceMode(false);
      return false;
    }

    applyRemoteGameStateRow(data);
    return !!data;
  } catch (err) {
    console.error("Supabase-Abfrage fehlgeschlagen:", err);
    setMaintenanceMode(false);
    return false;
  }
}

