    function handleTwitchCommand(event) {
      const rawText = event?.message?.text || "";
      const text = rawText.trim().toLowerCase();
      if (!text.startsWith("!")) return;

      const now = Date.now();
      const lastAt = twitchCommandCooldowns[text] || 0;
      const cooldownMs = Math.max(2000, Number(twitchState.settings?.commandCooldownMs) || 5000);
      if (now - lastAt < cooldownMs) return;

      let handled = false;
      if (text === "!gold" && twitchState.settings?.enableGold) {
        inventory[7] += 25;
        showMessage(`Twitch ${event.chatter_user_name}: +25 M-Bucks!`, 2200);
        handled = true;
      } else if (text === "!heal" && twitchState.settings?.enableHeal) {
        player.health = player.maxHealth;
        showMessage(`Twitch ${event.chatter_user_name}: Leben voll!`, 2200);
        handled = true;
      } else if (text === "!xp" && twitchState.settings?.enableXp) {
        addXp(40);
        showMessage(`Twitch ${event.chatter_user_name}: +40 XP!`, 2200);
        handled = true;
      } else if (text === "!slime" && twitchState.settings?.enableSlime) {
        createSlime(player.x + 80, player.y - 10, "normal");
        showMessage(`Twitch ${event.chatter_user_name}: Slime gespawnt!`, 2200);
        handled = true;
      }

      if (!handled) return;
      twitchCommandCooldowns[text] = now;
      twitchState.lastCommand = `${event.chatter_user_name || "Chat"}: ${text}`;
      updateUI();
      saveGame({ skipCloudSchedule: true });
      saveTwitchSettings();
      updateTwitchUi();
    }

    async function connectTwitch(url = "wss://eventsub.wss.twitch.tv/ws") {
      twitchState.channelName = (twitchChannelInput?.value || "").trim();
      twitchState.clientId = (twitchClientIdInput?.value || "").trim();
      twitchState.accessToken = (twitchTokenInput?.value || "").trim();
      twitchState.broadcasterUserId = (twitchBroadcasterIdInput?.value || "").trim();
      twitchState.moderatorUserId = (twitchModeratorIdInput?.value || "").trim();
      saveTwitchSettings();

      if (!twitchState.clientId || !twitchState.accessToken || !twitchState.broadcasterUserId || !twitchState.moderatorUserId) {
        setTwitchStatus("Bitte alle Twitch-Felder ausfüllen.", false);
        return;
      }

      disconnectTwitch(false);
      setTwitchStatus("Verbinde zu Twitch...", false);

      try {
        twitchEventSocket = new WebSocket(url);
      } catch (err) {
        setTwitchStatus(`Twitch-WebSocket fehlgeschlagen: ${err.message}`, false);
        return;
      }

      twitchEventSocket.onopen = () => {
        setTwitchStatus("Socket offen, warte auf Session...", false);
      };

      twitchEventSocket.onmessage = async (msg) => {
        try {
          const payload = JSON.parse(msg.data);
          const messageType = payload.metadata?.message_type;
          if (messageType === "session_welcome") {
            twitchState.sessionId = payload.payload?.session?.id || "";
            twitchState.reconnectUrl = payload.payload?.session?.reconnect_url || "";
            setTwitchStatus("Session verbunden, abonniere Events...", true);
            await subscribeTwitchEvents();
            setTwitchStatus("Twitch live verbunden", true);
            return;
          }
          if (messageType === "session_keepalive") {
            setTwitchStatus("Twitch live verbunden", true);
            return;
          }
          if (messageType === "session_reconnect") {
            const reconnectUrl = payload.payload?.session?.reconnect_url;
            if (reconnectUrl) connectTwitch(reconnectUrl);
            return;
          }
          if (messageType === "revocation") {
            setTwitchStatus("Twitch-Event widerrufen. Token/Scopes prüfen.", false);
            return;
          }
          if (messageType === "notification") {
            const type = payload.payload?.subscription?.type;
            const event = payload.payload?.event || {};
            if (type === "channel.follow") handleTwitchFollow(event);
            if (type === "channel.chat.message") handleTwitchCommand(event);
          }
        } catch (err) {
          console.warn("Twitch-Nachricht konnte nicht verarbeitet werden:", err);
          setTwitchStatus(`Twitch-Fehler: ${err.message}`, false);
        }
      };

      twitchEventSocket.onerror = () => {
        setTwitchStatus("Twitch-Verbindung fehlgeschlagen.", false);
      };

      twitchEventSocket.onclose = () => {
        twitchEventSocket = null;
        twitchState.connected = false;
        twitchState.sessionId = "";
        twitchState.reconnectUrl = "";
        updateTwitchUi();
      };
    }

    async function recordCreatorSupportSale(creator, spentGold, cashback) {
      if (!supabaseClient || !creator?.playerKey) return false;
      try {
        const { data, error } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .select("player_key, creator_total_earnings, creator_total_supported_spend, creator_total_purchases, creator_auto_payout, creator_pending_payout")
          .eq("player_key", creator.playerKey)
          .maybeSingle();

        if (error || !data) {
          if (error) throw error;
          return false;
        }

        const payoutAmount = Math.max(0, Math.floor(Number(cashback || 0)));
        const autoPayoutEnabled = data.creator_auto_payout === true;
        const currentPendingPayout = Math.max(0, Math.floor(Number(data.creator_pending_payout || 0)));
        const nextPendingPayout = autoPayoutEnabled ? currentPendingPayout : currentPendingPayout + payoutAmount;

        const { error: updateError } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .update({
            creator_total_earnings: Number(data.creator_total_earnings || 0) + payoutAmount,
            creator_total_supported_spend: Number(data.creator_total_supported_spend || 0) + Number(spentGold || 0),
            creator_total_purchases: Number(data.creator_total_purchases || 0) + 1,
            creator_pending_payout: nextPendingPayout
          })
          .eq("player_key", creator.playerKey);

        if (updateError) throw updateError;

        if (autoPayoutEnabled && payoutAmount > 0) {
          await createCreatorPayoutGrant(
            creator.playerKey,
            payoutAmount,
            `Creator-Code Verdienst: +${fmt(payoutAmount)} M-Bucks`
          );
        }

        creatorAccountProfiles[creator.playerKey] = {
          ...creator,
          totalEarnings: Number(creator.totalEarnings || 0) + payoutAmount,
          totalSupportedSpend: Number(creator.totalSupportedSpend || 0) + Number(spentGold || 0),
          totalPurchases: Number(creator.totalPurchases || 0) + 1,
          autoPayout: autoPayoutEnabled,
          pendingPayout: nextPendingPayout
        };

        if (cloudPlayerKey && cloudPlayerKey === creator.playerKey && autoPayoutEnabled) {
          processSupabaseLoginRewards(creator.playerKey)
            .then((count) => {
              if (count > 0) refreshAfterSupabaseRewardGrant();
            })
            .catch((err) => console.warn("Creator-Popup konnte nicht live geladen werden:", err));
        }

        return true;
      } catch (err) {
        console.warn("Creator-Einnahmen konnten nicht gespeichert werden:", err);
        return false;
      }
    }

