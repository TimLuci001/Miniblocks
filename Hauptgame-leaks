    function getFreeCrateLoot() {
      const rewards = [
        { type: "gold", amount: 3, chance: 28 },
        { type: "gold", amount: 5, chance: 20 },
        { type: "gold", amount: 8, chance: 18 },
        { type: "gold", amount: 12, chance: 12 },
        { type: "xp", amount: 30, chance: 10 },
        { type: "loot", id: "slimeGel", amount: 1, chance: 7 },
        { type: "loot", id: "emberCore", amount: 1, chance: 5 }
      ];

      let roll = Math.random() * rewards.reduce((sum, entry) => sum + entry.chance, 0);
      for (const reward of rewards) {
        roll -= reward.chance;
        if (roll <= 0) return reward;
      }
      return rewards[0];
    }

