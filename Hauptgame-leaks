    function tradeWithNpc(entry) {
      if (!entry) return;

      if (entry.type === "buy") {
        if (inventory[7] < entry.price) {
          showMessage("Nicht genug M-Bucks!");
          return;
        }

        inventory[7] -= entry.price;
        inventory[entry.itemId] = (inventory[entry.itemId] || 0) + entry.amount;
        showMessage(`${entry.amount}x ${getBlockName(entry.itemId)} gekauft!`);
      }

      if (entry.type === "sell") {
        if ((inventory[entry.itemId] || 0) < entry.amount) {
          showMessage(`Du brauchst ${entry.amount}x ${getBlockName(entry.itemId)}!`);
          return;
        }

        inventory[entry.itemId] -= entry.amount;
        inventory[7] += entry.price;
        showMessage(`${entry.amount}x ${getBlockName(entry.itemId)} verkauft!`);
      }

      saveGame();
      updateUI();
      renderNpcShop();
      renderInventory();
      renderShop();
    }

    function drawNpcs(cam) {
      for (const npc of npcs) {
        const nx = npc.x - cam.x;
        const ny = npc.y - cam.y;

        // Körper
        ctx.fillStyle = npc.color || "#6b4f2a";
        ctx.fillRect(nx, ny, npc.w, npc.h);

        // Kopf
        ctx.fillStyle = "#f1c27d";
        ctx.fillRect(nx + 3, ny - 10, npc.w - 6, 12);

        // Hut
        ctx.fillStyle = npc.hatColor || "#444";
        ctx.fillRect(nx + 1, ny - 14, npc.w - 2, 5);
        ctx.fillRect(nx + 5, ny - 20, npc.w - 10, 8);

        // Augen
        ctx.fillStyle = "#111";
        ctx.fillRect(nx + 7, ny - 4, 3, 3);
        ctx.fillRect(nx + 14, ny - 4, 3, 3);

        // Arme
        ctx.fillStyle = "#c68642";
        ctx.fillRect(nx - 3, ny + 10, 3, 12);
        ctx.fillRect(nx + npc.w, ny + 10, 3, 12);

        // Name
        ctx.fillStyle = "white";
        ctx.font = "bold 12px Arial";
        ctx.textAlign = "center";
        ctx.fillText(npc.name, nx + npc.w / 2, ny - 28);
        ctx.textAlign = "start";
      }
    }

    function drawNpcHint(cam) {
      const npc = getNearbyNpc();
      if (!npc || npcOpen) return;

      const nx = npc.x - cam.x;
      const ny = npc.y - cam.y;

      const text = "Drücke E zum Handeln";
      ctx.font = "bold 14px Arial";
      const width = ctx.measureText(text).width + 20;

      ctx.fillStyle = "rgba(0,0,0,0.55)";
      ctx.fillRect(nx + npc.w / 2 - width / 2, ny - 55, width, 28);

      ctx.strokeStyle = "rgba(255,255,255,0.5)";
      ctx.strokeRect(nx + npc.w / 2 - width / 2, ny - 55, width, 28);

      ctx.fillStyle = "#ffffff";
      ctx.textAlign = "center";
      ctx.fillText(text, nx + npc.w / 2, ny - 36);
      ctx.textAlign = "start";
    }

