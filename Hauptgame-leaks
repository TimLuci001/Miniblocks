<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mini Mineblock V2</title>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Space+Grotesk:wght@400;600;700&display=swap");
    body {
      margin: 0;
      overflow: hidden;
      background: #87ceeb;
      font-family: Arial, sans-serif;
    }

    canvas {
      display: block;
      background: linear-gradient(#87ceeb, #d7f2ff);
    }

    .hidden {
      display: none !important;
    }

    .hudRack {
      position: fixed;
      top: 10px;
      left: 12px;
      right: 12px;
      z-index: 80;
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: start;
      gap: 12px;
      pointer-events: none;
    }

    .hudRack > * {
      pointer-events: none;
    }

    .hudRack .hudRight,
    .hudRack .topMenuDock,
    .hudRack .topMenuDock *,
    .hudRack .returnLobbyBtn,
    .hudRack .hudCombo {
      pointer-events: auto;
    }

    .hudCombo {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(12, 18, 28, 0.82), rgba(8, 12, 20, 0.78));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 16px 34px rgba(0,0,0,0.3);
      backdrop-filter: blur(10px);
      max-width: min(360px, calc(100vw - 160px));
      opacity: 0.92;
    }

    .hudRight {
      display: grid;
      justify-items: end;
      align-items: start;
      gap: 10px;
    }

    .heartsHud,
    .xpHud {
      padding: 8px 10px;
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(28, 38, 56, 0.82), rgba(12, 18, 30, 0.82));
      border: 1px solid rgba(180, 219, 255, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05);
      color: white;
      user-select: none;
    }

    .heartsHud {
      display: grid;
      gap: 6px;
      min-width: 0;
    }

    .hudTitle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(226, 238, 255, 0.82);
    }

    .heartsRow {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .heartChip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 10px;
      font-size: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .heartChip.full {
      background:
        radial-gradient(circle at top, rgba(255, 190, 205, 0.28), transparent 58%),
        linear-gradient(180deg, rgba(255, 100, 132, 0.34), rgba(120, 20, 44, 0.2));
      border-color: rgba(255, 157, 180, 0.38);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 8px 18px rgba(255, 73, 120, 0.18);
    }

    .heartChip.empty {
      opacity: 0.72;
      color: rgba(232, 238, 246, 0.68);
    }

    .heartsMeta {
      color: rgba(230, 239, 248, 0.9);
      font-size: 12px;
      font-weight: 700;
    }

    .heartsExtra {
      margin-top: 2px;
      padding: 6px 8px;
      border-radius: 12px;
      border: 1px solid rgba(255, 185, 129, 0.22);
      background:
        radial-gradient(circle at top right, rgba(255, 199, 120, 0.16), transparent 28%),
        linear-gradient(180deg, rgba(73, 32, 19, 0.82), rgba(33, 16, 12, 0.9));
      color: #fff1e2;
      display: grid;
      gap: 4px;
    }

    .heartsExtraTitle {
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 221, 192, 0.78);
    }

    .heartsExtraValue {
      font-size: 16px;
      font-weight: 1000;
      color: #fff8ef;
    }

    .heartsExtraMeta {
      font-size: 11px;
      line-height: 1.45;
      color: rgba(255, 235, 220, 0.82);
    }

    .heartsWarning {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 8px;
      border-radius: 12px;
      background: rgba(255, 193, 93, 0.12);
      border: 1px solid rgba(255, 193, 93, 0.45);
      color: #fff6db;
      font-size: 11px;
      font-weight: 700;
    }

    .heartsWarning .warningIcon {
      font-size: 14px;
      line-height: 1;
    }

    .adminHeartsWarningPreview {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(255, 193, 93, 0.12);
      border: 1px solid rgba(255, 193, 93, 0.45);
      color: #fff6db;
      font-size: 12px;
      font-weight: 700;
    }

    .xpHud {
      min-width: 0;
      width: 100%;
      max-width: 300px;
      display: grid;
      gap: 6px;
    }

    .xpTop {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .xpLevelBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 78px;
      padding: 6px 10px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(162, 255, 100, 0.95), rgba(255, 226, 91, 0.92));
      color: #253000;
      font-size: 12px;
      font-weight: 900;
      box-shadow: 0 10px 22px rgba(171, 255, 88, 0.18);
    }

    .xpPassBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 88px;
      padding: 6px 10px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255, 214, 104, 0.95), rgba(255, 143, 67, 0.92));
      color: #4f2100;
      font-size: 12px;
      font-weight: 900;
      box-shadow: 0 10px 22px rgba(255, 180, 77, 0.18);
    }

    .xpText {
      color: #f7fbff;
      font-size: 12px;
      font-weight: 800;
      line-height: 1.45;
    }

    .xpInlineIcon {
      display: inline-block;
      width: 16px;
      height: 16px;
      margin: 0 4px;
      vertical-align: -3px;
      background: url("assets/ui/xpicon.png") center/contain no-repeat;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.25));
    }

    .xpBarWrap {
      width: 100%;
      max-width: 240px;
      height: 9px;
      padding: 2px;
      border-radius: 999px;
      background: rgba(255,255,255,0.09);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow: inset 0 2px 10px rgba(0,0,0,0.2);
    }

    .xpBarWrap.xpWithIcon {
      position: relative;
      padding-left: 22px;
    }

    .xpBarWrap.xpWithIcon::before {
      content: "";
      position: absolute;
      left: 5px;
      top: 50%;
      transform: translateY(-50%);
      width: 14px;
      height: 14px;
      border-radius: 5px;
      background: url("assets/ui/xpicon.png") center/contain no-repeat;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.25));
    }

    .boostIcon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      margin-right: 6px;
      border-radius: 7px;
      background: rgba(120, 255, 170, 0.2);
      border: 1px solid rgba(140, 255, 190, 0.5);
    }

    .boostIcon.boostXp {
      background:
        url("assets/ui/xpboost.png") center/contain no-repeat,
        rgba(120, 255, 170, 0.2);
    }

    .xpBar {
      width: 0%;
      height: 100%;
      max-width: 100%;
      border-radius: inherit;
      background:
        linear-gradient(90deg, #7dff4d 0%, #c9ff53 42%, #ffe76d 100%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.28);
    }

    .helpBtn,
    .adminBtn,
    .achBtn,
    .craftBtn,
    .creatorBtn,
    .shopBtn,
    .skillBtn,
    .passBtn,
    .communityEventBtn,
    .lockerBtn,
    .loreBtn,
    .moreBtn {
      position: static;
      z-index: 50;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 58px;
      padding: 12px 20px;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(42, 65, 97, 0.94), rgba(20, 30, 47, 0.96));
      color: #f8fbff;
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.02em;
      cursor: pointer;
      text-shadow: none;
      backdrop-filter: blur(14px);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.1);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease, border-color 0.18s ease;
    }

    .communityEventBtn {
      flex-direction: column;
      gap: 2px;
      min-width: 150px;
      padding: 10px 18px;
      border-color: rgba(120, 255, 210, 0.45);
      background:
        linear-gradient(135deg, rgba(40, 110, 90, 0.85), rgba(20, 45, 40, 0.95));
      box-shadow:
        0 16px 32px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 0 18px rgba(120, 255, 210, 0.18);
    }

    .communityEventLabel {
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .communityEventSub {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      opacity: 0.75;
    }

    .topMenuDock {
      position: relative;
      z-index: 80;
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 10px;
      width: fit-content;
      max-width: 100%;
      pointer-events: auto;
    }

    .topMenuDock > * {
      pointer-events: auto;
    }

    .lobbyBoostBar {
      position: fixed;
      top: 92px;
      left: 50%;
      transform: translateX(-50%);
      display: none;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: min(920px, calc(100vw - 32px));
      padding: 12px 18px;
      border-radius: 18px;
      border: 1px solid rgba(255, 235, 189, 0.22);
      background: linear-gradient(135deg, rgba(30, 49, 27, 0.9), rgba(16, 26, 21, 0.92));
      box-shadow: 0 16px 34px rgba(0,0,0,0.24);
      color: #fff6da;
      text-align: center;
      z-index: 79;
    }

    .lobbyBoostBar.active {
      display: flex;
    }

    .lobbyBoostBar strong {
      flex: 0 0 auto;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #7ef6aa;
    }

    .lobbyBoostBar span {
      font-size: 15px;
      font-weight: 800;
      color: #fff8e7;
    }

    .topMenuDock .passBtn {
      min-width: 220px;
    }

    .topMenuPrimary {
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 10px;
      width: 100%;
    }

    .topMenuMoreWrap {
      position: relative;
      display: flex;
      justify-content: flex-end;
    }

    .moreBtn {
      min-width: 108px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(111, 123, 148, 0.96), rgba(63, 73, 96, 0.96));
      border-color: rgba(226, 234, 244, 0.28);
    }

    .topMenuMorePanel {
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      display: grid;
      gap: 10px;
      min-width: 220px;
      padding: 14px;
      border-radius: 22px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.1), transparent 38%),
        linear-gradient(180deg, rgba(22, 30, 45, 0.98), rgba(12, 18, 28, 0.98));
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow:
        0 24px 44px rgba(0,0,0,0.32),
        inset 0 1px 0 rgba(255,255,255,0.08);
      backdrop-filter: blur(14px);
    }

    .topMenuMorePanel.hidden {
      display: none;
    }

    .topMenuMorePanel button {
      width: 100%;
      justify-content: center;
    }

    .helpBtn:hover,
    .adminBtn:hover,
    .achBtn:hover,
    .craftBtn:hover,
    .creatorBtn:hover,
    .shopBtn:hover,
    .skillBtn:hover,
    .passBtn:hover,
    .lockerBtn:hover,
    .moreBtn:hover,
    .achievementCloseBtn:hover,
    .shopActionBtn:hover,
    .skillActionBtn:hover {
      transform: translateY(-2px);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.1);
      filter: brightness(1.05);
    }

    .helpBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(83, 159, 255, 0.96), rgba(34, 82, 164, 0.94));
      border-color: rgba(203, 229, 255, 0.42);
    }
    .shopBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(80, 173, 125, 0.95), rgba(33, 94, 72, 0.95));
      border-color: rgba(190, 255, 218, 0.28);
    }
    .craftBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(255, 151, 82, 0.95), rgba(129, 66, 24, 0.95));
      border-color: rgba(255, 219, 188, 0.3);
    }
    .creatorBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(255, 116, 170, 0.95), rgba(143, 45, 102, 0.95));
      border-color: rgba(255, 214, 232, 0.3);
    }
    .loreBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(120, 170, 255, 0.95), rgba(58, 86, 168, 0.95));
      border-color: rgba(196, 216, 255, 0.34);
      color: #f1f6ff;
    }
    .skillBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(129, 109, 255, 0.95), rgba(66, 54, 142, 0.95));
      border-color: rgba(214, 206, 255, 0.3);
    }
    .lockerBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(70, 190, 214, 0.95), rgba(28, 103, 128, 0.95));
      border-color: rgba(188, 244, 255, 0.28);
    }
    .passBtn {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      border: 1px solid rgba(160, 228, 255, 0.55);
      background:
        linear-gradient(140deg, rgba(18, 28, 46, 0.96), rgba(10, 14, 24, 0.98)),
        radial-gradient(circle at 20% 20%, rgba(120, 214, 255, 0.35), transparent 40%);
      color: #eaf7ff;
      box-shadow:
        0 18px 36px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.1);
    }
    .passBtn::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, rgba(120, 214, 255, 0.25), transparent 40%),
        linear-gradient(300deg, rgba(255, 98, 98, 0.25), transparent 45%);
      opacity: 0.9;
      mix-blend-mode: screen;
      pointer-events: none;
    }
    .passBtn::after {
      content: "";
      position: absolute;
      inset: 8px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: inset 0 0 22px rgba(120, 214, 255, 0.12);
      pointer-events: none;
    }
    .passBtn:hover {
      border-color: rgba(255, 138, 138, 0.7);
      box-shadow:
        0 22px 42px rgba(0,0,0,0.34),
        0 0 18px rgba(120, 214, 255, 0.25),
        inset 0 1px 0 rgba(255,255,255,0.12);
    }
    .passBtnContent {
      display: grid;
      justify-items: start;
      gap: 2px;
      line-height: 1.05;
      letter-spacing: 0.02em;
    }
    .passBtnLabel {
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: rgba(233, 246, 255, 0.92);
      white-space: nowrap;
    }
    .passBtnTimer {
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 138, 138, 0.92);
      white-space: nowrap;
    }
    .achBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(255, 179, 92, 0.96), rgba(182, 112, 24, 0.96));
      border-color: rgba(255, 230, 191, 0.34);
    }
    .adminBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(124, 135, 152, 0.96), rgba(63, 73, 88, 0.96));
      border-color: rgba(226, 234, 244, 0.28);
    }

    .roadmapWrap {
      width: min(96vw, 1160px);
      max-height: 90vh;
      overflow: hidden;
      padding: 24px;
      border-radius: 32px;
      background:
        radial-gradient(circle at top right, rgba(125, 255, 206, 0.16), transparent 28%),
        radial-gradient(circle at left center, rgba(104, 180, 255, 0.14), transparent 26%),
        linear-gradient(165deg, rgba(16, 24, 40, 0.985), rgba(8, 12, 22, 0.99));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 26px 60px rgba(0,0,0,0.34);
      box-sizing: border-box;
    }

    .roadmapTop {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.8fr);
      gap: 18px;
      margin-bottom: 18px;
    }

    .roadmapHero,
    .roadmapStatusCard {
      padding: 22px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 18px 34px rgba(0,0,0,0.24);
    }

    .roadmapHero {
      background:
        radial-gradient(circle at top right, rgba(255, 216, 131, 0.2), transparent 28%),
        linear-gradient(135deg, rgba(42, 61, 95, 0.45), rgba(16, 22, 36, 0.98));
    }

    .roadmapStatusCard {
      display: grid;
      gap: 10px;
      align-content: start;
      background:
        radial-gradient(circle at top right, rgba(120, 255, 180, 0.14), transparent 26%),
        linear-gradient(180deg, rgba(28, 40, 61, 0.98), rgba(13, 20, 33, 0.98));
    }

    .roadmapEyebrow {
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(198, 255, 238, 0.72);
    }

    .roadmapTitle {
      font-size: clamp(30px, 3.2vw, 40px);
      font-weight: 900;
      color: #ffffff;
      margin-top: 6px;
    }

    .roadmapLead {
      margin-top: 8px;
      font-size: 14px;
      line-height: 1.6;
      color: rgba(230, 240, 255, 0.86);
    }

    .roadmapStatusLabel {
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(231, 241, 255, 0.66);
    }

    .roadmapStatusValue {
      font-size: 26px;
      font-weight: 900;
      color: #fff5d8;
    }

    .roadmapGrid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 18px;
    }

    .roadmapCard {
      padding: 18px;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
        rgba(10, 16, 28, 0.9);
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .roadmapCardTitle {
      font-size: 16px;
      font-weight: 900;
      color: #ffffff;
      margin-bottom: 6px;
    }

    .roadmapCardMeta {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(199, 219, 240, 0.7);
      margin-bottom: 8px;
    }

    .roadmapCheck {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-left: 8px;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: rgba(80, 220, 120, 0.18);
      border: 1px solid rgba(90, 230, 130, 0.55);
      color: #b9ffd1;
      font-size: 12px;
      font-weight: 900;
      line-height: 1;
    }

    .roadmapCardText {
      font-size: 13px;
      line-height: 1.55;
      color: rgba(231, 241, 255, 0.86);
    }

    .leakDiffGrid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .leakDiffItem {
      border-radius: 16px;
      padding: 12px;
      border: 1px solid rgba(255,255,255,0.1);
