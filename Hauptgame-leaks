    function applyEmergencyStatePayload(payload = {}) {
      emergencyState = {
        shop: payload.shop === true,
        battlePass: payload.battlePass === true || payload.battle_pass === true,
        quests: payload.quests === true,
        creator: payload.creator === true,
        twitch: payload.twitch === true
      };
      if (shopOpen && isShopFeatureDisabled()) {
        shopOpen = false;
        if (shopMenu) shopMenu.classList.add("hidden");
      }
      if (passOpen && isBattlePassFeatureDisabled()) {
        passOpen = false;
        if (passMenu) passMenu.classList.add("hidden");
      }
      if (questOpen && isQuestFeatureDisabled()) {
        questOpen = false;
        if (questMenu) questMenu.classList.add("hidden");
      }
      if (creatorOpen && isCreatorFeatureDisabled()) {
        creatorOpen = false;
        if (creatorMenu) creatorMenu.classList.add("hidden");
      }
      if (twitchOpen && isTwitchFeatureDisabled()) {
        twitchOpen = false;
        if (twitchMenu) twitchMenu.classList.add("hidden");
      }
      updateAdminEmergencyInfo();
      saveEmergencyStateLocal();
      updateBattlePassAvailability();
      renderBattlePassButtonCountdown();
      updateLobbyUi();
      renderShop();
    }

    function applyLiveEventStatePayload(payload = {}) {
      liveEventState = {
        xpBoost: payload.xpBoost === true || payload.xp_boost === true,
        passBoost: payload.passBoost === true || payload.pass_boost === true,
        communityBoost: payload.communityBoost === true || payload.community_boost === true,
        shopDiscount: payload.shopDiscount === true || payload.shop_discount === true
      };
      updateAdminLiveEventInfo();
      saveLiveEventStateLocal();
      renderShop();
      renderCommunityEvent();
      renderXp();
    }

    async function saveEmergencyStateToSupabase() {
      if (!supabaseClient) return false;
      try {
        const { error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: GAME_STATE_ID,
            ...buildEmergencyStateSupabasePayload()
          }, { onConflict: "id" });
        if (error) throw error;
        return true;
      } catch (err) {
        console.warn("Notfallschalter konnten nicht nach Supabase gespeichert werden:", err);
        return false;
      }
    }

    async function saveLiveEventStateToSupabase() {
      if (!supabaseClient) return false;
      try {
        const { error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: GAME_STATE_ID,
            ...buildLiveEventStateSupabasePayload()
          }, { onConflict: "id" });
        if (error) throw error;
        return true;
      } catch (err) {
        console.warn("Live-Events konnten nicht nach Supabase gespeichert werden:", err);
        return false;
      }
    }

