      currentMatchMode = "normal";
      isThreeDMode = false;
      lastPlayedLobbyMode = selectedLobbyMode;
      inLobby = false;
      gameStarted = true;
      lastPlayerBiome = "";
      resetFloodState();
      slimes.length = 0;
      updateDerivedStats();
      populateDefaultSlimeSet();
      if (isSeason4LiveEventActive()) {
        showMessage(`Live Event Modus aktiv! Finale um ${BATTLE_PASS_END_LABEL_SHORT}.`, 2400);
      }

      try {
        closeMenus();
      } catch {}
      try {
        if (isThreeDMode) startThreeDMode();
      } catch (error) {
        console.error("Lobby start fallback:", error);
      }
      try {
        updateLobbyUi();
      } catch {}
      try {
        updateUI();
      } catch {}
      showMessage(`${getLobbyModeLabel(selectedLobbyMode)} gestartet!`, 1800);
      if (!MINECRAFT_CREW_ENABLED) {
        setTimeout(() => showMessage(MINECRAFT_CREW_LOCKED_WARNING_TEXT, 2400), 1900);
      }
