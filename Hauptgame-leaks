    async function subscribeTwitchEvent(type, version, condition) {
      const response = await fetch("https://api.twitch.tv/helix/eventsub/subscriptions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Client-Id": twitchState.clientId,
          "Authorization": `Bearer ${twitchState.accessToken}`
        },
        body: JSON.stringify({
          type,
          version,
          condition,
          transport: {
            method: "websocket",
            session_id: twitchState.sessionId
          }
        })
      });

      if (!response.ok) {
        const text = await response.text();
        throw new Error(`${type}: ${response.status} ${text}`);
      }
    }

