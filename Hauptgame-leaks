            <div class="lockerTileFoot">
              <div class="shopBadge ${isActive ? "active" : "owned"}">${isActive ? "Live im Look" : "Bereit"}</div>
              <button class="shopActionBtn" data-locker-type="${type}" data-locker-id="${id}">${isActive ? "Aktiv" : "Anlegen"}</button>
