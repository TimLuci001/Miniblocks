    }

    function loadCreativeWorldsLocal() {
      try {
        const raw = localStorage.getItem(CREATIVE_WORLDS_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed)) {
          creativeWorlds = parsed
            .filter((entry) => entry && entry.id && entry.data)
            .map((entry) => ({
              id: String(entry.id),
              name: String(entry.name || "Creative Insel"),
              createdAt: Number(entry.createdAt) || Date.now(),
              updatedAt: Number(entry.updatedAt) || Date.now(),
              published: !!entry.published,
              data: Array.isArray(entry.data) ? entry.data : createBaseWorldGrid(),
              devices: Array.isArray(entry.devices) ? entry.devices : [],
              settings: entry.settings && typeof entry.settings === "object" ? entry.settings : getCreativeSettingsDefaults(),
              three: entry.three && typeof entry.three === "object" ? entry.three : createBaseThreeWorldData()
            }));
        }
      } catch (err) {
        console.warn("Creative-Welten konnten nicht geladen werden:", err);
      }
    }

    function createCreativeWorld(name = "Neue Insel") {
      const id = `creative_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
      const entry = {
        id,
        name: String(name || "Neue Insel").slice(0, 32),
        createdAt: Date.now(),
        updatedAt: Date.now(),
        published: false,
        data: createBaseWorldGrid(),
        devices: [],
        settings: getCreativeSettingsDefaults(),
        three: createBaseThreeWorldData()
      };
      creativeWorlds.unshift(entry);
      activeCreativeWorldId = id;
      saveCreativeWorldsLocal();
      setActiveCreativeWorld(id);
      queueCreativeWorldSync(entry);
      return entry;
    }

    function saveActiveCreativeWorldSnapshot() {
      if (!activeCreativeWorldId) return;
      const entry = getCreativeWorldById(activeCreativeWorldId);
      if (!entry) return;
      entry.data = cloneWorldGrid();
      entry.devices = Array.isArray(creativeDevices) ? creativeDevices.slice() : [];
      entry.settings = {
        gravity: creativeGravityValue,
        fog: creativeFogValue,
        ambient: creativeAmbientValue,
        spawn: { x: spawnPoint.x, y: spawnPoint.y }
      };
      if (isThreeDMode && threeDState.active) {
        entry.three = serializeThreeWorldData();
      } else if (!entry.three) {
        entry.three = createBaseThreeWorldData();
      }
