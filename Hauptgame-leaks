    function getCreatorStreakNextGoal(streakValue) {
      const steps = [3, 5, 10, 20, 35, 50];
      for (const step of steps) {
        if (streakValue < step) return step;
      }
      return Math.ceil((streakValue + 1) / 25) * 25;
    }

    function getCreatorStreakInfoText(current, nextGoal) {
      if (current <= 0) return "Starte deine Streak mit dem nächsten Shop-Kauf bei aktivem Creator-Code.";
      const missing = Math.max(0, nextGoal - current);
      if (missing <= 0) return `Stark! Nächstes Ziel: ${getCreatorStreakNextGoal(nextGoal)} Support-Käufe in Folge.`;
      if (missing === 1) return "Nur noch 1 Kauf bis zum nächsten Streak-Ziel.";
      return `Noch ${missing} Käufe bis zum nächsten Streak-Ziel.`;
    }

    function getCreatorStreakMilestoneReward(streakValue) {
      const numericStreak = Math.max(0, Math.floor(Number(streakValue || 0)));
      const fixedRewards = {
        3: { xp: 30, mBucks: 10 },
        5: { xp: 60, mBucks: 20 },
        10: { xp: 140, mBucks: 40 },
        20: { xp: 320, mBucks: 90 },
        35: { xp: 560, mBucks: 160 },
        50: { xp: 900, mBucks: 260 }
      };
      if (fixedRewards[numericStreak]) return { ...fixedRewards[numericStreak], streak: numericStreak };
      if (numericStreak > 50 && numericStreak % 25 === 0) {
        return {
          streak: numericStreak,
          xp: Math.max(250, Math.floor(numericStreak * 16)),
          mBucks: Math.max(80, Math.floor(numericStreak * 4.5))
        };
      }
      return null;
    }

    function applyCreatorStreakMilestoneReward(streakValue) {
      const reward = getCreatorStreakMilestoneReward(streakValue);
      if (!reward) return null;
      if (reward.xp > 0) addXp(reward.xp);
      if (reward.mBucks > 0) inventory[7] += reward.mBucks;
      setTimeout(() => {
        showMessage(`Code-Streak x${reward.streak}! +${fmt(reward.mBucks)} M-Bucks & +${fmt(reward.xp)} XP`, 2600);
      }, 520);
      return reward;
    }

