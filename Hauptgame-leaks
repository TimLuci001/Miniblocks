        ${renderLockerSection("Koerperfarben Archiv", "Alle freigeschalteten Koerperfarben liegen in einer eigenen Galerie statt in den alten Standard-Karten.", "bodies", playerSkin.ownedBodies, (id) => !playerSkin.activeSpecial && playerSkin.activeBody === id)}
        ${renderLockerSection("Regenfarben Control", "Diese Auswahl steuert Wetter- und Regenfarben und zeigt sie als eigene Effekt-Sammlung.", "rains", playerSkin.ownedRains, (id) => playerSkin.activeRain === id)}
