      backpack.position.set(0, 1.02, -0.26);
      group.add(backpack);

      threeDState.avatarGroup = group;
      threeDState.avatarParts = { skinMat, eyeMat, hairMat, jacketMat, shirtMat, pantsMat, shoesMat, accentMat, trimMat };
      threeDState.avatarCosmetics = { skinColor, eyeColor, outfitId: outfit.id };

      const player3d = threeDState.player || { x: 6, y: 6, z: 6 };
      const base = { x: player3d.x, y: player3d.y, z: player3d.z };
      threeDState.avatarBase = base;
      group.position.set(base.x, base.y, base.z);
      group.rotation.y = player3d.yaw || 0;
