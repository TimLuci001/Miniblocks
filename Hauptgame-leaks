        health = 9;
        speed = 1.85;
        highlight = "rgba(210,255,255,0.46)";
        elite = true;
      }

      slimes.push({
        type,
        elite,
        x, y,
        w: 28, h: 22,
        vx: Math.random() > 0.5 ? speed : -speed,
        moveSpeed: speed,
        damage,
        color,
        highlight,
        vy: 0,
        onGround: false,
        dirTimer: 60 + Math.floor(Math.random() * 120),
        jumpCooldown: 40 + Math.floor(Math.random() * 80),
        health,
        hurtTimer: 0
      });
    }

    for (let i = 0; i < 4; i++) createSlime((14 + i * 10) * TILE, 16 * TILE, "fire");
