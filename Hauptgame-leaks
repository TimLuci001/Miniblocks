    function buyConsumable(id) {
      const item = consumableItems.find(i => i.id === id);
      if (!item) return;
      if (!isShopItemVisible("consumables", item.id)) {
        showMessage("Dieser Trank ist gerade nicht verfuegbar.");
        return;
      }
      const price = getDiscountedPrice(item.price, "consumables", item.id);
      if ((inventory[7] || 0) < price) {
        showMessage("Nicht genug M-Bucks!");
        return;
      }
      inventory[7] -= price;
      consumables[item.id] = (consumables[item.id] || 0) + 1;
      stats.shopPurchases++;
      showMessage(`${item.name} gekauft!`, 1800);
      saveGame();
      renderShop();
      renderInventory();
      updateUI();
    }

    function useConsumable(id) {
      const item = consumableItems.find(i => i.id === id);
      if (!item) return;
      if ((consumables[item.id] || 0) <= 0) {
        showMessage("Du hast davon keinen Trank.");
        return;
      }
      consumables[item.id] -= 1;
      stats.consumablesUsed++;

      if (item.effect?.type === "heal") {
        const healAmount = Math.max(1, Number(item.effect.amount || 0));
        player.health = Math.min(player.maxHealth, player.health + healAmount);
        showMessage(`+${healAmount} Herzen durch ${item.name}!`, 1800);
      } else if (item.effect?.type === "speed") {
        effects.speed = Math.max(effects.speed, Number(item.effect.duration || 0));
        showMessage(`${item.name} aktiv!`, 1800);
      } else if (item.effect?.type === "jump") {
        effects.jump = Math.max(effects.jump, Number(item.effect.duration || 0));
        showMessage(`${item.name} aktiv!`, 1800);
      } else if (item.effect?.type === "shield") {
        effects.shield = Math.max(effects.shield, Number(item.effect.duration || 0));
        showMessage(`${item.name} aktiv!`, 1800);
      }

      updateDerivedStats();
      renderEffects();
      saveGame();
      renderInventory();
      renderShop();
      updateUI();
    }

    function attackWithSword() {
      if (maintenanceMode || inventoryOpen || helpOpen || skillOpen || craftOpen || communityEventOpen || npcOpen || !gameStarted) return;
      if (currentSword === "none") {
        showMessage("Du hast noch kein Schwert!");
        return;
      }
      if (attackCooldown > 0) return;

      attackCooldown = 25;
      attackTimer = 8;

      const gearDamageBonus = equipmentState.equipped.combat === "plasma_pack" ? 3 : (equipmentState.equipped.combat === "alien_core" ? 2 : 0);
      const combatSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.combat || 0);
      const swordDamage = swords[currentSword].damage + combatSkill + gearDamageBonus + (isOpModeActive() ? 4 : 0);
      const playerCenterX = player.x + player.w / 2;
      const playerCenterY = player.y + player.h / 2;
      let hitSomething = false;

      for (let i = slimes.length - 1; i >= 0; i--) {
        const s = slimes[i];
        const slimeCenterX = s.x + s.w / 2;
        const slimeCenterY = s.y + s.h / 2;
        const dx = slimeCenterX - playerCenterX;
        const dy = slimeCenterY - playerCenterY;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < 70) {
          hitSomething = true;
          s.health -= swordDamage;
          s.hurtTimer = 10;

          if (player.x < s.x) s.x += 14;
          else s.x -= 14;

          if (s.health <= 0) {
            if (s.type === "desert" && Math.random() > 0.45) inventory[7]++;
            if (s.type === "fire" && Math.random() > 0.55) inventory[6]++;
            if (Math.random() > 0.6) inventory[2]++;

            if (s.type === "fire") addLoot("emberCore", Math.random() > 0.7 ? 2 : 1);
            else if (s.type === "alien") addLoot("alienFragment", Math.random() > 0.7 ? 2 : 1);
            else if (s.type === "desert") addLoot("desertFang", Math.random() > 0.7 ? 2 : 1);
            else addLoot("slimeGel", 1);
            if (Math.random() > 0.55) addLoot("alienFragment", 1);

            stats.slimesKilled++;
            heroUltKills++;
            addXp(30 + progression.skills.combat * 4);
            updateSwordUnlocks();
            checkAchievements();
            saveGame();
            slimes.splice(i, 1);

            if (s.type === "fire") showMessage("Feuer-Slime besiegt!");
            else if (s.type === "alien") showMessage("Alien-Slime besiegt!");
            else if (s.type === "desert") showMessage("Wüsten-Slime besiegt!");
            else showMessage("Slime mit Schwert besiegt!");
          }
        }
      }

      if (!hitSomething) showMessage("Daneben!");
    }

    function activateHeroAbility() {
      if (!selectedHero || !gameStarted) return;
      const hero = HEROES[selectedHero];
      if (heroCooldown > 0) { showMessage(`? Noch ${Math.ceil(heroCooldown / 60)}s Cooldown`); return; }
      heroCooldown = hero.cooldownFrames;
      const pc = player.x + player.w / 2;
      const pyc = player.y + player.h / 2;
      if (selectedHero === "ironshield") {
        effects.shield = Math.max(effects.shield, 240);
        showMessage("?? Energie-Schild aktiviert! (4s)");
      } else if (selectedHero === "thunderstrike") {
        let hit = 0;
        for (let i = slimes.length - 1; i >= 0; i--) {
          const s = slimes[i];
          const dx = (s.x + s.w / 2) - pc; const dy = (s.y + s.h / 2) - pyc;
          if (Math.sqrt(dx * dx + dy * dy) < 140) {
            s.health -= 4; s.hurtTimer = 15; hit++;
            if (s.health <= 0) { heroUltKills++; stats.slimesKilled++; addXp(30); slimes.splice(i, 1); }
          }
        }
        updateSwordUnlocks(); checkAchievements(); saveGame();
        showMessage(`? Blitzschlag! ${hit} Feinde getroffen!`);
      } else if (selectedHero === "shadowfist") {
        stealthState.active = true;
        stealthState.batteryMs = 5000;
        updateDerivedStats();
        showMessage("?? Unsichtbar für 5s!");
      } else if (selectedHero === "cosmicguard") {
        let hit = 0;
        for (let i = slimes.length - 1; i >= 0; i--) {
          const s = slimes[i];
          const dx = (s.x + s.w / 2) - pc; const dy = (s.y + s.h / 2) - pyc;
          if (Math.sqrt(dx * dx + dy * dy) < 160) {
            s.health -= 3; s.hurtTimer = 12; hit++;
            if (s.health <= 0) { heroUltKills++; stats.slimesKilled++; addXp(30); slimes.splice(i, 1); }
          }
        }
        updateSwordUnlocks(); checkAchievements(); saveGame();
        showMessage(`?? Energie-Explosion! ${hit} Feinde getroffen!`);
      }
    }

    function activateHeroUltimate() {
      if (!selectedHero || !gameStarted) return;
      const hero = HEROES[selectedHero];
      if (heroUltKills < hero.ultKillsNeeded) {
        showMessage(`? Ultimate: noch ${hero.ultKillsNeeded - heroUltKills} Kills nötig`);
        return;
      }
      heroUltKills = 0;
      const cam = getCamera();
      let killed = 0;
      for (let i = slimes.length - 1; i >= 0; i--) {
        const s = slimes[i];
        const sx = s.x - cam.x; const sy = s.y - cam.y;
        if (sx > -80 && sx < canvas.width + 80 && sy > -80 && sy < canvas.height + 80) {
          stats.slimesKilled++; addXp(30); slimes.splice(i, 1); killed++;
        }
      }
      if (selectedHero === "ironshield") { effects.shield = Math.max(effects.shield, 360); showMessage(`?? RAKETEN-SALVE! ${killed} Feinde eliminiert!`, 2400); }
      else if (selectedHero === "thunderstrike") { showMessage(`? DONNER-NOVA! ${killed} Feinde vom Blitz getroffen!`, 2400); }
      else if (selectedHero === "shadowfist") { showMessage(`?? SCHATTENBLITZ! ${killed} Feinde eliminiert!`, 2400); }
      else if (selectedHero === "cosmicguard") { player.health = Math.min(player.maxHealth, player.health + 2); showMessage(`?? SUPERNOVA! ${killed} Feinde vernichtet!`, 2400); }
      updateSwordUnlocks(); checkAchievements(); saveGame(); updateUI();
    }

