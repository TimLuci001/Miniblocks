    function initRiftAudio() {
      if (riftAudioReady) return;
      try {
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        if (!AudioContext) return;
        riftAudioCtx = new AudioContext();
        riftAudioOsc = riftAudioCtx.createOscillator();
        riftAudioGain = riftAudioCtx.createGain();
        riftAudioOsc.type = "sawtooth";
        riftAudioOsc.frequency.value = 48;
        riftAudioGain.gain.value = 0;
        riftAudioOsc.connect(riftAudioGain);
        riftAudioGain.connect(riftAudioCtx.destination);
        riftAudioOsc.start();
        riftAudioReady = true;
      } catch (err) {
        riftAudioReady = false;
      }
    }

    function updateRiftAudio() {
      if (!riftAudioReady || !riftAudioGain || !riftAudioCtx) return;
      const target = riftEffectsEnabled && isRiftBiome() ? 0.08 : 0;
      const now = riftAudioCtx.currentTime;
      riftAudioGain.gain.cancelScheduledValues(now);
      riftAudioGain.gain.linearRampToValueAtTime(target, now + 0.3);
    }

    function spawnRiftParticle(cam) {
      const baseX = Math.max(RIFT_BIOME_START * TILE, cam.x);
      const maxX = Math.max(baseX + 1, cam.x + canvas.width);
      const x = baseX + Math.random() * (maxX - baseX);
      const y = cam.y + 40 + Math.random() * (canvas.height - 120);
      riftParticles.push({
        x,
        y,
        vx: -0.2 + Math.random() * 0.4,
        vy: -0.4 - Math.random() * 0.6,
        life: 120 + Math.random() * 80,
        size: 1.5 + Math.random() * 2.5,
        alpha: 0.3 + Math.random() * 0.4
      });
    }

    function updateRiftParticles(cam) {
      if (!riftEffectsEnabled || !isRiftBiome()) {
        riftParticles.length = 0;
        return;
      }
      const spawnCount = Math.random() < 0.6 ? 1 : 2;
      for (let i = 0; i < spawnCount; i++) spawnRiftParticle(cam);
      for (let i = riftParticles.length - 1; i >= 0; i--) {
        const p = riftParticles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.life -= 1;
        p.alpha *= 0.992;
        if (p.life <= 0 || p.alpha < 0.04 || p.y < cam.y - 80) {
          riftParticles.splice(i, 1);
        }
      }
      if (riftParticles.length > 140) {
        riftParticles.splice(0, riftParticles.length - 140);
      }
    }

    function drawRiftParticles(cam) {
      if (!riftEffectsEnabled || !isRiftBiome() || riftParticles.length === 0) return;
      ctx.save();
      for (const p of riftParticles) {
        const sx = p.x - cam.x;
        const sy = p.y - cam.y;
        if (sx < -20 || sy < -20 || sx > canvas.width + 20 || sy > canvas.height + 20) continue;
        ctx.fillStyle = `rgba(140, 210, 255, ${p.alpha})`;
        ctx.beginPath();
        ctx.ellipse(sx, sy, p.size, p.size * 1.6, 0, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }

    function updateRiftGlitch() {
      if (!riftEffectsEnabled || !isRiftBiome() || !gameStarted) {
        riftGlitchTimer = 0;
        return;
      }
      const now = Date.now();
      if (riftNextGlitchAt === 0) {
        riftNextGlitchAt = now + 3000 + Math.random() * 4000;
      }
      if (now >= riftNextGlitchAt) {
        riftGlitchTimer = 6 + Math.floor(Math.random() * 6);
        riftNextGlitchAt = now + 3200 + Math.random() * 5000;
      }
      if (riftGlitchTimer > 0) riftGlitchTimer--;
    }

    function drawRiftGlitchOverlay(cam) {
      if (!riftEffectsEnabled || !isRiftBiome() || riftGlitchTimer <= 0) return;
      ctx.save();
      ctx.globalAlpha = 0.22;
      ctx.fillStyle = "rgba(130, 180, 255, 0.35)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.globalAlpha = 0.4;
      ctx.strokeStyle = "rgba(180, 230, 255, 0.6)";
      for (let i = 0; i < 6; i++) {
        const y = 40 + i * 40 + Math.sin(dayTime * 3 + i) * 6;
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(canvas.width, y + (Math.random() * 8 - 4));
        ctx.stroke();
      }
      ctx.restore();
    }

