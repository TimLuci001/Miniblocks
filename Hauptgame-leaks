    function setActiveCreativeWorld(id, applyToWorld = true) {
      const entry = getCreativeWorldById(id);
      if (!entry) return false;
      activeCreativeWorldId = entry.id;
      if (applyToWorld) {
        const fallback = createBaseWorldGrid();
        for (let y = 0; y < WORLD_HEIGHT; y++) {
          world[y] = entry.data[y] ? entry.data[y].slice() : fallback[y].slice();
        }
        creativeDevices = Array.isArray(entry.devices) ? entry.devices : [];
        applyCreativeSettings(entry.settings || getCreativeSettingsDefaults());
        if (isThreeDMode && threeDState.active) {
          const threeData = entry.three || createBaseThreeWorldData();
          applyThreeWorldData(threeData);
        }
      }
      return true;
    }

    function ensureActiveCreativeWorld() {
      if (activeCreativeWorldId && getCreativeWorldById(activeCreativeWorldId)) return;
      if (creativeWorlds.length) {
        activeCreativeWorldId = creativeWorlds[0].id;
