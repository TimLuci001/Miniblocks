    function getFreeCrateCooldownMs() {
      const reduction = Math.min(0.6, progression.skills.fortune * 0.06);
      return Math.floor(1000 * 60 * 10 * (1 - reduction));
    }

    function isFreeCrateReady() {
      return Date.now() >= (freeCrateState.nextClaimAt || 0);
