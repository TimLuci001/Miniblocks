    async function syncLobbyFriendRequestsFromSupabase(playerKey = cloudPlayerKey) {
      if (!supabaseClient || !playerKey) return false;
      const previousIncomingCount = (lobbyFriendRequestState.incomingFriends?.length || 0) + (lobbyFriendRequestState.incomingParty?.length || 0);
      const [incomingRows, outgoingRows] = await Promise.all([
        fetchCloudSocialRequests(playerKey, "incoming"),
        fetchCloudSocialRequests(playerKey, "outgoing")
      ]);

      const incoming = incomingRows.map((entry) => normalizeLobbyRequestEntry(entry));
      const outgoing = outgoingRows.map((entry) => normalizeLobbyRequestEntry(entry));

      lobbyFriendRequestState = {
        incomingFriends: incoming.filter((entry) => entry.requestType === "friend"),
        incomingParty: incoming.filter((entry) => entry.requestType === "party"),
        outgoingFriends: outgoing.filter((entry) => entry.requestType === "friend"),
        outgoingParty: outgoing.filter((entry) => entry.requestType === "party")
      };

      const nextIncomingCount = lobbyFriendRequestState.incomingFriends.length + lobbyFriendRequestState.incomingParty.length;
      if (inLobby && nextIncomingCount > previousIncomingCount) {
        showMessage("Neue Anfrage in deiner Freundesliste!");
      }
      renderLobbyFriendsPanel();
      return true;
    }

