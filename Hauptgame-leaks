      const armLeft = new THREE.Mesh(new THREE.BoxGeometry(0.18, 0.56, 0.22), jacketMat);
      armLeft.position.set(-0.38, 1.02, 0);
      group.add(armLeft);

      const armRight = new THREE.Mesh(new THREE.BoxGeometry(0.18, 0.56, 0.22), jacketMat);
      armRight.position.set(0.38, 1.02, 0);
      group.add(armRight);

      const handLeft = new THREE.Mesh(new THREE.BoxGeometry(0.16, 0.16, 0.2), skinMat);
      handLeft.position.set(-0.38, 0.72, 0);
      group.add(handLeft);

      const handRight = new THREE.Mesh(new THREE.BoxGeometry(0.16, 0.16, 0.2), skinMat);
      handRight.position.set(0.38, 0.72, 0);
      group.add(handRight);

      const legLeft = new THREE.Mesh(new THREE.BoxGeometry(0.22, 0.6, 0.24), pantsMat);
      legLeft.position.set(-0.14, 0.3, 0);
      group.add(legLeft);

      const legRight = new THREE.Mesh(new THREE.BoxGeometry(0.22, 0.6, 0.24), pantsMat);
      legRight.position.set(0.14, 0.3, 0);
      group.add(legRight);

      const bootLeft = new THREE.Mesh(new THREE.BoxGeometry(0.24, 0.16, 0.32), shoesMat);
      bootLeft.position.set(-0.14, 0.05, 0.04);
      group.add(bootLeft);

      const bootRight = new THREE.Mesh(new THREE.BoxGeometry(0.24, 0.16, 0.32), shoesMat);
      bootRight.position.set(0.14, 0.05, 0.04);
      group.add(bootRight);

      const scarf = new THREE.Mesh(new THREE.BoxGeometry(0.52, 0.12, 0.36), accentMat);
      scarf.position.set(0, 1.28, 0.02);
      group.add(scarf);

