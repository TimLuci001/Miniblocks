    function renderLockerLobbyBackgroundSection() {
      ensureLobbyBackgroundOwnership();
      const allBackgrounds = getAllLobbyBackgrounds();
      if (allBackgrounds.length <= 1) return "";
      const backgroundFilterTabs = [
        { id: "all", label: "Alle" },
        { id: "season5", label: "Season 5" },
        { id: "season4", label: "Season 4" },
        { id: "youtube", label: "YouTube" }
      ];

      const normalizedFilter = ["all", "season5", "season4", "youtube"].includes(lockerLobbyBackgroundFilter)
        ? lockerLobbyBackgroundFilter
        : "all";
      lockerLobbyBackgroundFilter = normalizedFilter;

      const filteredBackgrounds = allBackgrounds.filter((background) => {
        if (normalizedFilter === "season5") return background.id.startsWith("rift_oasis") || background.id.startsWith("season5_");
        if (normalizedFilter === "season4") return background.id.startsWith("season4_");
        if (normalizedFilter === "youtube") return background.sourceType === "custom";
        return true;
      });

      const cards = filteredBackgrounds.map((background) => {
        const rarityMeta = getRarityMeta(background.rarity || "common");
        const owned = playerSkin.ownedLobbyBackgrounds.includes(background.id);
        const isActive = owned && playerSkin.activeLobbyBackground === background.id;
        const unlockState = getLobbyBackgroundUnlockState(background);

        let actionLabel = "Gesperrt";
        let actionDisabled = true;
        let actionType = "lobbyBackgroundLocked";
        if (owned) {
          actionLabel = isActive ? "Aktiv" : "Anlegen";
          actionDisabled = false;
          actionType = "lobbyBackgroundEquip";
        } else if (unlockState.unlockable) {
          actionLabel = background.sourceType === "shop"
            ? `Freischalten (${formatCurrency(background.price || 0)})`
            : "Freischalten";
          actionDisabled = false;
          actionType = "lobbyBackgroundUnlock";
        }

        return `
          <div class="lockerTile ${isActive ? "active" : ""}">
            <div class="lockerTileHead">
              <div class="lockerTileStatus ${isActive ? "activeTag" : "storedTag"}">${owned ? (isActive ? "Aktiv" : "Freigeschaltet") : "Gesperrt"}</div>
              <div class="shopBadge ${rarityMeta.type}">${rarityMeta.label}</div>
            </div>
            <div class="lockerTileMedia">
              <div class="shopPreview lockerBgPreview" style="background-image:linear-gradient(160deg, rgba(10, 16, 28, 0.2), rgba(10, 16, 28, 0.4)), url('${background.image}');"></div>
            </div>
            <div class="lockerTileBody">
              <div class="lockerTileName">${background.name}</div>
              <div class="lockerTileMeta">${background.dynamic ? "Dynamischer Lobby-Hintergrund mit animiertem Overlay." : "Statischer Lobby-Hintergrund mit eigenem Bildstil."}</div>
              <div class="lockerMetaTags">
                <div class="shopBadge owned">${background.sourceLabel}</div>
                ${background.dynamic ? `<div class="shopBadge active">Dynamisch</div>` : `<div class="shopBadge common">Statisch</div>`}
              </div>
              ${!owned ? `<div class="lockerTileMeta" style="margin-top:10px;">${unlockState.reason}</div>` : ""}
            </div>
            <div class="lockerTileFoot">
              <div class="shopBadge ${owned ? "owned" : "expensive"}">${owned ? "Im Spind" : "Noch nicht frei"}</div>
              <button class="shopActionBtn" data-locker-type="${actionType}" data-locker-id="${background.id}" ${actionDisabled ? "disabled" : ""}>${actionLabel}</button>
            </div>
          </div>
        `;
      }).join("");

      const filterButtons = backgroundFilterTabs.map((tab) => `
        <button class="lockerFilterBtn ${normalizedFilter === tab.id ? "active" : ""}" data-bg-filter="${tab.id}">${tab.label}</button>
      `).join("");
      const filteredOwnedCount = filteredBackgrounds.filter((background) => playerSkin.ownedLobbyBackgrounds.includes(background.id)).length;
      const filteredCountLabel = normalizedFilter === "all"
