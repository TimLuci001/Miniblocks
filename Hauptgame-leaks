    function buildShopBadges({ type, id, rarity = "common", owned = false, active = false, finalPrice = 0, inventoryCount = 0 }) {
      const badges = [];
      const entry = getShopStateEntry(type, id);
      const effectiveDiscount = getEffectiveDiscount(type, id);
      const rarityMeta = getRarityMeta(rarity);

      badges.push({ label: rarityMeta.label, type: rarityMeta.type });

      if (active) badges.push({ label: "Aktiv", type: "active" });
      else if (owned) badges.push({ label: "Besitzt du", type: "owned" });

      if (!owned && inventory[7] < finalPrice) badges.push({ label: "Zu teuer", type: "expensive" });
      else if (effectiveDiscount > 0) badges.push({ label: `-${effectiveDiscount}% Rabatt`, type: "discount" });

      if (isNewShopItem(type, id)) badges.push({ label: "Neu", type: "new" });
      if (isTimeLimitedShopItem(type, id)) badges.push({ label: "? Limitiert", type: "limited" });

      if (type === "consumables" && inventoryCount > 0) badges.push({ label: `Vorrat: ${inventoryCount}`, type: "stock" });

      return badges.slice(0, 3);
    }

