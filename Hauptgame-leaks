    function openLobby() {
      if (lobbyReadyTransitionTimer) {
        clearTimeout(lobbyReadyTransitionTimer);
        lobbyReadyTransitionTimer = null;
      }
      if (currentMatchMode === "creative") {
        saveActiveCreativeWorldSnapshot();
        restoreMainWorldBackup();
        creativeTestMode = false;
        creativeSetSpawnActive = false;
        stopThreeDMode();
      }
      lobbyReadyAnimating = false;
      lobbyActionPanelState.text = "";
      inLobby = true;
      gameStarted = false;
      if (skyModeWorldBackup) restoreSkySurvivalWorld();
      currentMatchMode = "normal";
      isThreeDMode = false;
      stopRiftRush();
      resetDossierHunt();
      stealthState.active = false;
      resetAlarmState();
      resetFloorLavaState();
      resetCommunityMeteorEvent();
      closeMenus();
      cancelMining();
      if (lobbyScreen) lobbyScreen.classList.remove("isLaunching");
      if (lobbyReadyBtn) {
        lobbyReadyBtn.classList.remove("isLaunching");
        lobbyReadyBtn.disabled = false;
      }
      renderLobbyScreen();
      startLobbyMiniEvents();
      startLobbyAmbientAudio();
      updateLobbyUi();
      updateUI();
    }

    function finalizeEnterGameWorld() {
      try {
        stopLobbyMiniEvents();
      } catch {}
      try {
        stopLobbyAmbientAudio();
      } catch {}

      lobbyReadyAnimating = false;
      if (lobbyReadyTransitionTimer) {
        clearTimeout(lobbyReadyTransitionTimer);
        lobbyReadyTransitionTimer = null;
      }

      if (lobbyScreen) lobbyScreen.classList.remove("isLaunching");
      if (lobbyReadyBtn) {
        lobbyReadyBtn.classList.remove("isLaunching");
        lobbyReadyBtn.disabled = false;
      }
      const lobbyPortalBtn = document.getElementById("lobbyPortalBtn");
      if (lobbyPortalBtn) lobbyPortalBtn.classList.remove("isLaunching");

      currentMatchMode = selectedLobbyMode === "rift"
        ? "rift"
        : (selectedLobbyMode === "creative"
          ? "creative"
          : (selectedLobbyMode === "stealth"
            ? "stealth"
            : (selectedLobbyMode === "dossier" ? "dossier" : "normal")));
      isThreeDMode = currentMatchMode === "creative";
      lastPlayedLobbyMode = selectedLobbyMode;
      inLobby = false;
      gameStarted = true;

      if (currentMatchMode === "creative") {
        saveMainWorldBackup();
        if (!creativeWorlds.length) {
          createCreativeWorld("Meine Insel");
        } else {
          ensureActiveCreativeWorld();
        }
        if (activeCreativeWorldId) setActiveCreativeWorld(activeCreativeWorldId);
      }

      try {
        closeMenus();
      } catch {}
      if (currentMatchMode === "rift") {
        startRiftRush();
      } else {
        stopRiftRush();
      }
      if (isStealthModeActive()) {
        stealthState.active = false;
        stealthState.batteryMs = stealthState.maxBatteryMs;
        stealthState.cooldownMs = 0;
        resetAlarmState();
      }
      if (isDossierModeActive()) {
        initDossierHunt();
      } else {
        resetDossierHunt();
      }
      try {
        if (isThreeDMode) startThreeDMode();
      } catch (error) {
        console.error("Lobby start fallback:", error);
      }
      try {
        updateLobbyUi();
      } catch {}
      try {
        updateUI();
      } catch {}
      showMessage(
        selectedLobbyMode === "rift"
          ? "Rift-Rush gestartet!"
          : (selectedLobbyMode === "creative" ? "Creative gestartet!" : "Solo gestartet!"),
        1800
      );
    }

    function enterGameWorld(skipAnimation = false, rulesAccepted = false) {
      if (isBattlePassExpired()) {
        showMessage(`Season 7 endet am ${BATTLE_PASS_END_LABEL}. Modi und Pass-Fortschritt werden danach eingefroren.`, 2800);
        return;
      }
      if (!rulesAccepted && inLobby) {
        if (openModeRulesMenuForStart()) return;
      }
      if (lobbyReadyAnimating && !skipAnimation) return;
      if (!skipAnimation && inLobby && lobbyScreen && lobbyReadyBtn) {
        lobbyReadyAnimating = true;
        lobbyScreen.classList.add("isLaunching");
        lobbyReadyBtn.classList.add("isLaunching");
        lobbyReadyBtn.disabled = true;
        const lobbyPortalBtn = document.getElementById("lobbyPortalBtn");
        if (lobbyPortalBtn) lobbyPortalBtn.classList.add("isLaunching");
        lobbyReadyTransitionTimer = setTimeout(() => {
          finalizeEnterGameWorld();
        }, 760);
        return;
      }
      finalizeEnterGameWorld();
    }

