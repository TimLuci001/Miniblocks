        return diff.map((entry) => ({
          code: normalizeLeakCode(entry.code || ""),
          title: entry.title || "",
          text: entry.text || "",
          status: entry.status || "new"
        })).filter((entry) => entry.code && entry.title && entry.text);
      }
      return [];
