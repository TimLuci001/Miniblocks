      `;

      const unequipBtn = document.getElementById("unequipSpecialSkinBtn");
      if (unequipBtn && playerSkin.activeSpecial) unequipBtn.addEventListener("click", () => equipSkinFromLocker("specials", null));

      lockerContent.querySelectorAll("button[data-locker-type]").forEach((button) => {
        button.addEventListener("click", () => {
          if (button.dataset.lockerType === "outfits") {
            equipOutfitFromLocker(button.dataset.lockerId);
          } else if (button.dataset.lockerType === "lobbyBackgroundEquip") {
            equipLobbyBackgroundFromLocker(button.dataset.lockerId);
          } else if (button.dataset.lockerType === "lobbyBackgroundUnlock") {
            unlockLobbyBackgroundFromLocker(button.dataset.lockerId);
          } else if (button.dataset.lockerType === "lobbyBackgroundAddYoutube") {
            addYoutubeLobbyBackgroundFromLocker();
          } else {
            equipSkinFromLocker(button.dataset.lockerType, button.dataset.lockerId);
          }
        });
      });

      lockerContent.querySelectorAll("button[data-bg-filter]").forEach((button) => {
        button.addEventListener("click", () => {
          const filter = button.dataset.bgFilter;
          if (!filter || filter === lockerLobbyBackgroundFilter) return;
          lockerLobbyBackgroundFilter = filter;
          renderLocker();
        });
      });
    }

