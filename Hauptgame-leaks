    function getBattlePassLaneLabel(lane) {
      return lane === "premium" ? "PREMIUM" : "KOSTENLOS";
    }

    function isBattlePassLaneUnlocked(lane) {
      return lane === "premium" ? battlePassState.premiumUnlocked : true;
    }

    function getBattlePassLaneClaimedList(lane) {
      return lane === "premium" ? battlePassState.claimedPremium : battlePassState.claimedFree;
    }

    function getBattlePassLaneReward(entry, lane) {
      return lane === "premium" ? entry.premium : entry.free;
    }

    function claimBattlePassReward(tier, lane) {
      const entry = battlePassRewards.find(item => item.tier === tier);
      if (!entry) return;
      if (BATTLE_PASS_MAIN_TRACK_DISABLED) {
        showMessage("Kostenlos und Premium sind wegen Problemen gerade entfernt!");
        return;
      }

      const reward = getBattlePassLaneReward(entry, lane);
      const claimedList = getBattlePassLaneClaimedList(lane);

      if (isBattlePassExpired()) {
        showMessage("Battle Pass ist abgelaufen!");
        return;
      }
      if (!isBattlePassLaneUnlocked(lane)) {
        showMessage("Premium-Reihe ist noch gesperrt. Bitte zuerst ein Premium-Paket kaufen!");
        return;
      }
      if (!getBattlePassTierUnlocked(tier)) {
        showMessage("Diese Stufe ist noch nicht freigeschaltet!");
        return;
      }
      if (claimedList.includes(tier)) {
        showMessage("Belohnung schon abgeholt!");
        return;
      }

      grantBattlePassReward(reward);
      claimedList.push(tier);
      renderBattlePass();
      renderInventory();
      renderShop();
      renderSkills();
      renderLocker();
      updateUI();
      if (reward.type === "specialSkin" || reward.type === "rainColor" || (reward.type === "currency" && Number(reward.amount || 0) >= 300)) {
        const itemData = reward.type === "specialSkin"
          ? getSpecialSkinData(reward.id)
          : (reward.type === "rainColor" ? getRainColorData(reward.id) : null);
        openShopPurchaseModal({
          lead: `Battle Pass Belohnung aus ${getBattlePassLaneLabel(lane)} auf Stufe ${tier}.`,
          rewards: [
            reward.type === "currency"
              ? `+${Number(reward.amount || 0).toLocaleString("de-DE")} ${CURRENCY_NAME}`
              : `${reward.type === "specialSkin" ? "Spezial-Skin" : "Regenfarbe"}: ${itemData?.name || reward.label}`
          ],
          equipAction: reward.type === "specialSkin"
            ? () => {
              playerSkin.activeSpecial = reward.id;
              saveGame();
              renderShop();
              renderLocker();
              updateUI();
              closeShopPurchaseModal();
              showMessage(`${itemData?.name || reward.label} ausgeruestet!`, 1800);
            }
            : (reward.type === "rainColor"
              ? () => {
                playerSkin.activeRain = reward.id;
                saveGame();
                renderShop();
                renderLocker();
                updateUI();
                closeShopPurchaseModal();
                showMessage(`${itemData?.name || reward.label} ausgeruestet!`, 1800);
              }
              : null),
          equipLabel: reward.type === "currency" ? "Weiter" : "Direkt ausruesten"
        });
      } else {
        showMessage(`Battle Pass: ${reward.label} erhalten!`, 2200);
      }
      queueDeferredSave();
    }

    function getClaimableBattlePassRewards() {
      if (BATTLE_PASS_MAIN_TRACK_DISABLED || isBattlePassExpired()) return [];
      const claimable = [];
      for (const entry of battlePassRewards) {
        if (!getBattlePassTierUnlocked(entry.tier)) continue;
        if (!battlePassState.claimedFree.includes(entry.tier)) {
          claimable.push({ type: "battle", tier: entry.tier, lane: "free", reward: entry.free });
        }
        if (battlePassState.premiumUnlocked && !battlePassState.claimedPremium.includes(entry.tier)) {
          claimable.push({ type: "battle", tier: entry.tier, lane: "premium", reward: entry.premium });
        }
      }
      return claimable;
    }

    function getClaimableNudelPassRewards() {
      if (!nudelPassState.unlocked) return [];
      return nudelPassRewards
        .filter((entry) => isNudelPassTierUnlocked(entry.tier) && !nudelPassState.claimedTiers.includes(entry.tier))
        .map((entry) => ({ type: "nudel", tier: entry.tier, reward: entry.reward }));
    }

    function getClaimableMiniPassRewards() {
      if (MINI_PASS_DISABLED || isMiniPassExpired()) return [];
      return miniPassRewards
        .filter((entry) => isMiniPassTierUnlocked(entry.tier) && !miniPassState.claimedTiers.includes(entry.tier))
        .map((entry) => ({ type: "mini", tier: entry.tier, reward: entry.reward }));
    }

    function getClaimableCommunityPassRewards() {
      const progress = getCommunityEventProgress();
      return getCommunityPassMilestones()
        .filter((entry) => progress >= entry.percent && !communityPassState.claimedMilestones.includes(entry.percent))
        .map((entry) => ({ type: "community", percent: entry.percent, reward: entry.reward }));
    }

    function getClaimablePassRewards() {
      return [
        ...getClaimableBattlePassRewards(),
        ...getClaimableNudelPassRewards(),
        ...getClaimableMiniPassRewards(),
        ...getClaimableCommunityPassRewards()
      ];
    }

    function claimAllAvailablePassRewards() {
      const claimable = getClaimablePassRewards();
      if (!claimable.length) {
        showMessage("Aktuell gibt es im Pass nichts zum Abholen!", 2200);
        return;
      }

      let totalCurrency = 0;
      let totalRewards = 0;

      for (const entry of claimable) {
        if (entry.type === "battle") {
          grantBattlePassReward(entry.reward);
          const targetList = entry.lane === "premium" ? battlePassState.claimedPremium : battlePassState.claimedFree;
          if (!targetList.includes(entry.tier)) targetList.push(entry.tier);
        } else if (entry.type === "nudel") {
          grantBattlePassReward(entry.reward);
          if (!nudelPassState.claimedTiers.includes(entry.tier)) nudelPassState.claimedTiers.push(entry.tier);
        } else if (entry.type === "mini") {
          grantBattlePassReward(entry.reward);
          if (!miniPassState.claimedTiers.includes(entry.tier)) miniPassState.claimedTiers.push(entry.tier);
        } else if (entry.type === "community") {
          if (entry.reward.type === "gold" || entry.reward.type === "currency") inventory[7] += entry.reward.amount;
          if (entry.reward.type === "combo") {
            inventory[7] += entry.reward.currency;
            if (!playerSkin.ownedSpecials.includes(entry.reward.skinId)) {
              playerSkin.ownedSpecials.push(entry.reward.skinId);
              ensureSkinStored("specials", entry.reward.skinId);
            }
          }
          if (!communityPassState.claimedMilestones.includes(entry.percent)) communityPassState.claimedMilestones.push(entry.percent);
        }

        if (entry.reward?.type === "currency") totalCurrency += Number(entry.reward.amount || 0);
        if (entry.reward?.type === "combo") totalCurrency += Number(entry.reward.currency || 0);
        totalRewards++;
      }

      renderBattlePass();
      renderInventory();
      renderShop();
      renderSkills();
      renderLocker();
      renderCommunityEvent();
      updateUI();
      queueDeferredSave();

      const currencyText = totalCurrency > 0 ? ` und ${totalCurrency.toLocaleString("de-DE")} ${CURRENCY_NAME}` : "";
      showMessage(`${totalRewards} Pass-Belohnungen${currencyText} gesammelt!`, 2600);
    }

    function getSeasonMemoryCards() {
      const totalClaimed = (battlePassState.claimedFree.length || 0)
        + (battlePassState.claimedPremium.length || 0)
        + (nudelPassState.claimedTiers.length || 0)
        + (miniPassState.claimedTiers.length || 0)
        + (communityPassState.claimedMilestones.length || 0);
      const lastModeLabel = lastPlayedLobbyMode ? getLobbyModeLabel(lastPlayedLobbyMode) : "Noch keiner";
      return [
        { label: "Letzter Run", value: lastModeLabel, meta: "Zuletzt gespielter Modus" },
        { label: "Rewards", value: totalClaimed.toLocaleString("de-DE"), meta: "Belohnungen in dieser Season abgeholt" },
        { label: "Riss-Status", value: "Stabilisiert", meta: "Chapter 2 Fortschritt gespeichert" }
      ];
    }

