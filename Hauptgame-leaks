      if (nextText === HEARTS_WARNING_LEGACY) nextText = "";
      const nextScope = hasScope
        ? normalizeHeartsWarningScope(payload.scope ?? payload.hearts_warning_scope)
        : normalizeHeartsWarningScope(heartsWarningState.scope);
      const normalizedText = normalizeHeartsWarningText(nextText);
      heartsWarningState = {
        active: nextActive,
        text: normalizedText,
        scope: nextScope
      };
      updateAdminHeartsWarningInfo();
      saveHeartsWarningStateLocal();
      updateHeartsHud();
      updateLobbyUi();
    }

