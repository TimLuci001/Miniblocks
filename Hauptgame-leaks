    function updateFloodHud() {
      if (!floodModeInline || !floodModeHudTimer || !floodModeHudMeta || !floodModeHudFill) return;
      if (!gameStarted || inLobby || !isFloodModeActive()) {
        floodModeInline.classList.add("hidden");
        return;
