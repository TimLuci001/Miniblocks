    function drawFloorLava(cam) {
      if (!isFloorLavaModeActive()) return;
      const surfaceY = getFloorLavaSurfaceY();
      const screenY = surfaceY - cam.y;
      if (screenY > canvas.height) return;

      ctx.save();
      const fillStartY = Math.max(-30, screenY);
      const lavaGradient = ctx.createLinearGradient(0, fillStartY, 0, canvas.height);
      lavaGradient.addColorStop(0, "rgba(255, 140, 80, 0.45)");
      lavaGradient.addColorStop(0.18, "rgba(255, 84, 40, 0.85)");
      lavaGradient.addColorStop(1, "rgba(96, 18, 8, 0.96)");
      ctx.fillStyle = lavaGradient;
      ctx.fillRect(0, fillStartY, canvas.width, canvas.height - fillStartY);

      ctx.fillStyle = "rgba(255, 210, 160, 0.8)";
      for (let i = 0; i < canvas.width; i += 36) {
        const waveY = fillStartY + Math.sin((Date.now() / 240) + i * 0.06) * 3;
        ctx.fillRect(i, waveY, 22, 2);
      }
      ctx.restore();
    }

    function drawVolcanoLava(cam) {
      if (!isVolcanoSeasonActive()) return;
