    function updateVolcanoLavaMode() {
      if (!isVolcanoSeasonActive()) {
        volcanoState.damageTick = 0;
        volcanoState.startedAt = 0;
        return;
      }

      const lavaSurfaceY = getVolcanoLavaSurfaceY();
      if (player.y + player.h >= lavaSurfaceY) {
        volcanoState.damageTick++;
