        ...playerSkin.ownedRains.map((id) => getSkinData("rains", id)),
        ...playerSkin.ownedSpecials.map((id) => getSkinData("specials", id))
      ].filter(Boolean);
      const mythicCount = ownedAll.filter((item) => (item.rarity || "common") === "mythic").length;
