    function tradeWithNpc(entry) {
      if (!entry) return;

      if (entry.type === "buy") {
        if (inventory[7] < entry.price) {
          showMessage("Nicht genug M-Bucks!");
          return;
        }

        inventory[7] -= entry.price;
        inventory[entry.itemId] = (inventory[entry.itemId] || 0) + entry.amount;
        showMessage(`${entry.amount}x ${getBlockName(entry.itemId)} gekauft!`);
      }

      if (entry.type === "sell") {
        if ((inventory[entry.itemId] || 0) < entry.amount) {
          showMessage(`Du brauchst ${entry.amount}x ${getBlockName(entry.itemId)}!`);
          return;
        }

        inventory[entry.itemId] -= entry.amount;
        inventory[7] += entry.price;
        showMessage(`${entry.amount}x ${getBlockName(entry.itemId)} verkauft!`);
      }

