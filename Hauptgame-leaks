    function buildShopSkinCard(type, item) {
      const finalPrice = getDiscountedPrice(item.price, type, item.id);
      const effectiveDiscount = getEffectiveDiscount(type, item.id);
      const wishlisted = isWishlisted(type, item.id);
      const owned = type === "eyes"
        ? playerSkin.ownedEyes.includes(item.id)
        : type === "rains"
          ? playerSkin.ownedRains.includes(item.id)
        : type === "bodies"
          ? playerSkin.ownedBodies.includes(item.id)
          : playerSkin.ownedSpecials.includes(item.id);
      const active = type === "eyes"
        ? !playerSkin.activeSpecial && playerSkin.activeEyes === item.id
        : type === "rains"
          ? playerSkin.activeRain === item.id
        : type === "bodies"
          ? !playerSkin.activeSpecial && playerSkin.activeBody === item.id
          : playerSkin.activeSpecial === item.id;
      const badges = buildShopBadges({ type, id: item.id, rarity: item.rarity, owned, active, finalPrice });

      return `
        <div class="shopItem ${owned ? "owned" : ""} ${active ? "active" : ""} ${effectiveDiscount > 0 ? "discount" : ""} ${wishlisted ? "wishlisted" : ""}" data-preview-type="${type}" data-preview-id="${item.id}">
          ${renderShopBadges(badges)}
          ${getShopPreviewMarkup(type, item)}
          <div><strong>${item.name}</strong></div>
          <div class="shopPrice">
            ${effectiveDiscount > 0 ? `Preis: <span class="oldPrice">${item.price}</span> <span class="salePrice">${formatCurrency(finalPrice)}</span>` : `Preis: ${formatCurrencyMarkup(finalPrice)}`}<br>
            ${type === "specials" ? "Kompletter Spezial-Look mit eigenem Effekt." : (type === "rains" ? "Faerbt Regen und Gewitter mit deiner ausgewaehlten Farbe ein." : "Vorschau zeigt deinen Charakter direkt mit diesem Look.")}
          </div>
          <div class="shopActionRow">
            <button class="shopActionBtn" data-shop-type="${type}" data-shop-id="${item.id}">${owned ? (active ? "Aktiv" : "Ausrüsten") : "Kaufen"}</button>
            <button class="shopActionBtn shopWishlistBtn" data-wishlist-type="${type}" data-wishlist-id="${item.id}">${wishlisted ? "♥" : "♡"}</button>
          </div>
        </div>
      `;
    }

