    function applyCommunityEventPayload(payload = {}, { fromSync = false, showUnlockMessage = true } = {}) {
      const savedSeasonId = payload?.seasonId || "legacy";
      if (savedSeasonId !== COMMUNITY_EVENT_SEASON_ID) {
        resetCommunityEventState();
        if (fromSync) renderCommunityEvent();
        return false;
      }

      communityEventState.seasonId = COMMUNITY_EVENT_SEASON_ID;
      if (typeof payload.totalBlocks === "number") communityEventState.totalBlocks = Math.max(0, payload.totalBlocks);
      if (typeof payload.targetBlocks === "number") communityEventState.targetBlocks = payload.targetBlocks;
      if (typeof payload.endAt === "number") communityEventState.endAt = payload.endAt;
      if (typeof payload.biomeUnlocked === "boolean") communityEventState.biomeUnlocked = payload.biomeUnlocked;
      ensureCommunityPassBaseUnlocked();

      if (communityEventState.totalBlocks >= communityEventState.targetBlocks) {
        communityEventState.totalBlocks = Math.max(communityEventState.totalBlocks, communityEventState.targetBlocks);
        communityEventState.biomeUnlocked = true;
      }

      if (communityEventState.biomeUnlocked) {
        applyCommunityBiomeWorld();
        applyRiftBiomeWorld();
        if (showUnlockMessage && !communityEventState.biomeAnnouncementShown) {
          communityEventState.biomeAnnouncementShown = true;
          showMessage("Community-Event geschafft! Neues Kristall-Biom freigeschaltet!", 3200);
        }
      } else {
        communityEventState.biomeAnnouncementShown = false;
        applyRiftBiomeWorld();
      }

      saveCommunityEventLocal();
      if (fromSync) renderCommunityEvent();
      return true;
    }

