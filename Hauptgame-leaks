        if (parsed.progression.skills) Object.assign(progression.skills, parsed.progression.skills);
      } else {
        resetProgressionForCurrentSeason();
      }

      if (parsed.playerSkin) {
        if (Array.isArray(parsed.playerSkin.ownedEyes)) playerSkin.ownedEyes = parsed.playerSkin.ownedEyes;
        if (Array.isArray(parsed.playerSkin.ownedBodies)) playerSkin.ownedBodies = parsed.playerSkin.ownedBodies;
        if (Array.isArray(parsed.playerSkin.ownedRains)) playerSkin.ownedRains = parsed.playerSkin.ownedRains;
        if (Array.isArray(parsed.playerSkin.ownedSpecials)) playerSkin.ownedSpecials = parsed.playerSkin.ownedSpecials;
        if (parsed.playerSkin.activeEyes) playerSkin.activeEyes = parsed.playerSkin.activeEyes;
        if (parsed.playerSkin.activeBody) playerSkin.activeBody = parsed.playerSkin.activeBody;
        if (parsed.playerSkin.activeRain) playerSkin.activeRain = parsed.playerSkin.activeRain;
        if ("activeSpecial" in parsed.playerSkin) playerSkin.activeSpecial = parsed.playerSkin.activeSpecial;
        if (parsed.playerSkin.savedSkinData) {
          if (parsed.playerSkin.savedSkinData.eyes) playerSkin.savedSkinData.eyes = parsed.playerSkin.savedSkinData.eyes;
          if (parsed.playerSkin.savedSkinData.bodies) playerSkin.savedSkinData.bodies = parsed.playerSkin.savedSkinData.bodies;
          if (parsed.playerSkin.savedSkinData.rains) playerSkin.savedSkinData.rains = parsed.playerSkin.savedSkinData.rains;
          if (parsed.playerSkin.savedSkinData.specials) playerSkin.savedSkinData.specials = parsed.playerSkin.savedSkinData.specials;
        }
      }
      if (!Array.isArray(playerSkin.ownedRains) || !playerSkin.ownedRains.length) playerSkin.ownedRains = ["default"];
      if (!playerSkin.ownedRains.includes("default")) playerSkin.ownedRains.unshift("default");
      if (!playerSkin.activeRain || !playerSkin.ownedRains.includes(playerSkin.activeRain)) playerSkin.activeRain = "default";

      ensureOwnedSkinsStored();
    }

