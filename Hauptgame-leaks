    function ensureLobbyBackgroundOwnership() {
      if (!Array.isArray(playerSkin.customLobbyBackgrounds)) {
        playerSkin.customLobbyBackgrounds = [];
      } else {
        const normalizedCustom = playerSkin.customLobbyBackgrounds
          .map((entry) => normalizeCustomLobbyBackgroundEntry(entry))
          .filter(Boolean);
        const seenCustom = new Set();
        playerSkin.customLobbyBackgrounds = normalizedCustom.filter((entry) => {
          if (seenCustom.has(entry.id)) return false;
          seenCustom.add(entry.id);
          return true;
        });
      }

      const allBackgrounds = getAllLobbyBackgrounds();
      const validIds = new Set(allBackgrounds.map((entry) => entry.id));
      const starterIds = lobbyBackgrounds
        .filter((entry) => entry.sourceType === "starter")
        .map((entry) => entry.id);
      if (!starterIds.length) starterIds.push(lobbyBackgrounds[0]?.id || "rift_oasis");
      const starterId = starterIds[0];
      if (!Array.isArray(playerSkin.ownedLobbyBackgrounds)) {
        playerSkin.ownedLobbyBackgrounds = starterIds.slice();
      }
      playerSkin.ownedLobbyBackgrounds = [...new Set(playerSkin.ownedLobbyBackgrounds.filter((id) => validIds.has(id)))];
      if (!playerSkin.ownedLobbyBackgrounds.length) {
        playerSkin.ownedLobbyBackgrounds = starterIds.slice();
      }
      starterIds.forEach((id) => {
        if (!playerSkin.ownedLobbyBackgrounds.includes(id)) {
          playerSkin.ownedLobbyBackgrounds.unshift(id);
        }
      });
      if (!playerSkin.ownedLobbyBackgrounds.includes(starterId)) {
        playerSkin.ownedLobbyBackgrounds.unshift(starterId);
      }
      if (!playerSkin.activeLobbyBackground || !playerSkin.ownedLobbyBackgrounds.includes(playerSkin.activeLobbyBackground)) {
        playerSkin.activeLobbyBackground = playerSkin.ownedLobbyBackgrounds[0];
      }
    }

    function getActiveLobbyBackground() {
      ensureLobbyBackgroundOwnership();
      return getLobbyBackgroundData(playerSkin.activeLobbyBackground) || getLobbyBackgroundData(playerSkin.ownedLobbyBackgrounds[0]) || getAllLobbyBackgrounds()[0] || null;
    }

    function getLobbyBackgroundUnlockState(background) {
      if (!background) return { unlockable: false, reason: "Unbekannt" };
      if (playerSkin.ownedLobbyBackgrounds.includes(background.id)) return { unlockable: true, reason: "Freigeschaltet" };

      if (background.sourceType === "starter") {
        return { unlockable: true, reason: "Starter-Hintergrund" };
      }
      if (background.sourceType === "shop") {
        return { unlockable: true, reason: `Shop: ${formatCurrency(background.price || 0)}` };
      }
      if (background.sourceType === "battlepass") {
        const currentTier = getBattlePassCurrentTier();
        const requiredTier = Math.max(1, Number(background.requiredTier) || 1);
        if (!battlePassState.premiumUnlocked) {
          return { unlockable: false, reason: "Premium-Battle-Pass benoetigt" };
        }
        return currentTier >= requiredTier
          ? { unlockable: true, reason: `Battle Pass Stufe ${requiredTier}` }
          : { unlockable: false, reason: `Stufe ${requiredTier} noetig (aktuell ${currentTier})` };
      }
      if (background.sourceType === "event") {
        return communityEventState.biomeUnlocked
          ? { unlockable: true, reason: "Event abgeschlossen" }
          : { unlockable: false, reason: "Community-Event abschliessen" };
      }
      if (background.sourceType === "achievement") {
        const requiredSpecials = Math.max(1, Number(background.requiredSpecials) || 3);
        const ownedSpecials = playerSkin.ownedSpecials.length;
        return ownedSpecials >= requiredSpecials
          ? { unlockable: true, reason: "Achievement erreicht" }
          : { unlockable: false, reason: `${requiredSpecials} Spezial-Skins noetig (${ownedSpecials}/${requiredSpecials})` };
      }
      if (background.sourceType === "custom") {
        return { unlockable: false, reason: "Eigenes YouTube-Hintergrundpaket" };
      }
      return { unlockable: false, reason: "Derzeit nicht verfuegbar" };
    }

