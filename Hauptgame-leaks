    .startFeatureCard {
      padding: 12px;
      border-radius: 16px;
      background: rgba(8, 14, 22, 0.48);
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
      scroll-snap-align: start;
    }

    .startFeatureTitle {
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(190, 220, 255, 0.82);
      margin-bottom: 6px;
    }

    .startFeatureText {
      font-size: 12px;
      line-height: 1.5;
      color: rgba(226, 236, 248, 0.85);
    }

    .startSuggestHeader {
      display: grid;
      gap: 6px;
      margin-top: 6px;
    }

    .startSuggestLabel {
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(178, 216, 255, 0.7);
    }

    .startSuggestLead {
      font-size: 14px;
      line-height: 1.6;
      color: rgba(222, 236, 252, 0.84);
    }

    .startSuggestGrid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 8px;
    }

    .startSuggestCard {
      padding: 12px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(8, 14, 22, 0.48);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .startSuggestTitle {
      font-size: 13px;
      font-weight: 800;
      color: #f9f5ea;
      margin-bottom: 6px;
    }

    .startSuggestText {
      font-size: 11px;
      line-height: 1.5;
      color: rgba(220, 232, 248, 0.82);
    }

    .startMetaCard {
      padding: 12px 12px 10px;
      border-radius: 24px;
      background: rgba(8, 14, 19, 0.36);
      border: 1px solid rgba(255,255,255,0.09);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .startMetaLabel {
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255, 229, 195, 0.72);
      margin-bottom: 8px;
    }

    .startMetaValue {
      font-size: 18px;
      font-weight: 1000;
      color: #fff8ec;
      margin-bottom: 6px;
    }

    .startMetaText {
      font-size: 11px;
      line-height: 1.55;
      color: rgba(233, 240, 248, 0.82);
    }

    .startPanel {
      padding: 36px 38px 28px;
      display: grid;
      align-content: center;
      gap: 18px;
      background:
        radial-gradient(circle at top right, rgba(109, 182, 255, 0.16), transparent 24%),
        linear-gradient(180deg, rgba(12, 20, 32, 0.98), rgba(8, 14, 24, 0.98));
    }

    .startPanelHeader {
      display: grid;
      gap: 10px;
    }

    .startPanelEyebrow {
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(188, 221, 255, 0.7);
    }

    .startPanelTitle {
      font-family: "Bangers", "Arial Black", sans-serif;
      font-size: clamp(24px, 3vw, 36px);
      line-height: 0.98;
      letter-spacing: -0.03em;
      color: #fef9f1;
    }

    .startPanelLead {
      font-size: 13px;
      line-height: 1.55;
      color: rgba(225, 236, 252, 0.84);
      max-width: 460px;
    }

    .startSecurityTag {
      margin-top: 6px;
      width: fit-content;
      padding: 7px 12px;
      border-radius: 999px;
      border: 1px solid rgba(147, 255, 190, 0.42);
      background: linear-gradient(135deg, rgba(52, 145, 98, 0.42), rgba(23, 53, 35, 0.5));
      color: #d5ffea;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .startFieldGrid {
      display: grid;
      gap: 10px;
    }

    .startFieldWrap {
      display: grid;
      gap: 8px;
      margin: 0;
    }

    .startTrapWrap {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .startFieldLabel {
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(200, 222, 247, 0.72);
    }

    .startInput {
      width: 100%;
      box-sizing: border-box;
      min-height: 54px;
      padding: 14px 16px;
      border-radius: 22px;
      border: 1px solid rgba(190, 215, 243, 0.18);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      color: white;
      outline: none;
      font-size: 16px;
      transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, transform 0.18s ease;
    }

    .startInput:focus {
      transform: translateY(-1px);
      border-color: rgba(128, 225, 255, 0.48);
      background: linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.04));
      box-shadow: 0 0 0 4px rgba(96, 195, 255, 0.1);
    }

    .startInput::placeholder {
      color: rgba(221, 234, 255, 0.5);
    }

    .startInput:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      filter: grayscale(0.2);
    }

    .startButtons {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 6px;
    }

    .startButtons.fullRow {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .startCaptchaCard {
      margin-top: 2px;
      padding: 12px;
      border-radius: 16px;
      border: 1px solid rgba(180, 228, 255, 0.24);
      background:
        radial-gradient(circle at top right, rgba(87, 160, 255, 0.14), transparent 48%),
        linear-gradient(180deg, rgba(11, 18, 31, 0.88), rgba(8, 14, 24, 0.9));
      display: grid;
      gap: 8px;
    }

    .startCaptchaTop {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }

    .startCaptchaLabel {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 900;
      color: rgba(187, 223, 255, 0.8);
    }

    .startCaptchaStatus {
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.22);
      background: rgba(255,255,255,0.08);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 900;
      color: #eff6ff;
    }

    .startCaptchaStatus.ok {
      border-color: rgba(156, 255, 198, 0.52);
      background: rgba(66, 143, 96, 0.38);
      color: #e4ffef;
    }

    .startCaptchaStatus.warn {
      border-color: rgba(255, 220, 146, 0.6);
      background: rgba(150, 100, 39, 0.38);
      color: #fff3dc;
    }

    .startCaptchaStatus.risk {
      border-color: rgba(255, 153, 153, 0.62);
      background: rgba(145, 47, 47, 0.44);
      color: #ffe5e5;
    }

    .startCaptchaMeter {
      height: 8px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.14);
    }

    .startCaptchaMeterFill {
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #5fe9a0, #f0d166, #f06f6f);
      transition: width 0.2s ease;
    }

    .startCaptchaDetail {
      font-size: 11px;
      line-height: 1.45;
      color: rgba(221, 234, 248, 0.82);
    }

    .startCaptchaVerify {
      min-height: 44px;
      font-size: 13px;
    }

    .startPanelFoot {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .startBtn {
      min-height: 54px;
      padding: 12px 16px;
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,0.12);
      background:
        linear-gradient(135deg, rgba(255, 176, 87, 0.96), rgba(194, 101, 31, 0.94));
      color: #201005;
      font-weight: 1000;
      font-size: 16px;
      font-family: "Bangers", "Arial Black", sans-serif;
      letter-spacing: -0.01em;
      cursor: pointer;
      box-shadow:
        0 18px 30px rgba(0,0,0,0.22),
        inset 0 1px 0 rgba(255,255,255,0.18);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
    }

    .startBtn:hover {
      transform: translateY(-2px);
      box-shadow:
        0 22px 36px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.2);
      filter: brightness(1.03);
    }

    .startBtn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      filter: grayscale(0.2);
      transform: none;
      box-shadow:
        0 14px 24px rgba(0,0,0,0.18),
        inset 0 1px 0 rgba(255,255,255,0.12);
    }

    .startBtn.secondary {
      background: linear-gradient(135deg, rgba(90, 230, 174, 0.94), rgba(30, 130, 99, 0.96));
      color: #04140f;
    }

    .startBtn.ghost {
      grid-column: 1 / -1;
      background: linear-gradient(135deg, rgba(80, 112, 201, 0.9), rgba(40, 58, 108, 0.95));
      color: #f4f8ff;
    }

    .startWarning {
      margin-top: 0;
      padding: 12px 14px;
      border-radius: 22px;
      border: 1px solid rgba(255, 186, 88, 0.5);
      background:
        radial-gradient(circle at top right, rgba(255, 196, 88, 0.18), transparent 55%),
        linear-gradient(150deg, rgba(52, 28, 8, 0.95), rgba(20, 14, 10, 0.98));
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #ffe8c7;
      text-align: center;
      box-shadow: 0 18px 30px rgba(0,0,0,0.28);
    }

    .startInfo {
      margin-top: 0;
      padding: 12px 14px;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
      border: 1px solid rgba(255,255,255,0.08);
      font-size: 12px;
      line-height: 1.6;
      color: rgba(241, 246, 255, 0.9);
    }

    .startHint {
      padding: 10px 12px;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(65, 90, 124, 0.2), rgba(33, 45, 65, 0.18));
      border: 1px solid rgba(166, 193, 230, 0.12);
      font-size: 11px;
      line-height: 1.6;
      color: rgba(220, 232, 255, 0.8);
    }

    .startWarning {
      padding: 12px 14px;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255, 129, 93, 0.2), rgba(92, 30, 26, 0.24));
      border: 1px solid rgba(255, 164, 138, 0.22);
      color: rgba(255, 232, 225, 0.92);
      font-size: 12px;
      line-height: 1.6;
    }

    .startWarning strong {
      display: block;
      margin-bottom: 4px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #ffd7c7;
    }

    @media (max-width: 1024px) {
      .startBox {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .startHero {
        border-right: none;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }

      .startHero,
      .startPanel {
        padding: 40px 28px;
      }
    }

    @media (max-width: 700px) {
      .startScreen {
        padding: 0;
      }

      .startBox {
        width: 100%;
        border-radius: 0;
      }

      .startHero,
      .startPanel {
        padding: 24px 20px;
      }

      .startQuickRow,
      .startMetaGrid,
      .startSuggestGrid,
      .startButtons,
      .startPanelFoot,
      .startFeatureGrid {
        grid-template-columns: 1fr;
      }

      .startInput,
      .startBtn {
        min-height: 58px;
        font-size: 16px;
      }
    }

    @media (max-height: 900px) {
      .startHero,
      .startPanel {
        padding: 32px 28px;
      }

      .startBox h1 {
        font-size: clamp(40px, 5.2vw, 72px);
      }

      .startQuickChip {
        min-height: 56px;
        font-size: 11px;
      }

      .startSuggestGrid {
        gap: 8px;
      }

      .startSuggestCard {
        padding: 10px;
      }

      .startInput,
      .startBtn {
        min-height: 50px;
        font-size: 15px;
      }

      .startInfo,
      .startHint {
        font-size: 10px;
      }
    }

    .lobbyScreen {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      overflow: hidden;
      --lobby-bg-image: url("assets/ui/season5.jpg");
      --lobby-bg-a: rgba(120, 184, 101, 0.18);
      --lobby-bg-b: rgba(255, 216, 132, 0.12);
      --lobby-bg-c1: rgba(86, 126, 76, 0.18);
      --lobby-bg-c2: rgba(42, 62, 44, 0.16);
      --lobby-bg-c3: rgba(34, 47, 34, 0.34);
      --lobby-bg-dynamic-accent: rgba(122, 212, 255, 0.25);
    }

    .lobbyBackdropDecor {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      background: var(--lobby-bg-image);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }

    .lobbyYoutubeLayer {
      position: absolute;
      inset: -4%;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
      opacity: 0.78;
      filter: saturate(1.05) contrast(1.04) brightness(0.86);
    }

    .lobbyYoutubeLayer iframe {
      position: absolute;
      top: 50%;
      left: 50%;
      width: max(100vw, 177.78vh);
      height: max(56.25vw, 100vh);
      transform: translate(-50%, -50%);
      border: 0;
      pointer-events: none;
    }

    .lobbyBackdropDecor::before {
      content: "";
      position: absolute;
      inset: -12%;
      pointer-events: none;
      opacity: 0;
      background:
        radial-gradient(circle at 24% 18%, rgba(255,255,255,0.18), transparent 34%),
        radial-gradient(circle at 76% 28%, var(--lobby-bg-dynamic-accent), transparent 36%),
        linear-gradient(120deg, transparent 22%, rgba(255,255,255,0.14) 48%, transparent 72%);
      mix-blend-mode: screen;
      transition: opacity 0.35s ease;
    }

    .lobbyScreen.hasDynamicLobbyBg .lobbyBackdropDecor::before {
      opacity: 0.56;
      animation: lobbyBackgroundDynamicSweep 8.5s linear infinite;
    }

    @keyframes lobbyBackgroundDynamicSweep {
      0% { transform: translate3d(-2%, -1%, 0) scale(1); }
      50% { transform: translate3d(2%, 1%, 0) scale(1.03); }
      100% { transform: translate3d(-2%, -1%, 0) scale(1); }
    }

    .lobbySunOrb,
    .lobbyDune,
    .lobbySandRibbon,
    .lobbyEventLayer,
    .lobbyLaunchOverlay {
      position: absolute;
      pointer-events: none;
    }

    .lobbySunOrb {
      top: 90px;
      right: 140px;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 237, 172, 0.78) 0%, rgba(171, 210, 118, 0.38) 44%, rgba(255, 182, 72, 0) 74%);
      filter: blur(2px);
      opacity: 0.72;
    }


    .lobbyScreen.isSkyMode .lobbyBackdropDecor {
      background: var(--lobby-bg-image);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }


    .lobbyScreen.isSkyMode .lobbySunOrb {
      background: radial-gradient(circle, rgba(255, 249, 214, 0.96) 0%, rgba(168, 224, 255, 0.58) 42%, rgba(146, 204, 255, 0) 74%);
      opacity: 0.96;
    }


    .lobbyScreen.isSkyMode .lobbyDune {
      background:
        linear-gradient(180deg, rgba(214, 242, 199, 0.24), rgba(90, 128, 76, 0.72)),
        linear-gradient(90deg, rgba(255,255,255,0.12), rgba(133, 170, 120, 0.14));
    }

    .lobbyScreen.isSkyMode .lobbyDune.back {
      opacity: 0.34;
      filter: blur(6px);
    }

    .lobbyScreen.isSkyMode .lobbySandRibbon {
      background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(166, 214, 255, 0.05));
      opacity: 0.56;
    }

    .lobbyDune {
      left: -4vw;
      right: -4vw;
      bottom: -12vh;
      height: 34vh;
      background:
        linear-gradient(180deg, rgba(109, 129, 84, 0.22), rgba(58, 72, 48, 0.8)),
        linear-gradient(90deg, rgba(117, 91, 58, 0.14), rgba(49, 38, 26, 0.18));
      border-radius: 50% 50% 0 0;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
