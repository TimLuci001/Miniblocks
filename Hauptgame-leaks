    function buyOrEquipEyeSkin(id) {
      const skin = eyeSkins.find(s => s.id === id);
      if (!skin) return;

      const owned = playerSkin.ownedEyes.includes(id);
      if (!owned) {
        const finalPrice = getDiscountedPrice(skin.price, "eyes", id);
        if (inventory[7] < finalPrice) return showMessage("Nicht genug M-Bucks!");
        inventory[7] -= finalPrice;
        const cashback = grantCreatorCashback(finalPrice);
        playerSkin.ownedEyes.push(id);
        ensureSkinStored("eyes", id);
        stats.shopPurchases++;
        openShopPurchaseModal({
          lead: `${skin.name} wurde gekauft und zu deinem Spind hinzugefügt.`,
          rewards: [
            `Augenfarbe: ${skin.name}`,
            ...(cashback > 0 ? [`Creator Bonus: +${cashback} M-Bucks`] : [])
          ],
          equipAction: () => {
            playerSkin.activeSpecial = null;
            playerSkin.activeEyes = id;
            saveGame();
            renderShop();
            renderLocker();
            updateUI();
            closeShopPurchaseModal();
            showMessage(`${skin.name} ausgerüstet!`, 1800);
          },
          equipLabel: "Ausrüsten"
        });
        checkAchievements();
      } else {
        showMessage(`${skin.name} ausgerüstet!`);
      }

      playerSkin.activeSpecial = null;
      playerSkin.activeEyes = id;
      saveGame();
      renderShop();
      updateUI();
    }

    function buyOrEquipBodySkin(id) {
      const skin = bodySkins.find(s => s.id === id);
      if (!skin) return;

      const owned = playerSkin.ownedBodies.includes(id);
