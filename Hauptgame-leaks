    .lobbySandRibbon {
      top: -8vh;
      left: 10vw;
      width: 90px;
      height: 118vh;
      transform: rotate(24deg);
      background: linear-gradient(180deg, rgba(182, 218, 151, 0.14), rgba(255, 220, 160, 0.02));
      opacity: 0.48;
    }

    .lobbyBackdropDecor::after {
      content: "";
      position: absolute;
