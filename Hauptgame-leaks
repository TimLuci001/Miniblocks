    function clampColor(value) {
      return Math.max(0, Math.min(255, Math.round(value)));
    }

    function hexToRgb(hex) {
      if (!hex) return null;
      let safe = String(hex).trim();
      if (!safe.startsWith("#")) return null;
      safe = safe.slice(1);
      if (safe.length === 3) safe = safe.split("").map((c) => c + c).join("");
      if (safe.length !== 6) return null;
      const num = parseInt(safe, 16);
      return {
        r: (num >> 16) & 255,
        g: (num >> 8) & 255,
        b: num & 255
      };
    }

    function rgbToHex({ r, g, b }) {
      const toHex = (val) => clampColor(val).toString(16).padStart(2, "0");
      return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
    }

    function shiftColor(hex, amount) {
      const rgb = hexToRgb(hex);
      if (!rgb) return hex;
      return rgbToHex({
        r: rgb.r + amount,
        g: rgb.g + amount,
        b: rgb.b + amount
      });
    }

    function toRgba(hex, alpha) {
      const rgb = hexToRgb(hex);
      if (!rgb) return `rgba(255,255,255,${alpha})`;
      return `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${alpha})`;
    }

