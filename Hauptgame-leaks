    function drawEasterEggs(cam) {
      if (isMiniPassExpired()) return;
      for (const egg of easterEggPickups) {
        if (miniPassState.collectedEggIds.includes(egg.id)) continue;
        const x = egg.x - cam.x;
        const y = egg.y - cam.y;
        if (x < -egg.w || y < -egg.h || x > canvas.width + egg.w || y > canvas.height + egg.h) continue;

        ctx.fillStyle = "rgba(0,0,0,0.16)";
        ctx.fillRect(x + 2, y + egg.h + 1, egg.w - 4, 3);

        ctx.fillStyle = egg.colorA;
        ctx.beginPath();
        ctx.ellipse(x + egg.w / 2, y + egg.h / 2, egg.w / 2, egg.h / 2, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = egg.colorB;
        ctx.fillRect(x + 3, y + 4, egg.w - 6, 3);
        ctx.fillRect(x + 4, y + 10, egg.w - 8, 3);
        ctx.fillRect(x + 5, y + 15, egg.w - 10, 2);
      }
    }

    function drawPortals(cam) {
      for (const portal of portals) {
        const px = portal.x - cam.x;
        const py = portal.y - cam.y;
        ctx.fillStyle = "rgba(10,18,30,0.5)";
        ctx.fillRect(px - 3, py + portal.h - 4, portal.w + 6, 6);
        ctx.fillStyle = "rgba(255,255,255,0.14)";
        ctx.fillRect(px, py, portal.w, portal.h);
        ctx.fillStyle = craftedState.portalKeyUnlocked ? portal.colorA : "rgba(130,140,160,0.35)";
        ctx.fillRect(px + 4, py + 4, portal.w - 8, portal.h - 8);
        ctx.fillStyle = craftedState.portalKeyUnlocked ? portal.colorB : "rgba(80,90,110,0.45)";
        ctx.fillRect(px + 8, py + 8, portal.w - 16, portal.h - 16);
        ctx.strokeStyle = "rgba(255,255,255,0.5)";
        ctx.lineWidth = 2;
        ctx.strokeRect(px, py, portal.w, portal.h);
      }
    }

    function drawAura(px, py, specialId, width = player.w, height = player.h) {
      const auraColor = getAuraColorForSpecial(specialId);
      if (!auraColor) return;

      const padding = specialId === "shadow" || specialId === "crystal" ? 5 : 4;
      ctx.fillStyle = auraColor;
      ctx.fillRect(px - padding, py - padding, width + padding * 2, height + padding * 2);
    }

    function drawPlayer(cam) {
      const px = player.x - cam.x;
      const py = player.y - cam.y;

      if (player.invincibleTimer > 0 && Math.floor(player.invincibleTimer / 5) % 2 === 0) {
        ctx.globalAlpha = 0.6;
      }

      const activeBody = getActiveBodySkin();
      const activeEyes = getActiveEyeSkin();

      if (isStealthModeActive() && stealthState.active) {
        ctx.save();
        ctx.globalAlpha = 0.7;
        ctx.beginPath();
        ctx.fillStyle = "rgba(120, 255, 200, 0.18)";
        ctx.shadowColor = "rgba(120, 255, 200, 0.45)";
        ctx.shadowBlur = 18;
        ctx.ellipse(px + player.w / 2, py + player.h / 2, player.w * 0.9, player.h * 0.8, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      drawAura(px, py, playerSkin.activeSpecial, player.w, player.h);

      const bodyColor = player.hurtTimer > 0 ? "#ffffff" : activeBody.color;
      const headX = px + 4;
      const headY = py + 3;
      const headSize = 16;
      const bodyX = px + 5;
      const bodyY = py + 18;
      const bodyW = player.w - 10;
      const bodyH = player.h - 20;
      const legY = py + player.h - 8;

      ctx.fillStyle = "rgba(9, 16, 28, 0.32)";
      ctx.fillRect(px + 4, py + player.h + 2, player.w - 8, 5);

      ctx.fillStyle = bodyColor;
      ctx.fillRect(bodyX, bodyY, bodyW, bodyH);

      ctx.fillStyle = "rgba(255,255,255,0.18)";
      ctx.fillRect(bodyX + 2, bodyY + 2, bodyW - 4, Math.max(4, Math.floor(bodyH * 0.35)));

      ctx.fillStyle = bodyColor;
      ctx.fillRect(headX, headY, headSize, headSize);

      ctx.fillStyle = "rgba(255,255,255,0.2)";
      ctx.fillRect(headX + 2, headY + 2, headSize - 4, 4);

      ctx.fillStyle = "#fffdf8";
      ctx.fillRect(headX + 3, headY + 5, 4, 4);
      ctx.fillRect(headX + 9, headY + 5, 4, 4);

      ctx.fillStyle = activeEyes.color;
      ctx.fillRect(headX + 4, headY + 6, 2, 2);
      ctx.fillRect(headX + 10, headY + 6, 2, 2);

      ctx.fillStyle = "rgba(50, 25, 32, 0.55)";
      ctx.fillRect(headX + 6, headY + 11, 4, 2);

      ctx.fillStyle = "rgba(8, 14, 24, 0.42)";
      ctx.fillRect(px + 6, legY, 5, 8);
      ctx.fillRect(px + player.w - 11, legY, 5, 8);

      ctx.fillStyle = "rgba(255,255,255,0.16)";
      ctx.fillRect(bodyX + 3, bodyY + 7, bodyW - 6, 2);
      ctx.fillRect(bodyX + 3, bodyY + 13, bodyW - 6, 2);

      if (currentSword !== "none") {
        ctx.fillStyle = swords[currentSword].color;
        if (attackTimer > 0) {
          ctx.fillRect(px + player.w, py + 18, 18, 4);
          ctx.fillRect(px + player.w + 12, py + 14, 4, 12);
        } else {
          ctx.fillRect(px + player.w - 2, py + 20, 12, 3);
          ctx.fillRect(px + player.w + 6, py + 17, 3, 9);
        }
      }

      ctx.globalAlpha = 1;
    }

