    function renderNudelPassPanel() {
      const totalPages = Math.max(1, Math.ceil(nudelPassRewards.length / NUDEL_PASS_PAGE_SIZE));
      const unlockedTiers = getNudelPassUnlockedTierCount();
      const expired = Date.now() >= NUDEL_PASS_END_AT;
      const clampedPage = Math.max(0, Math.min(totalPages - 1, nudelPassPage));
