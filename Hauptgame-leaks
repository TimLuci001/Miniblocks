        seasonId: communityEventState.seasonId,
        totalBlocks: communityEventState.totalBlocks,
        targetBlocks: communityEventState.targetBlocks,
        endAt: communityEventState.endAt,
        biomeUnlocked: communityEventState.biomeUnlocked
      }));
    }

    function resetCommunityEventState() {
      communityEventState.seasonId = COMMUNITY_EVENT_SEASON_ID;
      communityEventState.totalBlocks = 0;
      communityEventState.targetBlocks = COMMUNITY_EVENT_TARGET;
      communityEventState.endAt = COMMUNITY_EVENT_END_AT;
      communityEventState.biomeUnlocked = false;
      communityEventState.localPendingBlocks = 0;
      communityEventState.syncInFlight = false;
      communityEventState.biomeAnnouncementShown = false;
      ensureCommunityPassBaseUnlocked();
      saveCommunityEventLocal();
    }

    function resetCommunityPassStateForCurrentSeason() {
      communityPassState.seasonId = COMMUNITY_EVENT_SEASON_ID;
      communityPassState.claimedMilestones = [];
    }

    function applyCommunityEventPayload(payload = {}, { fromSync = false, showUnlockMessage = true } = {}) {
      const savedSeasonId = payload?.seasonId || "legacy";
      if (savedSeasonId !== COMMUNITY_EVENT_SEASON_ID) {
        resetCommunityEventState();
        if (fromSync) renderCommunityEvent();
        return false;
      }

      communityEventState.seasonId = COMMUNITY_EVENT_SEASON_ID;
      if (typeof payload.totalBlocks === "number") communityEventState.totalBlocks = Math.max(0, payload.totalBlocks);
      if (typeof payload.targetBlocks === "number") communityEventState.targetBlocks = payload.targetBlocks;
      if (typeof payload.endAt === "number") communityEventState.endAt = payload.endAt;
      if (typeof payload.biomeUnlocked === "boolean") communityEventState.biomeUnlocked = payload.biomeUnlocked;
      ensureCommunityPassBaseUnlocked();

      if (communityEventState.totalBlocks >= communityEventState.targetBlocks) {
        communityEventState.totalBlocks = Math.max(communityEventState.totalBlocks, communityEventState.targetBlocks);
        communityEventState.biomeUnlocked = true;
      }

      if (communityEventState.biomeUnlocked) {
        applyCommunityBiomeWorld();
        applyRiftBiomeWorld();
        if (showUnlockMessage && !communityEventState.biomeAnnouncementShown) {
          communityEventState.biomeAnnouncementShown = true;
          showMessage("Community-Event geschafft! Neues Kristall-Biom freigeschaltet!", 3200);
        }
      } else {
        communityEventState.biomeAnnouncementShown = false;
        applyRiftBiomeWorld();
      }

      saveCommunityEventLocal();
      if (fromSync) renderCommunityEvent();
      return true;
    }

    function loadCommunityEventLocal() {
      const raw = localStorage.getItem(COMMUNITY_EVENT_KEY);
      if (!raw) return;
      try {
        applyCommunityEventPayload(JSON.parse(raw), { fromSync: false, showUnlockMessage: false });
      } catch {
        console.warn("Community-Event konnte lokal nicht geladen werden.");
      }
    }

    function registerCommunityEventXp(amount = 0) {
      if (amount <= 0) return;
      const boostedAmount = Math.max(1, Math.round(amount * getLiveCommunityMultiplier()));
      communityEventState.localPendingBlocks += boostedAmount;
      communityEventState.totalBlocks += boostedAmount;
      if (communityEventState.totalBlocks >= communityEventState.targetBlocks) {
        communityEventState.biomeUnlocked = true;
      }
      applyCommunityEventPayload(communityEventState, { fromSync: true, showUnlockMessage: true });
      syncCommunityEventProgress();
    }

    async function syncCommunityEventProgress(force = false) {
      if (!supabaseClient) {
        if (communityEventState.localPendingBlocks > 0) {
          communityEventState.localPendingBlocks = 0;
          saveCommunityEventLocal();
        }
        return false;
      }
      if (communityEventState.syncInFlight) return false;
      if (!force && communityEventState.localPendingBlocks <= 0) return false;

      communityEventState.syncInFlight = true;
      try {
        const { data, error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .select("community_event_state")
          .eq("id", GAME_STATE_ID)
          .maybeSingle();

        if (error) throw error;

        const remoteState = data?.community_event_state || {};
        const remoteTotal = Number(remoteState.totalBlocks) || 0;
        const mergedBase = Math.max(remoteTotal, communityEventState.totalBlocks - communityEventState.localPendingBlocks);
        const mergedTotal = Math.min(COMMUNITY_EVENT_TARGET, mergedBase + communityEventState.localPendingBlocks);
        const nextPayload = {
          seasonId: COMMUNITY_EVENT_SEASON_ID,
          totalBlocks: mergedTotal,
          targetBlocks: COMMUNITY_EVENT_TARGET,
          endAt: COMMUNITY_EVENT_END_AT,
          biomeUnlocked: mergedTotal >= COMMUNITY_EVENT_TARGET
        };

        const { error: updateError } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: GAME_STATE_ID,
            community_event_state: nextPayload
          }, { onConflict: "id" });

        if (updateError) throw updateError;

        communityEventState.localPendingBlocks = 0;
        applyCommunityEventPayload(nextPayload, { fromSync: true, showUnlockMessage: true });
        return true;
      } catch (err) {
        console.warn("Community-Event Sync fehlgeschlagen:", err);
        saveCommunityEventLocal();
        return false;
      } finally {
        communityEventState.syncInFlight = false;
      }
    }

    function renderCommunityEvent() {
      if (!communityEventStats || !communityEventCountdownCard) return;

      const progress = getCommunityEventProgress();
      const xpLeft = Math.max(0, communityEventState.targetBlocks - communityEventState.totalBlocks);
      const countdownDone = Date.now() >= communityEventState.endAt;
      const stage = getActiveCommunityWorldStage();
      const stageEntries = getCommunityEventStageEntries();

      communityEventStats.innerHTML = `
        <div class="eventStatCard">
          <div class="eventStatLabel">Fortschritt</div>
          <div class="eventStatValue">${progress.toFixed(1)}%</div>
        </div>
        <div class="eventStatCard">
          <div class="eventStatLabel">Gespendet</div>
          <div class="eventStatValue">${communityEventState.totalBlocks.toLocaleString("de-DE")}</div>
        </div>
        <div class="eventStatCard">
          <div class="eventStatLabel">Fehlen noch</div>
          <div class="eventStatValue">${xpLeft.toLocaleString("de-DE")}</div>
        </div>
      `;

      communityEventCountdownCard.classList.toggle("done", communityEventState.biomeUnlocked);
      communityEventCountdownCard.innerHTML = (communityEventState.biomeUnlocked && countdownDone)
        ? `
          <div class="eventCountdownLabel">Community-Ziel erreicht</div>
          <div class="eventCountdownTime">100% freigeschaltet</div>
          <div class="eventCountdownMeta">Season 2 Battle Pass wird kostenlos für alle freigeschaltet.</div>
        `
        : `
          <div class="eventCountdownLabel">Event endet in</div>
          <div class="eventCountdownTime">${countdownDone ? "00:00:00" : formatRemainingTime(communityEventState.endAt)}</div>
          <div class="eventCountdownMeta">Bis zum Ende müssen zusammen 200.000 M-Bucks gespendet werden, damit alle Belohnungen aktiv werden.</div>
        `;

      communityEventProgressText.textContent = `${communityEventState.totalBlocks.toLocaleString("de-DE")} / ${communityEventState.targetBlocks.toLocaleString("de-DE")} M-Bucks`;
      communityEventProgressBar.style.width = `${progress}%`;
      communityEventRewardText.textContent = communityEventState.biomeUnlocked
        ? "100% erreicht: Season 2 Battle Pass ist kostenlos freigeschaltet."
        : `Aktive Event-Stufe: ${stage === 0 ? "Noch ruhig" : `${stageEntries[stage - 1].percent}% • ${stageEntries[stage - 1].title}`}. Spendet weiter M-Bucks, um die nächste Stufe freizuschalten.`;
      if (communityEventStageRail) {
        communityEventStageRail.innerHTML = stageEntries.map((entry, index) => `
          <div class="communityStageCard ${progress >= entry.percent ? "active" : ""}">
            <div class="communityStagePercent">${entry.percent}%</div>
            <div class="communityStageTitle">${entry.title}</div>
            <div class="communityStageDesc">${entry.desc}</div>
          </div>
        `).join("");
      }
    }

    function updateCurrencyDisplays() {
      if (shopGoldInfo) shopGoldInfo.innerHTML = `Deine ${formatCurrencyMarkup(inventory[7] || 0)}`;
      if (npcGoldInfo) npcGoldInfo.innerHTML = `Deine ${formatCurrencyMarkup(inventory[7] || 0)}`;
    }

    async function donateCommunityEvent(amount = COMMUNITY_EVENT_DONATION_AMOUNT) {
      const donation = Math.max(0, Number(amount) || 0);
      if (!donation) return;
      if ((inventory[7] || 0) < donation) {
        showMessage("Nicht genug M-Bucks!", 2200);
        return;
      }
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) {
        showMessage("Spenden nur mit Supabase-Account möglich.", 2400);
        return;
      }

      inventory[7] -= donation;
      queueDeferredSave();
      updateCurrencyDisplays();

      applyCommunityEventPayload({
        seasonId: COMMUNITY_EVENT_SEASON_ID,
        totalBlocks: Math.min(communityEventState.targetBlocks, communityEventState.totalBlocks + donation),
        targetBlocks: communityEventState.targetBlocks,
        endAt: communityEventState.endAt,
        biomeUnlocked: (communityEventState.totalBlocks + donation) >= communityEventState.targetBlocks
      }, { fromSync: true, showUnlockMessage: true });
      renderCommunityEvent();

      try {
        const { error } = await supabaseClient.rpc("donate_community_mbucks", {
          p_event_id: COMMUNITY_EVENT_SEASON_ID,
          p_player_key: cloudPlayerKey,
          p_amount: donation
        });
        if (error) throw error;

        const { data, error: readError } = await supabaseClient
          .from("community_event_state")
          .select("target_mbucks, donated_mbucks")
          .eq("id", COMMUNITY_EVENT_SEASON_ID)
          .single();

        if (!readError && data) {
          applyCommunityEventPayload({
            seasonId: COMMUNITY_EVENT_SEASON_ID,
            totalBlocks: Number(data.donated_mbucks) || 0,
            targetBlocks: Number(data.target_mbucks) || COMMUNITY_EVENT_TARGET,
            endAt: communityEventState.endAt,
            biomeUnlocked: (Number(data.donated_mbucks) || 0) >= (Number(data.target_mbucks) || COMMUNITY_EVENT_TARGET)
          }, { fromSync: true, showUnlockMessage: true });
          renderCommunityEvent();
        }
        showMessage(`Danke! ${donation.toLocaleString("de-DE")} M-Bucks gespendet.`, 2200);
      } catch (err) {
        inventory[7] += donation;
        queueDeferredSave();
        updateCurrencyDisplays();
        showMessage("Spende fehlgeschlagen. Bitte erneut versuchen.", 2400);
      }
    }

    function isInsideHousePlot(tx, ty) {
      return tx >= housePlot.x1 && tx <= housePlot.x2 && ty >= housePlot.y1 && ty <= housePlot.y2;
    }

    function getNextHouseMilestone() {
      return houseMilestones.find(step => houseState.blockCount < step.blocks) || null;
    }

    function awardHouseMilestone(step) {
      houseState.level = Math.max(houseState.level, step.level);
      inventory[7] += step.rewardGold;
      addXp(step.rewardXp);

      showMessage(`Haus-Level ${step.level}! ${step.rewardText}`, 3200);
      renderShop();
      renderInventory();
      updateUI();
    }

    function updateHouseProgress() {
      for (const step of houseMilestones) {
        if (houseState.blockCount >= step.blocks && houseState.level < step.level) {
          awardHouseMilestone(step);
        }
      }
    }

    function createBaseThreeWorldData() {
      const width = threeDState.worldWidth;
      const depth = threeDState.worldDepth;
      const height = threeDState.worldHeight;
      const blocks = [];
      for (let x = 0; x < width; x++) {
        for (let z = 0; z < depth; z++) {
          blocks.push([x, 0, z, 3]);
          blocks.push([x, 1, z, 1]);
        }
      }
      return { width, depth, height, blocks, spawn: { x: 6, y: 6, z: 6 } };
    }

    function clearThreeWorld() {
      if (!threeDState.blockGroup) return;
      threeDState.blocks.clear();
      while (threeDState.blockGroup.children.length) {
        threeDState.blockGroup.remove(threeDState.blockGroup.children[0]);
      }
    }

    function serializeThreeWorldData() {
      const blocks = [];
      for (const entry of threeDState.blocks.values()) {
        const mesh = entry.mesh;
        const data = mesh?.userData;
        if (!data) continue;
        blocks.push([data.x, data.y, data.z, data.id]);
      }
      return {
        width: threeDState.worldWidth,
        depth: threeDState.worldDepth,
        height: threeDState.worldHeight,
        blocks,
        spawn: threeDState.spawn ? { x: threeDState.spawn.x, y: threeDState.spawn.y, z: threeDState.spawn.z } : { x: 6, y: 6, z: 6 }
      };
    }

    function applyThreeWorldData(data) {
      if (!data) return;
      const width = Math.max(10, Number(data.width) || threeDState.worldWidth);
      const depth = Math.max(10, Number(data.depth) || threeDState.worldDepth);
      const height = Math.max(6, Number(data.height) || threeDState.worldHeight);
      threeDState.worldWidth = width;
      threeDState.worldDepth = depth;
      threeDState.worldHeight = height;
      if (data.spawn && typeof data.spawn.x === "number") {
        threeDState.spawn = {
          x: Number(data.spawn.x) || 6,
          y: Number(data.spawn.y) || 6,
          z: Number(data.spawn.z) || 6
        };
      } else {
        threeDState.spawn = { x: 6, y: 6, z: 6 };
      }
      clearThreeWorld();
      const blocks = Array.isArray(data.blocks) ? data.blocks : [];
      for (const entry of blocks) {
        if (!Array.isArray(entry) || entry.length < 4) continue;
        const [x, y, z, id] = entry.map((value) => Number(value) || 0);
        if (x < 0 || z < 0 || x >= width || z >= depth || y < 0 || y >= height) continue;
        if (!id) continue;
        setThreeBlock(x, y, z, id);
      }
    }

    function getThreeBlockKey(x, y, z) {
      return `${x}|${y}|${z}`;
    }

    function getThreeBlock(x, y, z) {
      const entry = threeDState.blocks.get(getThreeBlockKey(x, y, z));
      return entry ? entry.id : 0;
    }

    function getThreeMaterial(id) {
      if (!threeDState.materials[id]) {
        const color = BLOCKS[id]?.color || "#bbbbbb";
        threeDState.materials[id] = new THREE.MeshStandardMaterial({ color });
      }
      return threeDState.materials[id];
    }

    function setThreeBlock(x, y, z, id) {
      const key = getThreeBlockKey(x, y, z);
      const existing = threeDState.blocks.get(key);

      if (existing) {
        threeDState.blockGroup.remove(existing.mesh);
        threeDState.blocks.delete(key);
      }

      if (!id) return;

      const mesh = new THREE.Mesh(threeDState.blockGeometry, getThreeMaterial(id));
      mesh.position.set(x + 0.5, y + 0.5, z + 0.5);
      mesh.castShadow = false;
      mesh.receiveShadow = true;
      mesh.userData = { x, y, z, id };
      threeDState.blockGroup.add(mesh);
      threeDState.blocks.set(key, { id, mesh });
    }

    function buildThreeTree(baseX, baseZ, baseY) {
      const trunkHeight = 3 + ((baseX + baseZ) % 2);
      for (let y = 0; y < trunkHeight; y++) setThreeBlock(baseX, baseY + y, baseZ, 4);

      const leafY = baseY + trunkHeight;
      for (let x = baseX - 1; x <= baseX + 1; x++) {
        for (let z = baseZ - 1; z <= baseZ + 1; z++) {
          for (let y = leafY - 1; y <= leafY + 1; y++) {
            if (Math.abs(x - baseX) + Math.abs(z - baseZ) < 3) setThreeBlock(x, y, z, 5);
          }
        }
      }
    }

    function buildThreeWorld() {
      threeDState.blocks.clear();
      while (threeDState.blockGroup.children.length) {
        threeDState.blockGroup.remove(threeDState.blockGroup.children[0]);
      }

      for (let x = 0; x < threeDState.worldWidth; x++) {
        for (let z = 0; z < threeDState.worldDepth; z++) {
          const hill = Math.sin(x * 0.38) + Math.cos(z * 0.31);
          const topY = 1 + Math.max(0, Math.round(hill));

          setThreeBlock(x, 0, z, 3);
          for (let y = 1; y < topY; y++) setThreeBlock(x, y, z, 2);
          setThreeBlock(x, topY, z, x > 24 ? 9 : 1);

          if (topY >= 2 && x < 18 && z > 5 && z < 35 && x % 7 === 0 && z % 8 === 0) {
            buildThreeTree(x, z, topY + 1);
          }
        }
      }

      for (let x = 26; x <= 33; x++) {
        for (let z = 9; z <= 16; z++) {
          setThreeBlock(x, 2, z, 0);
        }
      }
    }

    function isThreeSolidAt(x, y, z) {
      return getThreeBlock(Math.floor(x), Math.floor(y), Math.floor(z)) !== 0;
    }

    function collidesThreePlayer(px, py, pz) {
      const radius = threeDState.player.radius;
      const height = threeDState.player.height;
      const samples = [
        [px - radius, py, pz - radius],
        [px + radius, py, pz - radius],
        [px - radius, py, pz + radius],
        [px + radius, py, pz + radius],
        [px - radius, py + height * 0.5, pz - radius],
        [px + radius, py + height * 0.5, pz + radius],
        [px - radius, py + height - 0.05, pz - radius],
        [px + radius, py + height - 0.05, pz + radius]
      ];

      return samples.some(([sx, sy, sz]) => isThreeSolidAt(sx, sy, sz));
    }

    function updateThreeTarget() {
      if (!threeDState.raycaster || !threeDState.camera) return;

      threeDState.raycaster.setFromCamera(new THREE.Vector2(0, 0), threeDState.camera);
      const hits = threeDState.raycaster.intersectObjects(threeDState.blockGroup.children, false);

      if (!hits.length) {
        threeDState.selectedHit = null;
        threeDState.targetOutline.visible = false;
        return;
      }

      const hit = hits[0];
      const block = hit.object.userData;
      const normal = hit.face.normal.clone().transformDirection(hit.object.matrixWorld).round();

      threeDState.selectedHit = { block, normal };
      threeDState.targetOutline.position.copy(hit.object.position);
      threeDState.targetOutline.visible = true;
    }

    function mineThreeBlock() {
      if (!threeDState.selectedHit) return;
      if (isCreativeModeActive() && currentMatchMode === "creative" && creativeTestMode) return;
      const { x, y, z, id } = threeDState.selectedHit.block;
      if (y <= 0) return;

      setThreeBlock(x, y, z, 0);
      if (isCreativeModeActive() && currentMatchMode === "creative") {
        saveActiveCreativeWorldSnapshot();
        updateUI();
        return;
      }
      inventory[id] = (inventory[id] || 0) + 1;
      stats.blocksMined++;
      registerCommunityEventBlocks(1);
      if (id === 4) stats.woodMined++;
      if (id === 3) stats.stoneMined++;
      if (id === 6) stats.coalMined++;
      if (id === 7) stats.goldMined++;
      addXp(6 + progression.skills.mining * 2);
      checkAchievements();
      saveGame();
      renderHotbar();
      updateUI();
    }

    function placeThreeBlock() {
      if (!threeDState.selectedHit) return;
      if (isCreativeModeActive() && currentMatchMode === "creative" && creativeTestMode) return;
      if (!isCreativeModeActive() && (inventory[selectedBlock] || 0) <= 0) return;

      const { block, normal } = threeDState.selectedHit;
      const x = block.x + normal.x;
      const y = block.y + normal.y;
      const z = block.z + normal.z;

      if (x < 0 || z < 0 || x >= threeDState.worldWidth || z >= threeDState.worldDepth || y < 1 || y >= threeDState.worldHeight) return;
      if (getThreeBlock(x, y, z) !== 0) return;

      const playerMinX = threeDState.player.x - threeDState.player.radius;
      const playerMaxX = threeDState.player.x + threeDState.player.radius;
      const playerMinY = threeDState.player.y;
      const playerMaxY = threeDState.player.y + threeDState.player.height;
      const playerMinZ = threeDState.player.z - threeDState.player.radius;
      const playerMaxZ = threeDState.player.z + threeDState.player.radius;

      if (
        playerMaxX > x && playerMinX < x + 1 &&
        playerMaxY > y && playerMinY < y + 1 &&
        playerMaxZ > z && playerMinZ < z + 1
      ) return;

      setThreeBlock(x, y, z, selectedBlock);
      if (isCreativeModeActive() && currentMatchMode === "creative") {
        saveActiveCreativeWorldSnapshot();
        updateUI();
        return;
      }
      inventory[selectedBlock]--;
      stats.blocksPlaced++;
      addXp(2 + progression.skills.builder * 3);
      checkAchievements();
      saveGame();
      renderHotbar();
      updateUI();
    }

    function updateThreePlayer(delta) {
      const player3d = threeDState.player;
      const pulseSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.pulse || 0);
      const moveSpeed = 5.5 + progression.skills.movement * 0.35 + pulseSkill * 0.2;
      const gravity = 24;
      const jumpPower = 8.8 + progression.skills.movement * 0.35 + pulseSkill * 0.25;

      let inputX = 0;
      let inputZ = 0;
      if (keys["w"] || keys["arrowup"]) inputZ += 1;
      if (keys["s"] || keys["arrowdown"]) inputZ -= 1;
      if (keys["a"] || keys["arrowleft"]) inputX -= 1;
      if (keys["d"] || keys["arrowright"]) inputX += 1;

      const cos = Math.cos(player3d.yaw);
      const sin = Math.sin(player3d.yaw);
      const worldX = (inputX * cos) - (inputZ * sin);
      const worldZ = (inputZ * cos) + (inputX * sin);
      const length = Math.hypot(worldX, worldZ) || 1;

      player3d.vx = (worldX / length) * (inputX || inputZ ? moveSpeed : 0);
      player3d.vz = (worldZ / length) * (inputX || inputZ ? moveSpeed : 0);

      if ((keys[" "] || keys["w"]) && player3d.onGround && document.pointerLockElement === threeDState.renderer.domElement) {
        player3d.vy = jumpPower;
        player3d.onGround = false;
      }

      player3d.vy -= gravity * delta;

      const tryX = player3d.x + player3d.vx * delta;
      if (!collidesThreePlayer(tryX, player3d.y, player3d.z)) player3d.x = tryX;

      const tryZ = player3d.z + player3d.vz * delta;
      if (!collidesThreePlayer(player3d.x, player3d.y, tryZ)) player3d.z = tryZ;

      const tryY = player3d.y + player3d.vy * delta;
      if (!collidesThreePlayer(player3d.x, tryY, player3d.z)) {
        player3d.y = tryY;
        player3d.onGround = false;
      } else {
        if (player3d.vy < 0) player3d.onGround = true;
        player3d.vy = 0;
      }

      if (player3d.y < 2) {
        const spawn = threeDState.spawn || { x: 6, y: 6, z: 6 };
        player3d.x = spawn.x;
        player3d.y = spawn.y;
        player3d.z = spawn.z;
        player3d.vy = 0;
      }

      threeDState.camera.position.set(player3d.x, player3d.y + player3d.height * 0.92, player3d.z);
      threeDState.camera.rotation.order = "YXZ";
      threeDState.camera.rotation.y = player3d.yaw;
      threeDState.camera.rotation.x = player3d.pitch;

      stats.distanceWalked += Math.abs(player3d.vx) * 7 + Math.abs(player3d.vz) * 7;
      checkAchievements();
    }

    function animateThreeD() {
      if (!threeDState.active) return;

      const delta = Math.min(0.033, threeDState.clock.getDelta());
      updateThreePlayer(delta);
      updateThreeTarget();
      threeDState.renderer.render(threeDState.scene, threeDState.camera);

      threeDState.uiTick += delta;
      if (threeDState.uiTick > 0.15) {
        updateUI();
        threeDState.uiTick = 0;
      }

      requestAnimationFrame(animateThreeD);
    }

    function startThreeDMode() {
      if (threeDState.active) return;
      if (!window.THREE) {
        showMessage("3D-Engine fehlt: Three.js konnte nicht geladen werden.", 3200);
        isThreeDMode = false;
        if (threeRoot) threeRoot.classList.add("hidden");
        if (crosshair3d) crosshair3d.classList.add("hidden");
        if (canvas) canvas.style.display = "block";
        updateLobbyUi();
        return;
      }

      canvas.style.display = "none";
      threeRoot.classList.remove("hidden");
      crosshair3d.classList.remove("hidden");

      threeDState.scene = new THREE.Scene();
      threeDState.scene.background = new THREE.Color(0x9fd4f5);
      threeDState.scene.fog = new THREE.Fog(0xaed7f2, 18, 58);

      threeDState.camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 200);
