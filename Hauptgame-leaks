      const youtubeId = ytBgDialogVideoId || extractYouTubeVideoId(ytBgLinkInput?.value || "");
      if (!youtubeId) {
        showMessage("Ungueltiger YouTube-Link oder Video-ID.", 2400);
        updateYoutubeLobbyBgPreview();
        return;
      }

      const duplicate = getAllLobbyBackgrounds().find((entry) => entry.sourceType === "custom" && entry.youtubeId === youtubeId);
      if (duplicate) {
        closeYoutubeLobbyBgDialog();
        equipLobbyBackgroundFromLocker(duplicate.id);
        showMessage("Dieser YouTube-Hintergrund ist schon in deinem Spind.", 2400);
        return;
      }

      const customCount = Array.isArray(playerSkin.customLobbyBackgrounds) ? playerSkin.customLobbyBackgrounds.length : 0;
