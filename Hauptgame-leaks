    .startScreen {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      font-family: "Sora", "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 18% 20%, rgba(255, 214, 126, 0.16), transparent 35%),
        radial-gradient(circle at 80% 18%, rgba(109, 208, 255, 0.2), transparent 38%),
        radial-gradient(circle at 30% 80%, rgba(136, 255, 192, 0.12), transparent 40%),
        linear-gradient(140deg, rgba(6, 10, 18, 0.98), rgba(8, 14, 24, 0.98));
      overflow: auto;
    }

    .startScreen::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, rgba(255, 255, 255, 0.06), transparent 40%),
        linear-gradient(200deg, rgba(45, 80, 120, 0.22), transparent 60%);
      opacity: 0.55;
      pointer-events: none;
    }

    .startBox {
      position: relative;
      z-index: 1;
      width: 100%;
      min-height: 100vh;
      display: grid;
      grid-template-columns: minmax(340px, 1.1fr) minmax(360px, 0.9fr);
      overflow: hidden;
      border-radius: 0;
      border: none;
      background:
        linear-gradient(135deg, rgba(12, 18, 28, 0.92), rgba(6, 10, 18, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.04);
      backdrop-filter: blur(16px);
      color: white;
    }

    .startHero {
      position: relative;
      padding: 36px 38px 28px;
      display: grid;
      align-content: space-between;
      gap: 14px;
      background:
        radial-gradient(circle at top left, rgba(255, 200, 120, 0.22), transparent 32%),
        radial-gradient(circle at 70% 0%, rgba(106, 200, 255, 0.2), transparent 40%),
        linear-gradient(180deg, rgba(16, 24, 36, 0.96), rgba(8, 12, 20, 0.98));
      border-right: 1px solid rgba(255,255,255,0.06);
      text-align: left;
    }

    .startHero::before {
      content: "";
      position: absolute;
      inset: auto 36px 30px auto;
      width: 200px;
      height: 200px;
      border-radius: 44px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02)),
        radial-gradient(circle at 35% 25%, rgba(255, 255, 255, 0.2), transparent 50%);
      border: 1px solid rgba(255,255,255,0.1);
      transform: rotate(18deg);
      pointer-events: none;
    }

    .startHeroTop {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
      max-width: 520px;
    }

    .startBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      min-height: 30px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff3d4;
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .startBox h1 {
      margin: 0;
      max-width: 540px;
      font-family: "Bangers", "Arial Black", sans-serif;
      font-size: clamp(40px, 5.4vw, 76px);
      line-height: 0.9;
      letter-spacing: -0.04em;
      text-transform: uppercase;
      color: #fff8ea;
      text-shadow: 0 16px 34px rgba(0,0,0,0.34);
    }

    .startLead {
      margin: 0;
      max-width: 500px;
      font-size: 14px;
      line-height: 1.6;
      color: rgba(236, 242, 250, 0.88);
    }

    .startQuickRow {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .startQuickChip {
      min-height: 56px;
      padding: 10px 12px;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
      border: 1px solid rgba(255,255,255,0.14);
      color: rgba(247, 244, 238, 0.95);
      font-size: 11px;
      font-weight: 800;
      line-height: 1.45;
      display: flex;
      align-items: flex-end;
    }

    .startMetaGrid {
