    function formatRemainingTime(targetTime) {
      if (!targetTime || Date.now() >= targetTime) return "abgelaufen";

      const totalSec = Math.floor((targetTime - Date.now()) / 1000);
      const h = Math.floor(totalSec / 3600);
      const m = Math.floor((totalSec % 3600) / 60);
      const s = totalSec % 60;

      return `${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
    }

    function formatRemainingTimeWithDays(targetTime) {
      if (!targetTime || Date.now() >= targetTime) return "abgelaufen";

      const totalSec = Math.floor((targetTime - Date.now()) / 1000);
      const days = Math.floor(totalSec / 86400);
      const h = Math.floor((totalSec % 86400) / 3600);
      const m = Math.floor((totalSec % 3600) / 60);
      const s = totalSec % 60;
      const dayLabel = days === 1 ? "Tag" : "Tage";

      return `${days} ${dayLabel} ${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
    }

    function getNextShopResetTime() {
      const now = new Date();
      const reset = new Date(now);
      reset.setHours(24, 0, 0, 0);
      return reset.getTime();
    }

    function getNextDailyQuestResetTime() {
      const now = new Date();
      const reset = new Date(now);
      reset.setHours(24, 0, 0, 0);
      return reset.getTime();
    }

    function getNextWeeklyQuestResetTime() {
      const now = new Date();
      const reset = new Date(now);
      reset.setHours(0, 0, 0, 0);
      const dayIndex = reset.getDay();
      let daysUntilMonday = (8 - dayIndex) % 7;
      if (daysUntilMonday === 0 && now.getTime() >= reset.getTime()) {
        daysUntilMonday = 7;
      }
      reset.setDate(reset.getDate() + daysUntilMonday);
      return reset.getTime();
    }

    function updateQuestCountdowns() {
