      belt.position.set(0, 0.67, 0);
      group.add(belt);

      const head = new THREE.Mesh(new THREE.BoxGeometry(0.46, 0.46, 0.46), skinMat);
      head.position.set(0, 1.55, 0);
      group.add(head);

