    async function fetchCreatorProfileByCode(rawCode) {
      const normalizedCode = (rawCode || "").trim().toLowerCase();
      if (!normalizedCode) return null;

      if (creatorAccountProfiles[normalizedCode]) {
        return creatorAccountProfiles[normalizedCode];
      }

      if (supabaseClient) {
        try {
          const { data, error } = await supabaseClient
            .from(PLAYER_ACCOUNTS_TABLE)
            .select("player_key, player_name, creator_enabled, creator_display_name, creator_cashback_percent, creator_total_earnings, creator_total_supported_spend, creator_total_purchases, creator_auto_payout, creator_pending_payout")
            .eq("creator_enabled", true);

          if (!error && Array.isArray(data)) {
            const matchedAccount = data.find((row) => {
              const playerKey = normalizeCreatorLookupValue(row.player_key);
              const playerName = normalizeCreatorLookupValue(row.player_name);
              const displayName = normalizeCreatorLookupValue(row.creator_display_name);
              return normalizedCode === playerKey || normalizedCode === playerName || normalizedCode === displayName;
            });

            if (matchedAccount) {
              const profile = buildCreatorProfileFromAccountRow(matchedAccount, normalizedCode);
              if (profile) {
                creatorAccountProfiles[normalizedCode] = profile;
                creatorAccountProfiles[profile.code] = profile;
                return profile;
              }
            }
          }
        } catch (err) {
          console.warn("Creator-Konto konnte nicht aus Supabase geladen werden:", err);
        }
      }

      if (creatorCodes[normalizedCode]) {
        creatorAccountProfiles[normalizedCode] = {
          ...creatorCodes[normalizedCode],
          playerKey: normalizedCode,
          source: "local"
        };
        return creatorAccountProfiles[normalizedCode];
      }

      return null;
    }

