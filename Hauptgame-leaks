    function getQuestProgress(def) {
      if (def.type === "blocksMined") return stats.blocksMined || 0;
      if (def.type === "slimesKilled") return stats.slimesKilled || 0;
      if (def.type === "alienFragment") return loot.alienFragment || 0;
      if (def.type === "goldMined") return stats.goldMined || 0;
      if (def.type === "blocksPlaced") return stats.blocksPlaced || 0;
      if (def.type === "distanceWalked") return stats.distanceWalked || 0;
      if (def.type === "crafts") return craftedState.totalCrafts || 0;
      return 0;
    }

    function withXpIcon(text = "") {
      return String(text).replace(/XP/g, '<span class="xpInlineIcon" aria-label="XP"></span>');
    }

    function hashStringSeed(text) {
      let hash = 2166136261;
      for (let i = 0; i < text.length; i++) {
        hash ^= text.charCodeAt(i);
        hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
      }
      return hash >>> 0;
    }

    function mulberry32(seed) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = t;
        r = Math.imul(r ^ (r >>> 15), r | 1);
        r ^= r + Math.imul(r ^ (r >>> 7), r | 61);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pickQuestSet(pool, count, seedKey) {
      const list = Array.isArray(pool) ? pool.slice() : [];
      if (!list.length) return [];
      const rng = mulberry32(hashStringSeed(seedKey));
      for (let i = list.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [list[i], list[j]] = [list[j], list[i]];
      }
      return list.slice(0, Math.max(1, Math.min(count, list.length)));
    }

    function getQuestDateKey(now = new Date()) {
      return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;
    }

    function getQuestWeekKey(now = new Date()) {
      const copy = new Date(now);
      copy.setHours(0, 0, 0, 0);
      const dayIndex = (copy.getDay() + 6) % 7;
      copy.setDate(copy.getDate() - dayIndex);
      return `${copy.getFullYear()}-${String(copy.getMonth() + 1).padStart(2, "0")}-${String(copy.getDate()).padStart(2, "0")}`;
    }

    function ensureQuestCadenceState(now = new Date()) {
      const dateKey = getQuestDateKey(now);
      const weekKey = getQuestWeekKey(now);
      let changed = false;

      if (questState.lastDailyKey !== dateKey) {
        questState.lastDailyKey = dateKey;
        questState.claimedDaily = [];
        changed = true;
      }
      if (questState.lastWeeklyKey !== weekKey) {
        questState.lastWeeklyKey = weekKey;
        questState.claimedWeekly = [];
        changed = true;
      }
      return changed;
    }

    function getActiveQuestDefinitions() {
      const now = new Date();
      const dateKey = getQuestDateKey(now);
      const weekKey = getQuestWeekKey(now);
      const daily = pickQuestSet(questPools.daily, 3, `daily:${dateKey}`);
      const weekly = pickQuestSet(questPools.weekly, 2, `weekly:${weekKey}`);
      return [
        ...daily.map((q) => ({ ...q, cadence: "daily" })),
        ...weekly.map((q) => ({ ...q, cadence: "weekly" }))
      ];
    }

    function isQuestClaimed(id, cadence = "daily") {
      const list = cadence === "weekly" ? questState.claimedWeekly : questState.claimedDaily;
      return Array.isArray(list) && list.includes(id);
    }

    function isQuestComplete(def) {
      return getQuestProgress(def) >= def.target;
    }

    function claimQuestReward(id) {
      const didReset = ensureQuestCadenceState();
      const def = getActiveQuestDefinitions().find((entry) => entry.id === id);
      if (!def) return;
      if (isQuestClaimed(id, def.cadence)) return showMessage("Quest schon abgeholt!", 1800);
      if (!isQuestComplete(def)) return showMessage("Quest noch nicht fertig!", 1800);

      if (def.reward.type === "gold") inventory[7] += def.reward.amount;
      if (def.reward.type === "xp") addXp(def.reward.amount);
      if (def.cadence === "weekly") {
        questState.claimedWeekly.push(id);
      } else {
        questState.claimedDaily.push(id);
      }
      renderQuestMenu();
      renderInventory();
      updateUI();
      queueDeferredSave();
      showMessage(`Quest abgeschlossen: ${def.reward.label}`, 2200);
    }

    function renderQuestMenu() {
      if (!questDailyGrid || !questWeeklyGrid || !questMilestoneGrid) return;
      const didReset = ensureQuestCadenceState();
      const activeQuests = getActiveQuestDefinitions();
      const dailyQuests = activeQuests.filter((def) => def.cadence !== "weekly");
      const weeklyQuests = activeQuests.filter((def) => def.cadence === "weekly");
      const claimedCount = activeQuests.filter((def) => isQuestClaimed(def.id, def.cadence)).length;
      const claimedDaily = dailyQuests.filter((def) => isQuestClaimed(def.id, "daily")).length;
      const claimedWeekly = weeklyQuests.filter((def) => isQuestClaimed(def.id, "weekly")).length;
      if (questInfo) questInfo.textContent = `${claimedCount} / ${activeQuests.length} erledigt`;
      if (questDailyInfo) questDailyInfo.textContent = `${claimedDaily} / ${dailyQuests.length} erledigt`;
      if (questWeeklyInfo) questWeeklyInfo.textContent = `${claimedWeekly} / ${weeklyQuests.length} erledigt`;

      const buildQuestCards = (list) => list.map((def) => {
        const progress = getQuestProgress(def);
        const complete = progress >= def.target;
        const claimed = isQuestClaimed(def.id, def.cadence);
        const pct = Math.max(0, Math.min(100, (progress / def.target) * 100));
        const rewardLabel = withXpIcon(def.reward.label || "");
        return `
          <div class="skillCard ${claimed ? "claimed" : ""}">
            <div class="skillHeader">
              <div>
                <div class="skillName">${def.name}</div>
                <div class="skillLevel">Belohnung: ${rewardLabel}</div>
              </div>
            </div>
            <div class="skillDesc">${def.desc}</div>
            <div class="shopBonusText">${Math.min(progress, def.target)} / ${def.target}</div>
            <div class="xpBarWrap" style="margin-bottom:10px;">
              <div class="xpBar" style="width:${pct}%;"></div>
            </div>
            <button class="skillActionBtn" data-quest-id="${def.id}" ${(!complete || claimed) ? "disabled" : ""}>${claimed ? "Abgeholt" : (complete ? "Abholen" : "In Arbeit")}</button>
          </div>
        `;
      }).join("");

      questDailyGrid.innerHTML = buildQuestCards(dailyQuests);
      questWeeklyGrid.innerHTML = buildQuestCards(weeklyQuests);

      const totalSkillLevel = Object.values(progression.skills || {}).reduce((sum, value) => sum + (value || 0), 0);
      const milestoneDefs = [
        { id: "milestone_level_25", name: "Einsatzleiter", desc: "Erreiche Level 25.", current: progression.level || 0, target: 25, reward: "+400 XP" },
        { id: "milestone_skill_24", name: "Taktiknetz", desc: "Investiere insgesamt 24 Skillpunkte.", current: totalSkillLevel, target: 24, reward: "+2 Skillpunkte" },
        { id: "milestone_mine_900", name: "Bohrkommando", desc: "Baue 900 Blöcke ab.", current: stats.blocksMined || 0, target: 900, reward: "+420 M-Bucks" },
        { id: "milestone_build_700", name: "Bastionsarchitekt", desc: "Platziere 700 Blöcke.", current: stats.blocksPlaced || 0, target: 700, reward: "+420 M-Bucks" },
        { id: "milestone_walk_160000", name: "Langmarsch", desc: "Laufe 160.000 Pixel.", current: stats.distanceWalked || 0, target: 160000, reward: "+650 XP" },
        { id: "milestone_crafts_40", name: "Master-Mechanik", desc: "Schließe 40 Crafting-Vorgaenge ab.", current: craftedState.totalCrafts || 0, target: 40, reward: "Titel: Werkbank-Legende" }
      ];
      const milestoneDone = milestoneDefs.filter((def) => def.current >= def.target).length;
      if (questMilestoneInfo) questMilestoneInfo.textContent = `${milestoneDone} / ${milestoneDefs.length} erledigt`;

      questMilestoneGrid.innerHTML = milestoneDefs.map((def) => {
        const complete = def.current >= def.target;
