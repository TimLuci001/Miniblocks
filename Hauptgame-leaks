    async function createAccountWithCloud(name, pin) {
      if (!supabaseClient) {
        cloudSyncEnabled = false;
        startInfo.textContent = "Supabase ist nicht erreichbar. Kontoerstellung ist gerade nicht möglich.";
        return false;
      }

      const normalizedName = normalizePlayerName(name);
      const pinHash = await hashText(pin);

      try {
        const existingAccount = await fetchAccountRecord(normalizedName);
        if (existingAccount) {
          startInfo.textContent = "Dieser Name ist schon vergeben. Bitte melde dich an.";
          return false;
        }

        const { error } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .insert({
            player_key: normalizedName,
            player_name: name,
            pin_hash: pinHash,
            created_at: new Date().toISOString(),
            last_login_at: new Date().toISOString()
          });

        if (error) throw error;
        startInfo.textContent = "Konto erstellt. Spielstand wird eingerichtet...";
        return finishCloudLogin(name, pinHash);
      } catch (error) {
        console.warn("Konto konnte nicht erstellt werden:", error);
        startInfo.textContent = getSupabaseAccountErrorText(
          error,
          "Konto konnte nicht erstellt werden."
        );
        return false;
      }
    }

    async function loginWithCloud(name, pin) {
      if (!supabaseClient) {
        cloudSyncEnabled = false;
        startInfo.textContent = "Supabase ist nicht erreichbar. Anmeldung ist gerade nicht möglich.";
        return false;
      }

      const normalizedName = normalizePlayerName(name);
      const pinHash = await hashText(pin);

      try {
        const account = await fetchAccountRecord(normalizedName);
        if (!account) {
          startInfo.textContent = "Dieses Konto wurde nicht gefunden. Bitte zuerst erstellen.";
          return false;
        }
        if (account.pin_hash !== pinHash) {
          cloudSyncEnabled = false;
          cloudPlayerKey = "";
          cloudPinHash = "";
          cloudAccountName = "";
          startInfo.textContent = "Diese PIN passt nicht zu diesem Konto.";
          return false;
        }

        startInfo.textContent = "Konto gefunden. Spielstand wird geladen...";
        return finishCloudLogin(account.player_name || name, pinHash);
      } catch (error) {
        console.warn("Anmeldung fehlgeschlagen:", error);
        startInfo.textContent = getSupabaseAccountErrorText(
          error,
          "Anmeldung fehlgeschlagen."
        );
        return false;
      }
    }

