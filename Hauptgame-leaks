    function addXp(amount) {
      const scholarSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.scholar || 0);
      const riftSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.rift || 0);
      const xpMultiplier = (1 + scholarSkill * 0.07) * getLiveXpMultiplier();
      const finalAmount = Math.round(amount * xpMultiplier);
      progression.xp += finalAmount;
      battlePassState.xp += Math.round(finalAmount * getLiveBattlePassMultiplier() * (1 + riftSkill * 0.05));
      registerCommunityEventXp(finalAmount);

      while (progression.xp >= getXpNeeded()) {
        progression.xp -= getXpNeeded();
        progression.level++;
        progression.skillPoints++;
        showMessage(`Level Up! Level ${progression.level}`, 2600);
      }

      renderXp();
      renderSkills();
      renderBattlePass();
      saveGame();
    }

