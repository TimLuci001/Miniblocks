    function hashStringSeed(text) {
      let hash = 2166136261;
      for (let i = 0; i < text.length; i++) {
        hash ^= text.charCodeAt(i);
        hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
      }
      return hash >>> 0;
    }

    function mulberry32(seed) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = t;
        r = Math.imul(r ^ (r >>> 15), r | 1);
        r ^= r + Math.imul(r ^ (r >>> 7), r | 61);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pickQuestSet(pool, count, seedKey) {
      const list = Array.isArray(pool) ? pool.slice() : [];
      if (!list.length) return [];
      const rng = mulberry32(hashStringSeed(seedKey));
      for (let i = list.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [list[i], list[j]] = [list[j], list[i]];
      }
      return list.slice(0, Math.max(1, Math.min(count, list.length)));
    }

    function getActiveQuestDefinitions() {
      const now = new Date();
      const dateKey = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;
      const weekNumber = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 1).getTime()) / (7 * 86400000));
      const weekKey = `${now.getFullYear()}-W${weekNumber}`;
      const daily = pickQuestSet(questPools.daily, 3, `daily:${dateKey}`);
      const weekly = pickQuestSet(questPools.weekly, 2, `weekly:${weekKey}`);
      return [
        ...daily.map((q) => ({ ...q, cadence: "daily" })),
        ...weekly.map((q) => ({ ...q, cadence: "weekly" }))
      ];
    }

