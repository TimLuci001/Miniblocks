    function buildSkyIsland(cx, topY, halfWidth, coreBlock = 2, topBlock = 1) {
      for (let dx = -halfWidth; dx <= halfWidth; dx++) {
        const columnHeight = Math.max(1, 2 + Math.floor((halfWidth - Math.abs(dx)) * 0.55));
        const wx = cx + dx;
        if (wx < 0 || wx >= WORLD_WIDTH) continue;
        if (topY >= 0 && topY < WORLD_HEIGHT) world[topY][wx] = topBlock;
        for (let dy = 1; dy <= columnHeight; dy++) {
          const wy = topY + dy;
          if (wy >= 0 && wy < WORLD_HEIGHT) world[wy][wx] = coreBlock;
        }
        const stoneDepth = topY + columnHeight + 1;
        if (stoneDepth >= 0 && stoneDepth < WORLD_HEIGHT && Math.abs(dx) <= Math.max(1, halfWidth - 3)) {
          world[stoneDepth][wx] = 3;
        }
      }
    }

