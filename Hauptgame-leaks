    function ensureValidShopSpotlightSelection() {
      const current = getShopItemByType(shopSpotlightSelection.type, shopSpotlightSelection.id);
      if (current && isShopItemVisible(shopSpotlightSelection.type, shopSpotlightSelection.id)) return;

      const fallbackSpecial = specialSkins.find(item => isShopItemVisible("specials", item.id));
      const fallbackRain = rainColors.find(item => isShopItemVisible("rains", item.id));
      const fallbackBody = bodySkins.find(item => isShopItemVisible("bodies", item.id));
      const fallbackEye = eyeSkins.find(item => isShopItemVisible("eyes", item.id));

      if (shopBundles.find((entry) => entry.id === "starter_packet")) shopSpotlightSelection = { type: "bundle", id: "starter_packet" };
      else if (!isBattlePassFeatureDisabled() && !isBattlePassExpired()) shopSpotlightSelection = { type: "pass", id: "premium" };
      else if (fallbackRain) shopSpotlightSelection = { type: "rains", id: fallbackRain.id };
      else if (fallbackSpecial) shopSpotlightSelection = { type: "specials", id: fallbackSpecial.id };
      else if (fallbackBody) shopSpotlightSelection = { type: "bodies", id: fallbackBody.id };
      else if (fallbackEye) shopSpotlightSelection = { type: "eyes", id: fallbackEye.id };
    }

    function getShopSpotlightData() {
      ensureValidShopSpotlightSelection();
      const type = shopSpotlightSelection.type;
      const item = getShopItemByType(type, shopSpotlightSelection.id);
      if (!item) return null;
      return {
        type,
        item,
        rarityMeta: getRarityMeta(item.rarity || "common"),
        finalPrice: getDiscountedPrice(item.price, type, item.id)
      };
    }

    function getShopSpotlightEntries() {
      const entries = [];
      const seen = new Set();
      const tryAdd = (type, id) => {
        if (!type || !id) return;
        const key = `${type}:${id}`;
        if (seen.has(key)) return;
        const item = getShopItemByType(type, id);
        if (!item || !isShopItemVisible(type, id)) return;
        seen.add(key);
        entries.push({
          type,
          item,
          rarityMeta: getRarityMeta(item.rarity || "common"),
          finalPrice: getDiscountedPrice(item.price, type, item.id)
        });
      };

      ensureValidShopSpotlightSelection();
      tryAdd(shopSpotlightSelection.type, shopSpotlightSelection.id);
      tryAdd("bundle", "starter_packet");
      tryAdd("bundle", "builder_boost_pack");
      tryAdd("bundle", "storm_chaser_pack");
      if (!isBattlePassExpired()) tryAdd("pass", "premium");

      const fallbackLists = [
        ["bundle", shopBundles],
        ["rains", rainColors],
        ["specials", specialSkins],
        ["bodies", bodySkins],
        ["eyes", eyeSkins]
      ];

      for (const [type, list] of fallbackLists) {
        for (const entry of list) {
          tryAdd(type, entry.id);
          if (entries.length >= 3) return entries.slice(0, 3);
        }
      }

      return entries.slice(0, 3);
    }

    function getWishlistKey(type, id) {
      return `${type}:${id}`;
    }

    function isWishlisted(type, id) {
      return shopWishlist.includes(getWishlistKey(type, id));
    }

    function toggleWishlist(type, id) {
      const key = getWishlistKey(type, id);
      if (shopWishlist.includes(key)) {
        shopWishlist = shopWishlist.filter((entry) => entry !== key);
        showMessage("Aus Wunschliste entfernt!", 1800);
      } else {
        shopWishlist.push(key);
        showMessage("Zur Wunschliste hinzugefügt!", 1800);
      }
      queueDeferredSave();
      renderShop();
    }

    function getWishlistEntries() {
      return shopWishlist.map((entry) => {
        const [type, id] = entry.split(":");
        const item = getShopItemByType(type, id);
        if (!item) return null;
        return { type, id, item };
      }).filter(Boolean);
    }

    function renderWishlistSection() {
      if (!wishlistShopList) return;
      const entries = getWishlistEntries();
      if (!entries.length) {
        wishlistShopList.innerHTML = `<div class="shopWishlistEmpty">Markiere Angebote mit dem Herz, dann tauchen sie hier gesammelt wieder auf.</div>`;
        return;
      }

      wishlistShopList.innerHTML = entries.map(({ type, item }) => {
        if (type === "bundle") {
          const owned = isBundleOwned(item);
          const rarityMeta = getRarityMeta(item.rarity || "common");
          return `
            <div class="shopBundleCard ${owned ? "owned active" : ""}">
              <div class="shopBadgeRow">
                <span class="shopBadge ${rarityMeta.type}">${rarityMeta.label}</span>
                <span class="shopBadge new">Wunschliste</span>
                ${item.limited ? `<span class="shopBadge limited">⏰ Limitiert</span>` : ""}
              </div>
              <div class="shopBundlePreviewRow">${buildBundlePreview(item)}</div>
              <div><strong>${item.name}</strong></div>
              <div class="shopPrice">${localizeCurrencyText(item.lead)}<br>Preis: ${formatCurrencyMarkup(item.price)}</div>
              <div class="shopActionRow">
                <button class="shopActionBtn" data-bundle-id="${item.id}" ${owned ? "disabled" : ""}>${owned ? "Komplett" : "Bundle kaufen"}</button>
                <button class="shopActionBtn shopWishlistBtn" data-wishlist-type="${type}" data-wishlist-id="${item.id}">♥</button>
              </div>
            </div>
          `;
        }
        return buildShopSkinCard(type, item);
      }).join("");
    }

    function renderShopSpotlight() {
      if (!shopSpotlight) return;
      shopSpotlight.innerHTML = "";
    }

    function buildBundlePreview(bundle) {
      const previewEntries = bundle.previewItems || bundle.items;
      return previewEntries.map((entry) => {
        const item = getShopItemByType(entry.type, entry.id);
        if (!item) return "";
        const color = entry.type === "specials" ? item.bodyColor : item.color;
        return `<div class="shopBundleMini" style="background:${color};"></div>`;
      }).join("");
    }

    function isBundleOwned(bundle) {
      if (bundle.repeatable) return false;
      return bundle.items.every((entry) => {
        if (entry.type === "eyes") return playerSkin.ownedEyes.includes(entry.id);
        if (entry.type === "bodies") return playerSkin.ownedBodies.includes(entry.id);
        if (entry.type === "specials") return playerSkin.ownedSpecials.includes(entry.id);
        if (entry.type === "rains") return playerSkin.ownedRains.includes(entry.id);
        if (entry.type === "currency") return true;
        return false;
      });
    }

    function getStarterPacketRandomReward(excludedKeys = []) {
      const pool = [
        ...eyeSkins.filter((item) => !item.shopHidden).map((item) => ({ type: "eyes", item })),
        ...bodySkins.filter((item) => !item.shopHidden).map((item) => ({ type: "bodies", item })),
        ...specialSkins.filter((item) => !item.shopHidden).map((item) => ({ type: "specials", item }))
      ].filter((entry) => !excludedKeys.includes(`${entry.type}:${entry.item.id}`));
      const unownedPool = pool.filter((entry) => (
        entry.type === "eyes" ? !playerSkin.ownedEyes.includes(entry.item.id)
          : entry.type === "bodies" ? !playerSkin.ownedBodies.includes(entry.item.id)
            : !playerSkin.ownedSpecials.includes(entry.item.id)
      ));
      const source = unownedPool.length ? unownedPool : pool;
      return source[Math.floor(Math.random() * source.length)] || null;
    }

    function getStarterPacketRandomRain() {
      const pool = rainColors.filter((item) => !item.shopHidden && item.id !== "default");
      const unownedPool = pool.filter((item) => !playerSkin.ownedRains.includes(item.id));
      const source = unownedPool.length ? unownedPool : pool;
      return source[Math.floor(Math.random() * source.length)] || null;
    }

    function buyShopBundle(bundleId) {
      const bundle = shopBundles.find(entry => entry.id === bundleId);
      if (!bundle) return;
      if (bundle.id === "starter_packet" && isBattlePassExpired()) return showMessage(`Starter Packet ist seit ${BATTLE_PASS_END_LABEL} nicht mehr verfügbar.`, 2600);
      if (bundle.id === "starter_packet" && STARTER_PACKET_DISABLED) return showMessage("Starter Packet kommt bald zurueck!", 2200);
      if (isBundleOwned(bundle)) return showMessage("Bundle schon komplett!");
      if (inventory[7] < bundle.price) return showMessage("Nicht genug M-Bucks für das Bundle!");

      inventory[7] -= bundle.price;
      const cashback = grantCreatorCashback(bundle.price);
      if (bundle.id === "starter_packet") {
        const randomRewards = [];
        const usedStarterRewards = [];
        for (let i = 0; i < 3; i++) {
          const reward = getStarterPacketRandomReward(usedStarterRewards);
          if (!reward) break;
          usedStarterRewards.push(`${reward.type}:${reward.item.id}`);
          randomRewards.push(reward);
        }
        const rainReward = getStarterPacketRandomRain();
        inventory[7] += 600;
        for (const randomReward of randomRewards) {
          if (randomReward.type === "eyes" && !playerSkin.ownedEyes.includes(randomReward.item.id)) {
            playerSkin.ownedEyes.push(randomReward.item.id);
            ensureSkinStored("eyes", randomReward.item.id);
          }
          if (randomReward.type === "bodies" && !playerSkin.ownedBodies.includes(randomReward.item.id)) {
            playerSkin.ownedBodies.push(randomReward.item.id);
            ensureSkinStored("bodies", randomReward.item.id);
          }
          if (randomReward.type === "specials" && !playerSkin.ownedSpecials.includes(randomReward.item.id)) {
            playerSkin.ownedSpecials.push(randomReward.item.id);
            ensureSkinStored("specials", randomReward.item.id);
          }
        }
        if (rainReward && !playerSkin.ownedRains.includes(rainReward.id)) {
          playerSkin.ownedRains.push(rainReward.id);
          ensureSkinStored("rains", rainReward.id);
        }
        stats.shopPurchases++;
        saveGame();
        renderShop();
        renderLocker();
        updateUI();
        checkAchievements();
        openShopPurchaseModal({
          lead: "Starter Packet gekauft. Du hast 600 M-Bucks, 3 zufaellige Skins und 1 zufaellige Regenfarbe bekommen.",
          rewards: [
            "+600 M-Bucks",
            ...randomRewards.map((randomReward) => `${randomReward.type === "eyes" ? "Augenfarbe" : (randomReward.type === "bodies" ? "Koerperfarbe" : "Spezial-Skin")}: ${randomReward.item.name}`),
            rainReward ? `Regenfarbe: ${rainReward.name}` : "Regenfarbe konnte nicht vergeben werden",
            ...(cashback > 0 ? [`Creator Bonus: +${cashback} M-Bucks`] : [])
          ],
          equipAction: randomRewards[0] ? () => {
            const featuredReward = randomRewards[0];
            if (featuredReward.type === "eyes") {
              playerSkin.activeSpecial = null;
              playerSkin.activeEyes = featuredReward.item.id;
            }
            if (featuredReward.type === "bodies") {
              playerSkin.activeSpecial = null;
              playerSkin.activeBody = featuredReward.item.id;
            }
            if (featuredReward.type === "specials") {
              playerSkin.activeSpecial = featuredReward.item.id;
            }
            if (rainReward) playerSkin.activeRain = rainReward.id;
            saveGame();
            renderShop();
            renderLocker();
            updateUI();
            closeShopPurchaseModal();
            showMessage(`${featuredReward.item.name} und ${rainReward ? rainReward.name : "deine Rewards"} ausgeruestet!`, 1800);
          } : null,
          equipLabel: "Starter Rewards ausruesten"
        });
        return;
      }

      for (const entry of bundle.items) {
        if (entry.type === "eyes" && !playerSkin.ownedEyes.includes(entry.id)) {
          playerSkin.ownedEyes.push(entry.id);
          ensureSkinStored("eyes", entry.id);
        }
        if (entry.type === "bodies" && !playerSkin.ownedBodies.includes(entry.id)) {
          playerSkin.ownedBodies.push(entry.id);
          ensureSkinStored("bodies", entry.id);
        }
        if (entry.type === "specials" && !playerSkin.ownedSpecials.includes(entry.id)) {
          playerSkin.ownedSpecials.push(entry.id);
          ensureSkinStored("specials", entry.id);
        }
        if (entry.type === "rains" && !playerSkin.ownedRains.includes(entry.id)) {
          playerSkin.ownedRains.push(entry.id);
          ensureSkinStored("rains", entry.id);
        }
        if (entry.type === "currency") {
          inventory[7] += Number(entry.amount || 0);
        }
      }

      stats.shopPurchases++;
      saveGame();
      renderShop();
      renderLocker();
      updateUI();
      checkAchievements();
      openShopPurchaseModal({
        lead: `${bundle.name} wurde gekauft. Alle Bundle-Inhalte sind jetzt in deinem Spind gespeichert.`,
        rewards: [
          ...bundle.items.map((entry) => {
            const item = getShopItemByType(entry.type, entry.id);
            if (entry.type === "currency") return `M-Bucks: +${Number(entry.amount || 0).toLocaleString("de-DE")}`;
            return `${entry.type === "eyes" ? "Augenfarbe" : (entry.type === "bodies" ? "Körperfarbe" : (entry.type === "rains" ? "Regenfarbe" : "Spezial-Skin"))}: ${item?.name || entry.id}`;
          }),
          ...(cashback > 0 ? [`Creator Bonus: +${cashback} M-Bucks`] : [])
        ],
        equipAction: null,
        equipLabel: "Ausrüsten"
      });
    }

