        spawnGauntletSlimeAtTile(bossTiles[0], "elite_fire");
        spawnGauntletSlimeAtTile(bossTiles[1], "elite_desert");
        spawnGauntletSlimeAtTile(bossTiles[2], "elite_alien");
        for (let i = 0; i < 7; i++) {
          const type = i % 2 === 0 ? "alien" : "fire";
          const tile = spawnTiles[Math.floor(Math.random() * spawnTiles.length)];
          spawnGauntletSlimeAtTile(tile, type);
        }
        showMessage(`Hero Gauntlet Finale ${wave}/${HERO_GAUNTLET_TOTAL_WAVES}!`, 2600);
      } else {
        const baseCount = 3 + wave * 2;
        const eliteCount = wave >= 4 ? Math.min(2, Math.floor((wave - 2) / 3)) : 0;
        const typePool = ["normal", "fire", "desert", "alien"];
        for (let i = 0; i < baseCount; i++) {
          const type = typePool[(wave + i) % typePool.length];
          const tile = spawnTiles[Math.floor(Math.random() * spawnTiles.length)];
          spawnGauntletSlimeAtTile(tile, type);
        }
        for (let i = 0; i < eliteCount; i++) {
          const eliteType = wave % 2 === 0 ? "elite_desert" : "elite_fire";
          const tile = spawnTiles[Math.floor(Math.random() * spawnTiles.length)];
          spawnGauntletSlimeAtTile(tile, eliteType);
        }
        showMessage(`Hero Gauntlet Welle ${wave}/${HERO_GAUNTLET_TOTAL_WAVES}`, 2200);
      }
      heroGauntletState.enemiesRemaining = slimes.length;
    }

    function completeHeroGauntletRun() {
      if (!heroGauntletState.active || heroGauntletState.completed) return;
      heroGauntletState.completed = true;
      heroGauntletState.waveInProgress = false;
      heroGauntletState.awaitingUpgrade = false;
      heroGauntletState.active = false;
      heroGauntletState.enemiesRemaining = 0;
      updateDerivedStats();
      inventory[7] += 1200;
      addXp(1200);
      progression.skillPoints += 2;
      showMessage("Hero Gauntlet abgeschlossen! +1200 XP, +1200 M-Bucks, +2 Skillpunkte", 3400);
      openShopPurchaseModal({
        lead: "Hero Gauntlet abgeschlossen!",
        reasons: [
          `Finale Welle ${HERO_GAUNTLET_TOTAL_WAVES} besiegt`,
          "Du kannst jetzt in Ruhe looten oder zur Lobby zurueckkehren"
        ],
        rewards: ["+1200 XP", "+1200 M-Bucks", "+2 Skillpunkte"],
        equipAction: null,
        equipLabel: "Weiter"
      });
      saveGame();
    }

    function updateHeroGauntlet() {
      if (!heroGauntletState.active || inLobby || !gameStarted) return;
      heroGauntletState.enemiesRemaining = slimes.length;
      if (heroGauntletState.waveInProgress || heroGauntletState.awaitingUpgrade) return;
      if (heroGauntletState.wave >= HERO_GAUNTLET_TOTAL_WAVES) {
        completeHeroGauntletRun();
        return;
      }
      heroGauntletState.awaitingUpgrade = true;
      setTimeout(() => {
        if (!heroGauntletState.active || inLobby || !gameStarted) return;
        openHeroGauntletUpgradeSelection();
        heroGauntletState.awaitingUpgrade = false;
        spawnHeroGauntletWave();
      }, HERO_GAUNTLET_WAVE_INTERMISSION_MS);
    }

    function updateHeroGauntletHud() {
      if (!gauntletModeInline || !gauntletModeHudWave || !gauntletModeHudFill || !gauntletModeHudMeta) return;
      const visible = gameStarted && !inLobby && selectedLobbyMode === "gauntlet" && !isSeason4LiveEventActive();
      if (!visible) {
        gauntletModeInline.classList.add("hidden");
        return;
      }
      gauntletModeInline.classList.remove("hidden");

      const total = Math.max(1, heroGauntletState.totalWaves || HERO_GAUNTLET_TOTAL_WAVES);
      const wave = Math.max(0, Math.min(heroGauntletState.wave || 0, total));
      const progress = Math.max(0, Math.min(1, wave / total));
      const enemies = Math.max(0, Math.floor(Number(heroGauntletState.enemiesRemaining || 0)));

      let phase = "Bereit";
      if (heroGauntletState.completed) phase = "Run abgeschlossen";
      else if (heroGauntletState.awaitingUpgrade) phase = "Upgrade waehlen";
      else if (heroGauntletState.waveInProgress) phase = "Kampf aktiv";
      else if (heroGauntletState.active) phase = "Naechste Welle";

      gauntletModeHudWave.textContent = `Welle ${wave}/${total}`;
      gauntletModeHudFill.style.width = `${(progress * 100).toFixed(1)}%`;
      gauntletModeHudMeta.textContent = `Gegner: ${enemies} | ${phase}`;
    }

    function startHeroGauntletRun() {
      resetHeroGauntletState(true);
      heroGauntletState.active = true;
      heroGauntletState.wave = 0;
      heroGauntletState.waveInProgress = false;
      heroGauntletState.awaitingUpgrade = true;
      slimes.length = 0;
      updateDerivedStats();
      showMessage("Hero Gauntlet gestartet! Bereite dich auf Welle 1 vor.", 2200);
      setTimeout(() => {
        if (!heroGauntletState.active || inLobby || !gameStarted) return;
        heroGauntletState.awaitingUpgrade = false;
        spawnHeroGauntletWave();
      }, 500);
    }

    function slimeRectCollides(slime, newX, newY) {
      return rectCollides(newX, newY, slime.w, slime.h);
    }

    function updateSlimes() {
      if (isSkySurvivalActive()) return;
      for (let i = slimes.length - 1; i >= 0; i--) {
        const s = slimes[i];
        s.dirTimer--;
        s.jumpCooldown--;

        const stealthIgnore = isStealthModeActive() && stealthState.active;
        const distanceToPlayer = (player.x + player.w / 2) - (s.x + s.w / 2);
        const chaseRange = stealthIgnore ? 0 : 220;
        if (!stealthIgnore && Math.abs(distanceToPlayer) < chaseRange) {
          s.vx = distanceToPlayer < 0 ? -s.moveSpeed : s.moveSpeed;
          addAlarm(0.35);
        } else if (s.dirTimer <= 0) {
          s.vx = Math.random() > 0.5 ? s.moveSpeed : -s.moveSpeed;
          s.dirTimer = 70 + Math.floor(Math.random() * 140);
        }

        if (s.onGround && s.jumpCooldown <= 0) {
          s.vy = s.type.includes("fire") ? -8.5 : (s.type.includes("desert") ? -8 : (s.type.includes("alien") ? -9 : -7.5));
          s.onGround = false;
          s.jumpCooldown = 50 + Math.floor(Math.random() * 80);
        }

        s.vy += GRAVITY;
        if (s.vy > 12) s.vy = 12;

        s.x += s.vx;
        if (slimeRectCollides(s, s.x, s.y)) {
          s.x -= s.vx;
          s.vx *= -1;
        }

        s.y += s.vy;
        if (slimeRectCollides(s, s.x, s.y)) {
          s.y -= s.vy;
          if (s.vy > 0) s.onGround = true;
          s.vy = 0;
        } else {
          s.onGround = false;
        }

        if (s.hurtTimer > 0) s.hurtTimer--;

        if (rectsOverlap(player.x, player.y, player.w, player.h, s.x, s.y, s.w, s.h)) {
          if (stealthIgnore) continue;
          const playerBottom = player.y + player.h;
          const slimeTop = s.y;

          if (player.vy > 2 && playerBottom - slimeTop < 20) {
            s.health--;
            s.hurtTimer = 10;
            player.vy = -8;

            if (s.health <= 0) {
              const fortuneGold = rollFortuneBonus();
              if (s.type.includes("desert") && Math.random() > 0.45) inventory[7]++;
              if (s.type.includes("alien") && Math.random() > 0.4) inventory[7] += 2;
              if (s.type.includes("fire") && Math.random() > 0.55) inventory[6]++;
              if (Math.random() > 0.6) inventory[2]++;
              if (fortuneGold) inventory[7] += 1;
              if (s.elite) inventory[7] += 8;

              if (s.type.includes("fire")) addLoot("emberCore", s.elite ? 3 : (Math.random() > 0.7 ? 2 : 1));
              else if (s.type.includes("alien")) addLoot("alienFragment", s.elite ? 4 : 2);
              else if (s.type.includes("desert")) addLoot("desertFang", s.elite ? 3 : (Math.random() > 0.7 ? 2 : 1));
              else addLoot("slimeGel", s.elite ? 3 : 1);
              addLoot("alienFragment", s.elite ? 2 : 1);
              if (s.elite) addLoot("bossShard", 1);

              stats.slimesKilled++;
              heroUltKills++;
              addXp((s.elite ? 70 : 30) + progression.skills.combat * 4);
              updateSwordUnlocks();
              checkAchievements();
              saveGame();
              slimes.splice(i, 1);

              if (s.type === "elite_fire") showMessage("Elite-Feuer-Slime besiegt!", 2200);
              else if (s.type === "elite_desert") showMessage("Elite-Wüsten-Slime besiegt!", 2200);
              else if (s.type === "elite_alien") showMessage("Elite-Alien-Slime besiegt!", 2200);
              else if (s.type === "elite") showMessage("Elite-Slime besiegt!", 2200);
              else if (s.type === "fire") showMessage(fortuneGold ? "Feuer-Slime besiegt! Fortune +1 M-Bucks!" : "Feuer-Slime besiegt!");
              else if (s.type === "alien") showMessage(fortuneGold ? "Alien-Slime besiegt! Fortune +1 M-Bucks!" : "Alien-Slime besiegt!");
              else if (s.type === "desert") showMessage(fortuneGold ? "Wüsten-Slime besiegt! Fortune +1 M-Bucks!" : "Wüsten-Slime besiegt!");
              else showMessage(fortuneGold ? "Slime besiegt! Fortune +1 M-Bucks!" : "Slime besiegt!");
              continue;
            }
          } else {
            damagePlayer(s.damage);
            if (player.x < s.x) player.x -= 12;
            else player.x += 12;
          }
        }
      }
      if (heroGauntletState.active) {
        heroGauntletState.enemiesRemaining = slimes.length;
        if (heroGauntletState.waveInProgress && slimes.length === 0) {
          heroGauntletState.waveInProgress = false;
        }
      }
    }

    function drawSlimes(cam) {
      if (isSkySurvivalActive()) return;
      for (const s of slimes) {
        const sx = s.x - cam.x;
        const sy = s.y - cam.y;

        ctx.fillStyle = s.hurtTimer > 0 ? "#ffffff" : s.color;
        ctx.fillRect(sx, sy, s.w, s.h);

        ctx.fillStyle = s.highlight;
        ctx.fillRect(sx + 4, sy + 3, s.w - 8, 7);

        ctx.fillStyle = s.type.includes("fire") ? "#5a1200" : (s.type.includes("alien") ? "#104b35" : "#111");
        ctx.fillRect(sx + 7, sy + 8, 4, 4);
        ctx.fillRect(sx + 17, sy + 8, 4, 4);

        if (s.type.includes("fire")) {
          ctx.fillStyle = "rgba(255,180,80,0.35)";
          ctx.fillRect(sx + 10, sy - 4, 3, 4);
          ctx.fillRect(sx + 16, sy - 2, 3, 5);
        }

        if (s.type.includes("alien")) {
          ctx.fillStyle = "rgba(111,255,213,0.35)";
          ctx.fillRect(sx + 9, sy - 5, 10, 3);
          ctx.fillRect(sx + 12, sy - 8, 4, 3);
        }

        if (s.elite) {
          ctx.strokeStyle = "rgba(255, 233, 133, 0.9)";
          ctx.lineWidth = 2;
          ctx.strokeRect(sx - 2, sy - 2, s.w + 4, s.h + 4);
          ctx.fillStyle = "#ffe680";
          ctx.fillRect(sx + 11, sy - 8, 6, 4);
          ctx.fillRect(sx + 8, sy - 4, 4, 4);
          ctx.fillRect(sx + 16, sy - 4, 4, 4);
        }

        if (isStealthModeActive() && stealthState.active) {
          ctx.save();
          ctx.font = "bold 14px Arial";
          ctx.fillStyle = "rgba(255, 255, 255, 0.85)";
          ctx.strokeStyle = "rgba(20, 40, 60, 0.6)";
          ctx.lineWidth = 3;
          const qx = sx + s.w / 2 - 4;
          const qy = sy - 10;
          ctx.strokeText("?", qx, qy);
          ctx.fillText("?", qx, qy);
          ctx.restore();
        }
      }
    }


    function rectsOverlap(x1, y1, w1, h1, x2, y2, w2, h2) {
      return !(
        x1 + w1 <= x2 ||
        x1 >= x2 + w2 ||
        y1 + h1 <= y2 ||
        y1 >= y2 + h2
      );
    }

    function gameLoop(timestamp = 0) {
      if (isThreeDMode) {
        updateMessage(16);
        if (gameStarted) updateUI();
        requestAnimationFrame(gameLoop);
        return;
      }

      const deltaMs = timestamp - lastTime;
      lastTime = timestamp;

      dayTime += DAY_SPEED;
      updateWeather();

      if (attackCooldown > 0) attackCooldown--;
      if (attackTimer > 0) attackTimer--;
      if (heroCooldown > 0) heroCooldown--;
      if (selectedHero === "cosmicguard" && gameStarted) {
        heroHealTick++;
        if (heroHealTick >= 480 && player.health < player.maxHealth) {
          heroHealTick = 0;
          player.health = Math.min(player.maxHealth, player.health + 1);
        }
      } else { heroHealTick = 0; }

      updateEffects();
      updateStealthState(deltaMs || 16);

      if (gameStarted && !maintenanceMode && !inventoryOpen && !helpOpen && !skillOpen && !craftOpen && !communityEventOpen && !npcOpen) {
        updatePlayer();
        updateSlimes();
        updateMining();
        updateRiftGlitch();
        updateFloorLavaMode();
        updateFloodMode();
      }

      updateRiftAudio();

      updateMessage(deltaMs || 16);
      getActiveLobbyVoteMode();
      updateAdminShopInfo();

      const cam = getCamera();

ctx.clearRect(0, 0, canvas.width, canvas.height);
drawBackground(cam);
drawWorld(cam);
drawFloorLava(cam);
drawFloodWater(cam);
drawDossierMarkers(cam);
drawVaultMarker(cam);
updateRiftParticles(cam);
drawRiftParticles(cam);
drawEasterEggs(cam);
drawPortals(cam);
drawMiningCracks(cam);
drawNpcs(cam);
drawSlimes(cam);
drawPlayer(cam);
drawNpcHint(cam);
drawCrosshairBlock(cam);
drawWeather(cam);
drawDayNightOverlay();
drawRiftGlitchOverlay(cam);

      updateUI();
      requestAnimationFrame(gameLoop);
    }

    loadHeartsWarningStateLocal();
    if (supabaseClient) {
  loadMaintenanceStateFromSupabase().then((loadedFromSupabase) => {
    if (loadedFromSupabase) {
      updateBattlePassAvailability();
      renderBattlePassButtonCountdown();
      updateLobbyUi();
      updateUI();
    }
  });
  subscribeToGameStateRealtime();
  setInterval(async () => {
    const loadedFromSupabase = await loadMaintenanceStateFromSupabase();
    if (loadedFromSupabase) {
      updateBattlePassAvailability();
      renderBattlePassButtonCountdown();
      updateLobbyUi();
      updateUI();
    }
  }, 30000);
} else {
  setMaintenanceMode(false);
}

    bindStartScreenControls();
    bindAdminTabs();

    try {
      loadPlayerName();
      if (!supabaseClient) {
        loadShopAdminStateLocal();
        loadModeAccessStateLocal();
        loadEmergencyStateLocal();
        loadLiveEventStateLocal();
      }
      loadTwitchSettings();
      loadUiTheme();
      loadRiftEffectsSetting();
      loadLooksTabSetting();
      loadAdminToolsState();
      loadCrewMembership();
      
      loadGame();
      loadThreeDOutfitSetting();
      bindLooksTabs();
      ensureLobbyBackgroundOwnership();
      ensureOwnedSkinsStored();
      applyLobbyBackgroundVisual();
      updateSwordUnlocks();
      updateDerivedStats();
      renderAchievements();
      renderInventory();
      renderLocker();
      renderHotbar();
      renderSkills();
      updateBattlePassAvailability();
      renderBattlePassButtonCountdown();
      renderBattlePassCountdownCard();
      renderBattlePass();
      renderEffects();
      renderXp();
      updateHeartsHud();
      updateTwitchUi();
      updateLoreUi();
      renderLeakMenu();
      updateLobbyUi();
      updateUI();
    } catch (error) {
      console.error("Fehler beim Hintergrund-Laden:", error);
      if (startInfo) {
        startInfo.textContent = "Startmenü aktiv. Hintergrund lädt gerade nicht korrekt, Konto/Offline sollte aber trotzdem gehen.";
      }
      updateLobbyUi();
      updateUI();
    }

    playerNameInput.addEventListener("input", () => {
      startNewsConfirmed = false;
    });
    if (playerPinInput) {
      playerPinInput.addEventListener("input", () => {
        startNewsConfirmed = false;
      });
    }
    window.addEventListener("beforeunload", () => {
      disconnectTwitch(false);
      const payload = createSavePayload();
      localStorage.setItem(SAVE_KEY, JSON.stringify(payload));
      if (cloudSyncTimer) clearTimeout(cloudSyncTimer);
      uploadCloudSave(payload);
    });

    const tryInitRiftAudio = () => initRiftAudio();
    window.addEventListener("pointerdown", tryInitRiftAudio, { once: true });
    window.addEventListener("keydown", tryInitRiftAudio, { once: true });
    window.addEventListener("keydown", (event) => {
      if (event.repeat) return;
      const tag = (event.target && event.target.tagName) ? event.target.tagName.toLowerCase() : "";
      if (tag === "input" || tag === "textarea") return;
      if (event.key.toLowerCase() === "c" && isStealthModeActive() && gameStarted && !inLobby) {
        toggleStealthMode();
      }
    });

    gameLoop();
  </script>
