    async function upsertCreativeWorldToSupabase(entry, { publish = false } = {}) {
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey || !entry) return false;
      const payload = {
        id: entry.id,
        owner_key: cloudPlayerKey,
        world_name: entry.name,
        world_data: {
          grid: entry.data,
          devices: entry.devices || [],
          settings: entry.settings || getCreativeSettingsDefaults(),
          three: entry.three || createBaseThreeWorldData()
        },
        published: publish ? true : !!entry.published,
        created_at: new Date(entry.createdAt || Date.now()).toISOString(),
        updated_at: new Date(entry.updatedAt || Date.now()).toISOString()
      };
      if (publish) {
        payload.published_at = new Date().toISOString();
      }
      const { error } = await supabaseClient
        .from(CREATIVE_WORLDS_TABLE)
        .upsert(payload, { onConflict: "id" });
      if (error) {
        console.warn("Creative-Welt konnte nicht gespeichert werden:", error);
        return false;
      }
      return true;
    }

    async function loadCreativeWorldsFromSupabase() {
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) return;
      try {
        const { data, error } = await supabaseClient
          .from(CREATIVE_WORLDS_TABLE)
          .select("id, world_name, world_data, published, created_at, updated_at")
          .eq("owner_key", cloudPlayerKey)
          .order("updated_at", { ascending: false });
        if (error || !Array.isArray(data)) return;
        const map = new Map(creativeWorlds.map((entry) => [entry.id, entry]));
        for (const row of data) {
          const id = String(row.id || "");
          if (!id) continue;
          const existing = map.get(id);
          const updatedAt = Date.parse(row.updated_at || "") || Date.now();
          if (!existing || updatedAt > (existing.updatedAt || 0)) {
            const rawData = row.world_data;
            const grid = Array.isArray(rawData)
              ? rawData
              : (rawData && Array.isArray(rawData.grid) ? rawData.grid : createBaseWorldGrid());
            const devices = rawData && Array.isArray(rawData.devices) ? rawData.devices : [];
            const three = rawData && typeof rawData.three === "object" ? rawData.three : createBaseThreeWorldData();
            const settings = rawData && typeof rawData.settings === "object"
              ? rawData.settings
              : getCreativeSettingsDefaults();
            map.set(id, {
              id,
              name: String(row.world_name || "Creative Insel"),
              createdAt: Date.parse(row.created_at || "") || Date.now(),
              updatedAt,
              published: !!row.published,
              data: grid,
              devices,
              settings,
              three
            });
          }
        }
        creativeWorlds = Array.from(map.values()).sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
        saveCreativeWorldsLocal();
      } catch (err) {
        console.warn("Creative-Welten konnten nicht aus Supabase geladen werden:", err);
      }
    }

