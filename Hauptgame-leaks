      waterGradient.addColorStop(0, "rgba(120, 210, 255, 0.38)");
      waterGradient.addColorStop(0.2, "rgba(70, 150, 220, 0.72)");
      waterGradient.addColorStop(1, "rgba(18, 50, 90, 0.9)");
      ctx.fillStyle = waterGradient;
      ctx.fillRect(0, fillStartY, canvas.width, canvas.height - fillStartY);

      ctx.fillStyle = "rgba(210, 244, 255, 0.75)";
      for (let i = 0; i < canvas.width; i += 34) {
