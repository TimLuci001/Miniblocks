    function getSupabaseAccountErrorText(error, fallbackText) {
      const code = error?.code || "";
      const message = String(error?.message || "").trim();

      if (code === "42501") {
        return "Supabase blockiert den Zugriff. In den Tabellen fehlen wahrscheinlich RLS-Policies für SELECT/INSERT/UPDATE.";
      }

      if (code === "23505") {
        return "Dieses Konto existiert schon. Bitte melde dich stattdessen an.";
      }

      if (message) {
        return `${fallbackText} Fehler: ${message}`;
      }

      return fallbackText;
    }

