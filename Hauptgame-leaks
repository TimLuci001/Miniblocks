    async function applyAdminShopRule() {
      const type = adminShopType.value;
      const id = adminShopItem.value;
      if (!id) return;

      const discount = Number(adminDiscountInput.value || 0);
      const visibleMinutes = Number(adminVisibleMinutesInput.value || 0);
      const hiddenMinutes = Number(adminHiddenMinutesInput.value || 0);

      const entry = getShopStateEntry(type, id);
      const now = Date.now();

      entry.discountPercent = Math.max(0, Math.min(90, discount));

      if (visibleMinutes > 0) {
        entry.visibleUntil = now + visibleMinutes * 60 * 1000;
      } else {
        entry.visibleUntil = 0;
      }

      if (hiddenMinutes > 0) {
        entry.hiddenUntil = now + hiddenMinutes * 60 * 1000;
      } else {
        entry.hiddenUntil = 0;
      }

      await syncShopAdminState({
        showSavedMessage: true,
        savedMessage: "Shop-Regel gespeichert!"
      });
    }

