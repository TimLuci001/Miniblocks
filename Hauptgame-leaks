    function enforceLobbyPartyLimit() {
      const allowedPartyFriendCount = getLobbyAllowedFriendCount();
      let keptPartyFriends = 0;
      lobbyFriendsState.list.forEach((entry) => {
        if (!entry.inParty) return;
        keptPartyFriends += 1;
        if (keptPartyFriends > allowedPartyFriendCount) entry.inParty = false;
      });
    }

    function getLobbyPartyFriendCount() {
      if (!Array.isArray(lobbyFriendsState.list)) return 0;
      return lobbyFriendsState.list.filter((entry) => !!entry.inParty).length;
    }

    function getLobbyPartyPlayerCount() {
      return 1 + getLobbyPartyFriendCount();
    }

    function getLobbyFriendStatus(friend, index = 0) {
      const cycle = Math.floor(Date.now() / 300000);
      const seed = Math.abs((Number(friend?.addedAt) || 0) + index * 17 + cycle);
      return LOBBY_FRIEND_STATUS_META[seed % LOBBY_FRIEND_STATUS_META.length];
    }

    function ensureLobbyFriendSelection() {
      if (!Array.isArray(lobbyFriendsState.list)) lobbyFriendsState.list = [];
      if (!lobbyFriendsState.list.length) {
        lobbyFriendsState.selectedId = "";
        return null;
      }
      const selected = lobbyFriendsState.list.find((entry) => entry.id === lobbyFriendsState.selectedId) || lobbyFriendsState.list[0];
      lobbyFriendsState.selectedId = selected.id;
      return selected;
    }

    async function syncLobbyFriendsFromSupabase(playerKey = cloudPlayerKey) {
      if (!supabaseClient || !playerKey) return false;
      const rows = await fetchCloudLobbyFriends(playerKey);
      lobbyFriendsState.list = rows
        .map((entry) => normalizeLobbyFriendEntry({
          id: entry.friend_key,
          key: entry.friend_key,
          name: entry.friend_name || entry.friend_key,
          addedAt: entry.created_at ? Date.parse(entry.created_at) : Date.now(),
          inParty: !!entry.in_party,
          source: "supabase"
        }))
        .filter((entry) => !!entry.name);
      enforceLobbyPartyLimit();
      ensureLobbyFriendSelection();
      saveGame();
      if (inLobby) renderLobbyScreen();
      renderLobbyFriendsPanel();
      return true;
    }

    async function addLobbyFriend(name) {
      const safeName = String(name || "").trim().slice(0, 20);
      if (!safeName) {
        showMessage("Gib erst einen Namen ein.");
        return;
      }
      if (lobbyFriendsState.list.some((entry) => entry.name.toLowerCase() === safeName.toLowerCase())) {
        showMessage("Der Freund ist schon in deiner Liste.");
        return;
      }

      let friendAccount = null;
      if (supabaseClient && cloudSyncEnabled) {
        try {
          friendAccount = await findAccountByFriendName(safeName);
          if (!friendAccount) {
            showMessage("Dieses Konto wurde in Supabase nicht gefunden.");
            return;
          }
          if (normalizePlayerName(friendAccount.player_key) === normalizePlayerName(cloudPlayerKey || playerName)) {
            showMessage("Du kannst dich nicht selbst zur Freundesliste hinzufügen.");
            return;
          }
          if (lobbyFriendsState.list.some((entry) => (entry.key || "").toLowerCase() === normalizePlayerName(friendAccount.player_key))) {
            showMessage("Der Freund ist schon in deiner Liste.");
            return;
          }

          const normalizedFriendKey = normalizePlayerName(friendAccount.player_key);
          if (lobbyFriendRequestState.outgoingFriends.some((entry) => entry.targetKey === normalizedFriendKey)) {
            showMessage("An dieses Konto wurde schon eine Freundesanfrage gesendet.");
            return;
          }
          if (lobbyFriendRequestState.incomingFriends.some((entry) => entry.ownerKey === normalizedFriendKey)) {
            await acceptLobbyFriendRequest(normalizedFriendKey);
            return;
          }
        } catch (err) {
          console.warn("Freund konnte nicht in Supabase gesucht werden:", err);
          showMessage("Freund konnte gerade nicht über Supabase geladen werden.");
          return;
        }
      }

      if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friendAccount?.player_key) {
        try {
          await upsertCloudSocialRequest(
            cloudPlayerKey,
            normalizePlayerName(friendAccount.player_key),
            playerName || cloudAccountName || cloudPlayerKey,
            "friend"
          );
          await syncLobbyFriendRequestsFromSupabase();
          showMessage(`Freundesanfrage an ${friendAccount.player_name || safeName} gesendet!`);
          return;
        } catch (err) {
          console.warn("Freundesanfrage konnte nicht gesendet werden:", err);
          showMessage("Freundesanfrage konnte nicht gesendet werden.");
          return;
        }
      }

      const friend = normalizeLobbyFriendEntry({
        id: friendAccount?.player_key || `friend_${Date.now().toString(36)}${Math.random().toString(36).slice(2, 6)}`,
        key: friendAccount?.player_key || safeName,
        name: friendAccount?.player_name || safeName,
        addedAt: Date.now(),
        inParty: false,
        source: friendAccount ? "supabase" : "local"
      });
      lobbyFriendsState.list.unshift(friend);
      lobbyFriendsState.selectedId = friend.id;

      if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend.key) {
        try {
          await upsertCloudLobbyFriend(cloudPlayerKey, friend);
        } catch (err) {
          console.warn("Cloud-Freund konnte nicht gespeichert werden:", err);
          showMessage("Freund lokal gespeichert, aber Supabase-Sync ist fehlgeschlagen.");
        }
      }

      saveGame();
      renderLobbyFriendsPanel();
      showMessage(`${friend.name} zur Freundesliste hinzugefuegt!`);
    }

    async function removeLobbyFriend(friendId) {
      const friend = lobbyFriendsState.list.find((entry) => entry.id === friendId);
      lobbyFriendsState.list = lobbyFriendsState.list.filter((entry) => entry.id !== friendId);
      if (lobbyFriendsState.selectedId === friendId) {
        lobbyFriendsState.selectedId = lobbyFriendsState.list[0]?.id || "";
      }

      if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend?.key) {
        try {
          await removeCloudLobbyFriend(cloudPlayerKey, friend.key);
        } catch (err) {
          console.warn("Cloud-Freund konnte nicht entfernt werden:", err);
          showMessage("Freund lokal entfernt, aber Supabase-Sync ist fehlgeschlagen.");
        }
      }

      saveGame();
      renderLobbyFriendsPanel();
      renderLobbyScreen();
      if (friend) showMessage(`${friend.name} entfernt.`);
    }

    async function toggleLobbyFriendInvite(friendId) {
      const friend = lobbyFriendsState.list.find((entry) => entry.id === friendId);
      if (!friend) return;

      if (!friend.inParty) {
        showMessage("Team-Modus ist aktuell entfernt.");
        return;
      }

      if (friend.inParty) {
        friend.inParty = false;
        if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend.key) {
          try {
            await upsertCloudLobbyFriend(cloudPlayerKey, friend);
            await upsertCloudLobbyFriend(friend.key, normalizeLobbyFriendEntry({
              id: cloudPlayerKey,
              key: cloudPlayerKey,
              name: playerName || cloudAccountName || cloudPlayerKey,
              addedAt: Date.now(),
              inParty: false,
              source: "supabase"
            }));
            await removeCloudSocialRequest(cloudPlayerKey, friend.key, "party").catch(() => {});
            await removeCloudSocialRequest(friend.key, cloudPlayerKey, "party").catch(() => {});
          } catch (err) {
            console.warn("Cloud-Partystatus konnte nicht gespeichert werden:", err);
          }
        }
        saveGame();
        renderLobbyFriendsPanel();
        renderLobbyScreen();
        showMessage(`${friend.name} aus der Gruppe entfernt.`);
        return;
      }

      if (getLobbyPartyFriendCount() >= getLobbyAllowedFriendCount()) {
        showMessage("Team-Modus ist aktuell entfernt.");
        return;
      }

      if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend.key) {
        try {
          if (lobbyFriendRequestState.outgoingParty.some((entry) => entry.targetKey === friend.key)) {
            showMessage("Team-Modus ist aktuell entfernt.");
            return;
          }
          if (lobbyFriendRequestState.incomingParty.some((entry) => entry.ownerKey === friend.key)) {
            await acceptLobbyPartyInvite(friend.key);
            return;
          }
          await upsertCloudSocialRequest(
            cloudPlayerKey,
            friend.key,
            playerName || cloudAccountName || cloudPlayerKey,
            "party"
          );
          await syncLobbyFriendRequestsFromSupabase();
          showMessage("Team-Modus ist aktuell entfernt.");
          return;
        } catch (err) {
          console.warn("Cloud-Duoeinladung konnte nicht gespeichert werden:", err);
          showMessage("Team-Modus ist aktuell entfernt.");
          return;
        }
      }
      friend.inParty = false;
      saveGame();
      renderLobbyFriendsPanel();
      renderLobbyScreen();
      showMessage("Team-Modus ist aktuell entfernt.");
    }

    function renderLobbyFriendsPanel() {
      if (!lobbyFriendsPanel) return;
