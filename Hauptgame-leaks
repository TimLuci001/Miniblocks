          return {
            id: "25",
            name: "+25 Stufen Paket",
            price: BATTLE_PASS_25_PACKAGE_PRICE,
            rarity: "legendary",
            spotlightLead: `Schaltet Premium frei und fuellt den Battle Pass direkt bis Stufe ${Math.min(BATTLE_PASS_25_PACKAGE_TIERS, battlePassRewards.length)}.`
          };
        }
      }
      if (type === "rains") return rainColors.find(item => item.id === id) || null;
      if (type === "eyes") return eyeSkins.find(item => item.id === id) || null;
      if (type === "bodies") return bodySkins.find(item => item.id === id) || null;
      if (type === "outfits") return threeDOutfits[id] || null;
      if (type === "specials") return specialSkins.find(item => item.id === id) || null;
      if (type === "consumables") return consumableItems.find(item => item.id === id) || null;
      if (type === "bundle") return shopBundles.find(item => item.id === id) || null;
      return null;
    }

    function loadNewShopState() {
      if (newShopLoaded) return;
      newShopLoaded = true;
      try {
        const raw = localStorage.getItem(NEW_SHOP_SAVE_KEY);
        if (!raw) {
          newShopOwned = [];
          return;
        }
        const data = JSON.parse(raw);
        newShopOwned = Array.isArray(data?.owned) ? data.owned.filter((id) => newShopCatalog.some((entry) => entry.id === id)) : [];
      } catch (err) {
        console.warn("New shop state could not be loaded:", err);
        newShopOwned = [];
      }
    }

    function saveNewShopState() {
      try {
        localStorage.setItem(NEW_SHOP_SAVE_KEY, JSON.stringify({ owned: newShopOwned }));
      } catch (err) {
        console.warn("New shop state could not be saved:", err);
      }
    }

    function isNewShopOwned(itemId) {
      return newShopOwned.includes(itemId);
    }

    function buyNewShopItem(itemId) {
      const item = newShopCatalog.find((entry) => entry.id === itemId);
      if (!item) return;
      if (isNewShopOwned(item.id)) {
        showMessage("Item bereits gekauft.", 1600);
        return;
      }

      const finalPrice = getDiscountedPrice(item.price, "consumables", item.id);
      const wallet = Number(inventory[7] || 0);
      if (wallet < finalPrice) {
        showMessage("Nicht genug M-Bucks.", 1800);
        return;
      }

      inventory[7] = wallet - finalPrice;
      newShopOwned.push(item.id);
      if (typeof item.onBuy === "function") {
        item.onBuy();
      }
      if (stats && typeof stats.shopPurchases === "number") {
        stats.shopPurchases += 1;
      }

      const cashback = grantCreatorCashback(finalPrice);
      saveNewShopState();
      queueDeferredSave();
      renderHud();
      renderShop();

      openShopPurchaseModal({
        lead: `${item.name} freigeschaltet`,
        reasons: ["Neuer Shop 2.0 Kauf abgeschlossen"],
        rewards: [item.description, cashback > 0 ? `Creator Cashback: +${cashback} ${CURRENCY_NAME}` : "Kein Cashback aktiv"],
        equipAction: null,
        equipLabel: "OK"
      });
    }

    function getNewShopSkinEntries() {
      const outfitEntries = Object.values(threeDOutfits || {}).filter((item) => item && !item.shopHidden).slice(0, 3).map((item) => ({ type: "outfits", item }));
      return [
        ...eyeSkins.filter((item) => item && !item.shopHidden).slice(0, 3).map((item) => ({ type: "eyes", item })),
        ...bodySkins.filter((item) => item && !item.shopHidden).slice(0, 3).map((item) => ({ type: "bodies", item })),
        ...specialSkins.filter((item) => item && !item.shopHidden).slice(0, 3).map((item) => ({ type: "specials", item })),
        ...outfitEntries
      ];
    }

    function isNewShopSkinOwned(type, id) {
      if (type === "eyes") return playerSkin.ownedEyes.includes(id);
      if (type === "bodies") return playerSkin.ownedBodies.includes(id);
      if (type === "specials") return playerSkin.ownedSpecials.includes(id);
      if (type === "outfits") return playerSkin.ownedOutfits.includes(id);
      return false;
    }

    function isNewShopSkinActive(type, id) {
      if (type === "eyes") return !playerSkin.activeSpecial && playerSkin.activeEyes === id;
      if (type === "bodies") return !playerSkin.activeSpecial && playerSkin.activeBody === id;
      if (type === "specials") return playerSkin.activeSpecial === id;
      if (type === "outfits") return activeThreeDOutfitId === id;
      return false;
    }

    function handleNewShopSkinAction(type, id) {
      if (type === "eyes") buyOrEquipEyeSkin(id);
      else if (type === "bodies") buyOrEquipBodySkin(id);
      else if (type === "specials") buyOrEquipSpecialSkin(id);
      else if (type === "outfits") buyOrEquipOutfit(id);
    }

