          progression.skillPoints += 1;
          showMessage("Upgrade: +1 Skillpunkt erhalten!", 2000);
        }}
      ];
      const picks = [];
      const used = new Set();
      while (picks.length < 3 && used.size < pool.length) {
        const idx = Math.floor(Math.random() * pool.length);
        if (used.has(idx)) continue;
        used.add(idx);
        picks.push(pool[idx]);
      }
      return picks;
    }

