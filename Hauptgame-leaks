          id: skin.id,
          name: skin.name,
          color: skin.color,
          secondaryColor: skin.secondaryColor,
          rarity: skin.rarity || "common"
        };
      }
      return {
        id: skin.id,
        name: skin.name,
        color: skin.color,
        rarity: skin.rarity || "common"
      };
