    function isSupabaseRewardActiveWindow(entry) {
      const now = Date.now();
      const payload = entry?.reward_payload && typeof entry.reward_payload === "object"
        ? entry.reward_payload
        : {};
      const startsAtRaw = entry?.starts_at || payload?.starts_at;
      const endsAtRaw = entry?.ends_at || payload?.ends_at;
      const startsAt = startsAtRaw ? Date.parse(startsAtRaw) : 0;
      const endsAt = endsAtRaw ? Date.parse(endsAtRaw) : 0;
      if (startsAt && now < startsAt) return false;
      if (endsAt && now > endsAt) return false;
      return true;
    }

    function isSupabaseRewardTargetMatch(entry, playerKey = "", playerName = "") {
      const payload = entry?.reward_payload && typeof entry.reward_payload === "object"
        ? entry.reward_payload
        : {};
      const scope = String(entry?.scope || payload?.scope || "global");
      const entryTargetKey = normalizePlayerName(entry?.target_key || payload?.target_key || "");
      const targetKey = normalizePlayerName(payload?.target_player_key || "");
      const targetName = normalizePlayerName(payload?.target_player_name || "");
      const normalizedPlayerKey = normalizePlayerName(playerKey || "");
      const normalizedPlayerName = normalizePlayerName(playerName || "");

      if (scope === "global") return true;
      const combinedTargetKey = entryTargetKey || targetKey;
      if (!combinedTargetKey && !targetName) return false;
      if (combinedTargetKey && combinedTargetKey === normalizedPlayerKey) return true;
      if (targetName && (targetName === normalizedPlayerName || targetName === normalizedPlayerKey)) return true;
      return false;
    }

    function queueSupabaseRewardModal(title, lines = [], popupText = "") {
