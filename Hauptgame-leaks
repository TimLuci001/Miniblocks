        data.mode_solo_enabled !== undefined ||
        data.mode_rift_enabled !== undefined
      );
      const hasFlatEmergencyState = data && (
        data.emergency_battle_pass !== undefined ||
        data.emergency_quests !== undefined ||
        data.emergency_creator !== undefined ||
        data.emergency_twitch !== undefined
      );
      const hasFlatLiveEventState = data && (
        data.event_xp_boost !== undefined ||
        data.event_pass_boost !== undefined ||
        data.event_community_boost !== undefined
      );
      const hasHeartsWarningState = data && (
        data.hearts_warning_active !== undefined ||
        data.hearts_warning_text !== undefined ||
        data.hearts_warning_scope !== undefined
      );

      applyModeAccessPayload(hasFlatModeState ? createFlatModeStatePayload(data) : (data?.mode_state || {}));
      applyEmergencyStatePayload(hasFlatEmergencyState ? createFlatEmergencyStatePayload(data) : (data?.emergency_state || {}));
      applyLiveEventStatePayload(hasFlatLiveEventState ? createFlatLiveEventStatePayload(data) : (data?.live_event_state || {}));
      applyHeartsWarningPayload(hasHeartsWarningState
        ? { active: data.hearts_warning_active, text: data.hearts_warning_text, scope: data.hearts_warning_scope }
        : (data?.hearts_warning_state || {}));

      if (data) {
        if (data.community_event_state) {
          const applied = applyCommunityEventPayload(data.community_event_state, { fromSync: true, showUnlockMessage: true });
          if (!applied) {
            syncCommunityEventProgress(true);
          }
        } else {
          resetCommunityEventState();
          syncCommunityEventProgress(true);
        }
      }
    }

    async function saveMaintenanceStateToSupabase(active) {
      if (!supabaseClient) return false;

      try {
        const { error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: GAME_STATE_ID,
            maintenance_active: !!active
          }, { onConflict: "id" });

        if (error) throw error;
        return true;
      } catch (err) {
        console.warn("Wartungsstatus konnte nicht nach Supabase gespeichert werden:", err);
        return false;
      }
    }

