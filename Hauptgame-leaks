    function getShopStateEntry(type, id) {
      if (!shopState[type]) {
        shopState[type] = {};
      }
      if (!shopState[type][id]) {
        shopState[type][id] = {
          discountPercent: 0,
          visibleUntil: 0,
          hiddenUntil: 0
        };
      }
      return shopState[type][id];
    }

    function isShopItemVisible(type, id) {
      const item = getShopItemByType(type, id);
      if (item?.shopHidden) return false;
      const entry = getShopStateEntry(type, id);
      const now = Date.now();

      if (entry.hiddenUntil && now < entry.hiddenUntil) return false;
      if (entry.visibleUntil && now > entry.visibleUntil) return false;

      return true;
    }

    function getDiscountedPrice(basePrice, type, id) {
      const directDiscount = getShopStateEntry(type, id).discountPercent || 0;
      const totalDiscount = Math.max(0, Math.min(90, directDiscount + globalShopDiscount + getLiveShopDiscountBonus()));
      return Math.max(0, Math.round(basePrice * (1 - totalDiscount / 100)));
    }

    function getEffectiveDiscount(type, id) {
      const directDiscount = getShopStateEntry(type, id).discountPercent || 0;
      return Math.max(0, Math.min(90, directDiscount + globalShopDiscount + getLiveShopDiscountBonus()));
    }

