    function renderBattlePassLane(label, lane, entries = battlePassRewards) {
      const claimedList = getBattlePassLaneClaimedList(lane);
      const expired = isBattlePassExpired();
      const laneIcon = lane === "premium" ? "assets/ui/battle-pass-icon-silver.png" : "assets/ui/battle-pass-icon-gold.png";
      const laneMeta = isBattlePassLaneUnlocked(lane)
        ? (lane === "premium" ? "Premium aktiv" : "Kostenlos aktiv")
