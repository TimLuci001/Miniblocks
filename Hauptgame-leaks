function formatLobbyModeCountdown(ms) {
  const totalSeconds = Math.max(0, Math.floor(ms / 1000));
  const minutes = Math.floor(totalSeconds / 60);
  const seconds = totalSeconds % 60;
  return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
}

function updateLobbyModeCountdownUi() {
  if (!lobbyModeCountdown) return;
  const phase = getSeason4LiveEventPhase();
  const now = Date.now();

  lobbyModeCountdown.classList.remove("hidden", "isLive", "isCritical");

  if (phase === "pre") {
    const remaining = Math.max(0, SEASON4_LIVE_EVENT_START_AT - now);
    lobbyModeCountdown.textContent = `Live Event startet in ${formatLobbyModeCountdown(remaining)}`;
    if (remaining <= 60000) lobbyModeCountdown.classList.add("isCritical");
    return;
  }

  if (phase === "live") {
    const remaining = Math.max(0, SEASON4_LIVE_EVENT_END_AT - now);
    lobbyModeCountdown.textContent = `Live Event endet in ${formatLobbyModeCountdown(remaining)}`;
    lobbyModeCountdown.classList.add("isLive");
    if (remaining <= 60000) lobbyModeCountdown.classList.add("isCritical");
    return;
  }

  lobbyModeCountdown.textContent = "Live Event beendet";
  lobbyModeCountdown.classList.add("isCritical");
}

