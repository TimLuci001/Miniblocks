    const SHOP_ALLOWED_FILTERS = ["all", "featured", "wishlist", "starter", "passes", "vbucks", "rain", "bundles", "looks", "crew"];

    function applyShopFilterVisibility() {
      const sectionGroups = {
        featured: [featuredSection],
        wishlist: [wishlistSection],
        starter: [starterSection],
        vbucks: [vbucksSection],
        rain: [rainSection],
        bundles: [bundlesSection],
        looks: [eyesSection, bodiesSection, specialsSection],
        crew: [crewSection],
        passes: [passesSection]
      };

      Object.values(sectionGroups).flat().forEach((el) => {
        if (el) el.classList.add("hidden");
      });

      if (shopFilter === "all") {
        Object.values(sectionGroups).flat().forEach((el) => {
          if (el) el.classList.remove("hidden");
        });
        return;
      }

      (sectionGroups[shopFilter] || []).forEach((el) => {
        if (el) el.classList.remove("hidden");
      });
    }

    function renderShopFilterPanel() {
      if (!shopFilterList) return;
      shopFilterList.querySelectorAll("[data-shop-filter]").forEach((button) => {
        const allowed = SHOP_ALLOWED_FILTERS.includes(button.dataset.shopFilter || "");
        button.classList.toggle("hidden", !allowed);
        button.classList.toggle("active", button.dataset.shopFilter === shopFilter);
      });
    }

