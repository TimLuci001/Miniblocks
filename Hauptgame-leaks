function getCreativeLockRemainingMs(now = Date.now()) {
  return Math.max(0, CREATIVE_LOCK_UNTIL - now);
}

function isCreativeLobbyLocked(now = Date.now()) {
  return CREATIVE_LOCK_ENABLED && now < CREATIVE_LOCK_UNTIL;
}

function formatCreativeLockCountdown(ms) {
  const totalSeconds = Math.max(0, Math.ceil(ms / 1000));
  const days = Math.floor(totalSeconds / 86400);
  const hours = Math.floor((totalSeconds % 86400) / 3600);
  const mins = Math.floor((totalSeconds % 3600) / 60);
  const secs = totalSeconds % 60;
  const time = `${String(hours).padStart(2, "0")}:${String(mins).padStart(2, "0")}:${String(secs).padStart(2, "0")}`;
  return days > 0 ? `${days}d ${time}` : time;
}

function getCreativeLockText() {
  if (!isCreativeLobbyLocked()) return "";
  return `Gesperrt bis ${CREATIVE_LOCK_LABEL} (${formatCreativeLockCountdown(getCreativeLockRemainingMs())})`;
}

