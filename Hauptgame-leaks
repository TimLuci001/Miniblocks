      creativeGravityValue = typeof settings.gravity === "number" ? settings.gravity : fallback.gravity;
      creativeFogValue = typeof settings.fog === "number" ? settings.fog : fallback.fog;
      creativeAmbientValue = typeof settings.ambient === "number" ? settings.ambient : fallback.ambient;
      if (settings.spawn && typeof settings.spawn.x === "number" && typeof settings.spawn.y === "number") {
