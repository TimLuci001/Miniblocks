              <div class="skillNodeDesc">${data.desc}</div>
              <div class="skillNodeMeta">${getSkillMetaText(key, value)}</div>
              <div class="skillNodeNext">${getSkillNextBonusText(key, value)}</div>
              <div class="skillNodeBar"><span style="width:${Math.min(100, value * 10)}%"></span></div>
              <button class="skillNodeAction" ${progression.skillPoints <= 0 ? "disabled" : ""}>+ Skillpunkt</button>
            `;
            card.querySelector("button").addEventListener("click", () => upgradeSkill(key));
            sectionGrid.appendChild(card);
          });

        skillSectionsColumn.appendChild(wrap);
      }
    }

    function upgradeSkill(key) {
      if (progression.skillPoints <= 0) {
        showMessage("Keine Skillpunkte!");
        return;
      }
      progression.skillPoints--;
      progression.skills[key]++;
      showMessage(`${skillData[key].name} verbessert!`);
      updateDerivedStats();
      renderSkills();
      renderXp();
      checkAchievements();
      saveGame();
    }

    function updateDerivedStats() {
      const movementSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.movement || 0);
      const survivalSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.survival || 0);
      const fortuneSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.fortune || 0);
      const builderSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.builder || 0);
      const tideSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.tide || 0);
      const diverSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.diver || 0);
      const playerTileX = Math.floor((player.x + player.w / 2) / TILE);
      const inWaterBiome = getBiomeAt(playerTileX) === "water";
      const speedBonus = equipmentState.equipped.mobility === "runner_boots" ? 0.6 : 0;
      const utilityFortuneBonus = equipmentState.equipped.utility === "lucky_charm" ? 0.06 : 0;
      const diverArmorActive = equipmentState.equipped.utility === "diver_armor";
      const waterSpeedBonus = inWaterBiome ? tideSkill * 0.25 + (diverArmorActive ? 0.3 : 0) : 0;
      const waterJumpBonus = inWaterBiome ? tideSkill * 0.35 : 0;
      const waterDefenseBonus = inWaterBiome ? diverSkill * 0.05 + (diverArmorActive ? 0.08 : 0) : 0;
      const waterFortuneBonus = inWaterBiome ? diverSkill * 0.03 : 0;
      const sandstormActive = false;
      const opModeActive = isOpModeActive();
      const weatherMovePenalty = 0;
      const weatherJumpPenalty = 0;
      const weatherResistance = survivalSkill * 0.12;
      const builderBonus = builderSkill * 0.03;
      const gauntletSpeedBonus = heroGauntletState.active ? heroGauntletState.speedBonus : 0;
      const gauntletDamageReductionBonus = heroGauntletState.active ? heroGauntletState.damageReductionBonus : 0;
      const gauntletMaxHealthBonus = heroGauntletState.active ? heroGauntletState.maxHealthBonus : 0;

      player.speed = player.baseSpeed
        + movementSkill * 0.35
        + builderBonus
        + speedBonus
        + waterSpeedBonus
        + gauntletSpeedBonus
        + (opModeActive ? 1.8 : 0)
        + (effects.speed > 0 ? 2.4 : 0)
        - weatherMovePenalty * (1 - weatherResistance);
      player.jump = player.baseJump
        - movementSkill * 0.45
        - waterJumpBonus
        - (opModeActive ? 2.2 : 0)
        - (effects.jump > 0 ? 3.5 : 0)
        + weatherJumpPenalty * (1 - weatherResistance);
      player.damageReduction = Math.min(0.82, survivalSkill * 0.08 + waterDefenseBonus + gauntletDamageReductionBonus + (opModeActive ? 0.55 : 0));
      if (selectedHero === "shadowfist") player.speed += 0.8;
      player.fortuneChance = fortuneSkill * 0.08 + utilityFortuneBonus + waterFortuneBonus;
      player.maxHealth = (opModeActive ? 10 : BASE_PLAYER_MAX_HEALTH) + gauntletMaxHealthBonus;
      if (player.health > player.maxHealth) player.health = player.maxHealth;
    }

    function getRequirementAmount(requirement) {
      if (requirement.type === "loot") return loot[requirement.id] || 0;
      if (requirement.type === "gold") return inventory[7] || 0;
      if (requirement.type === "block") return inventory[requirement.id] || 0;
      return 0;
    }

    function getRequirementLabel(requirement) {
      if (requirement.type === "loot") return lootData[requirement.id]?.name || requirement.id;
      if (requirement.type === "gold") return "M-Bucks";
      if (requirement.type === "block") return getBlockName(requirement.id);
      return requirement.id;
    }

    function canCraftRecipe(recipe) {
      return recipe.requirements.every(req => getRequirementAmount(req) >= req.amount);
    }

    function consumeRecipeRequirements(recipe) {
      for (const req of recipe.requirements) {
        if (req.type === "loot") loot[req.id] -= req.amount;
        if (req.type === "gold") inventory[7] -= req.amount;
        if (req.type === "block") inventory[req.id] -= req.amount;
      }
    }

    function spawnEliteSlimeNearPlayer() {
      const playerTileX = Math.floor((player.x + player.w / 2) / TILE);
      const eliteType = playerTileX >= BIOME_SPLIT ? "elite_desert" : (playerTileX >= JUNGLE_BIOME_START ? "elite_fire" : "elite_fire");
      createSlime(player.x + 110, player.y - 10, eliteType);
    }

    function hasCraftedRecipe(recipeId) {
      return Array.isArray(craftedState.craftedRecipeIds) && craftedState.craftedRecipeIds.includes(recipeId);
    }

    function craftRecipe(recipeId) {
      const recipe = craftingRecipes.find(entry => entry.id === recipeId);
      if (!recipe) return;
      if (recipe.oneTime && hasCraftedRecipe(recipe.id)) {
        showMessage("Dieses Rezept ist schon hergestellt!");
        return;
      }
      if (!canCraftRecipe(recipe)) {
        showMessage("Materialien fehlen!");
        return;
      }

      consumeRecipeRequirements(recipe);
      craftedState.totalCrafts = (craftedState.totalCrafts || 0) + 1;
      if (recipe.oneTime && !hasCraftedRecipe(recipe.id)) {
        craftedState.craftedRecipeIds.push(recipe.id);
      }

      if (recipe.id === "portal_key") {
        craftedState.portalKeyUnlocked = true;
        showMessage("Portal-Schlüssel hergestellt! Die Portale sind jetzt aktiv.", 2600);
      }
      if (recipe.id === "elite_bait") {
        spawnEliteSlimeNearPlayer();
        showMessage("Elite-Köder genutzt! Ein Elite-Slime ist erschienen.", 2600);
      }
      if (recipe.id === "skill_core") {
        progression.skillPoints++;
        showMessage("Kristallkern hergestellt! +1 Skillpunkt", 2200);
      }
      if (recipe.id === "jungle_totem") {
        craftedState.jungleTotemCrafted = true;
        progression.skills.survival++;
        showMessage("Jungel-Totem gebaut! Survival +1", 2400);
      }
      if (recipe.id === "ruin_blade") {
        craftedState.ruinBladeForged = true;
        currentSword = "ruinBlade";
        addXp(120);
        showMessage("Ruinenklinge geschmiedet!", 2600);
      }
      if (recipe.id === "relic_core") {
        progression.skillPoints++;
        addXp(90);
        showMessage("Reliktkern aktiviert! +1 Skillpunkt und +90 XP", 2400);
      }
      if (recipe.id === "vine_bundle") {
        inventory[21] = (inventory[21] || 0) + 8;
        inventory[20] = (inventory[20] || 0) + 6;
        showMessage("Lianen-Bündel hergestellt! +8 Lianen, +6 Ruinenstein", 2400);
      }
      if (progression.skills.crafting > 0) {
        inventory[7] += progression.skills.crafting * 3;
        addXp(progression.skills.crafting * 4);
      }

      updateSwordUnlocks();
      updateDerivedStats();
      checkAchievements();
      saveGame();
      renderCrafting();
      renderInventory();
      renderSkills();
      updateUI();
    }

    function renderCrafting() {
      if (!craftGrid) return;
      if (craftInfo) {
        const builtCount = craftedState.totalCrafts || 0;
        craftInfo.textContent = `${craftingRecipes.length} Rezepte • ${builtCount} Crafts • ${craftedState.portalKeyUnlocked ? "Portale aktiv" : "Portale gesperrt"}`;
      }

      craftGrid.innerHTML = craftingRecipes.map((recipe) => {
        const ready = canCraftRecipe(recipe);
        const done = !!(recipe.oneTime && hasCraftedRecipe(recipe.id));
        const reqMarkup = recipe.requirements.map((req) => `
          <div class="craftRequirement ${getRequirementAmount(req) >= req.amount ? "ok" : ""}">
            <span>${getRequirementLabel(req)}</span>
            <span>${getRequirementAmount(req)}/${req.amount}</span>
          </div>
        `).join("");

        return `
          <div class="craftCard ${ready ? "ready" : ""} ${done ? "done" : ""}">
            <div class="craftRewardTag">${recipe.rewardLabel}</div>
            <div class="craftRecipeName">${recipe.name}</div>
            <div class="craftRecipeText">${recipe.desc}</div>
            <div class="craftRequirementList">${reqMarkup}</div>
            <button class="achievementCloseBtn" data-craft-id="${recipe.id}" ${(done || !ready) ? "disabled" : ""}>${done ? "Schon gebaut" : "Herstellen"}</button>
          </div>
        `;
      }).join("");

      craftGrid.querySelectorAll("button[data-craft-id]").forEach((button) => {
        button.addEventListener("click", () => craftRecipe(button.dataset.craftId));
      });
    }

    function isNearPortal(portal) {
      const playerCenterX = player.x + player.w / 2;
      const playerCenterY = player.y + player.h / 2;
      const portalCenterX = portal.x + portal.w / 2;
      const portalCenterY = portal.y + portal.h / 2;
      const dx = portalCenterX - playerCenterX;
      const dy = portalCenterY - playerCenterY;
      return Math.sqrt(dx * dx + dy * dy) < 72;
    }

    function getNearbyPortalRaw() {
      return portals.find(portal => isNearPortal(portal)) || null;
    }

    function getNearbyPortal() {
      if (currentMatchMode !== "rift" && !craftedState.portalKeyUnlocked) return null;
      return getNearbyPortalRaw();
    }

    function useNearbyPortal() {
      const portal = getNearbyPortal();
      if (!portal || portalCooldown > 0) return false;
      player.x = portal.targetX;
      player.y = portal.targetY;
      player.vx = 0;
      player.vy = 0;
      portalCooldown = 90;
      showMessage(`${portal.label} aktiviert!`, 2200);
      return true;
    }

    function getMiningTime() {
      const equipmentReduction = equipmentState.equipped.utility === "miner_gloves" ? 0.12 : 0;
      const tideSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.tide || 0);
      const playerTileX = Math.floor((player.x + player.w / 2) / TILE);
      const inWaterBiome = getBiomeAt(playerTileX) === "water";
      const waterReduction = inWaterBiome ? tideSkill * 0.04 : 0;
      return Math.max(6, Math.floor(BASE_MINING_TIME * (1 - progression.skills.mining * 0.10 - equipmentReduction - waterReduction)));
    }

    function getBattlePassTierUnlocked(tier) {
      return battlePassState.xp >= Math.max(0, (tier - 1) * BATTLE_PASS_TIER_XP);
    }

    function isBattlePassExpired() {
      return isBattlePassFeatureDisabled() || (BATTLE_PASS_COUNTDOWN_ENABLED && Date.now() >= BATTLE_PASS_END_AT);
    }

    function updateBattlePassAvailability() {
      if (!passBtn) return;
      passBtn.classList.remove("hidden");
      passBtn.disabled = isBattlePassExpired();
      if (passBtnLabel) passBtnLabel.textContent = isBattlePassFeatureDisabled() ? "VERMISCHUNG AUS" : (isBattlePassExpired() ? "VERMISCHUNG Ende" : "VERMISCHUNG-Pass");
    }

    function renderBattlePassButtonCountdown() {
      if (!passBtnTimer) return;
      passBtnTimer.textContent = isBattlePassFeatureDisabled()
        ? "Von Admin gesperrt"
        : (BATTLE_PASS_COUNTDOWN_ENABLED
        ? (isBattlePassExpired() ? "Season beendet" : `Noch ${formatRemainingTimeWithDays(BATTLE_PASS_END_AT)}`)
        : "Chapter 2 • S5 VERMISCHUNG");
    }

    function renderBattlePassCountdownCard() {
      if (!passCountdownCard) return;
      const expired = isBattlePassExpired();
      passCountdownCard.classList.toggle("expired", expired);
      passCountdownCard.innerHTML = expired ? `
        <div class="passCountdownTop">
          <div class="passCountdownBadge">
            <div class="passCountdownIcon">?</div>
            <div class="passCountdownBadgeText">
              <div class="passCountdownLabel">Chapter 2</div>
              <div class="passCountdownTitle">Battle Pass eingefroren</div>
            </div>
          </div>
          <div class="passCountdownState">Beendet</div>
        </div>
        <div class="passCountdownMain">
          <div>
            <div class="passCountdownTime">Season beendet</div>
            <div class="passCountdownSubtext">Chapter 2 • S5 VERMISCHUNG ist gerade pausiert. Der 200-Stufen-Track bleibt ohne Countdown sichtbar.</div>
          </div>
          <div class="passCountdownMeta">
            <div class="passCountdownMetaItem">Status: Abgelaufen</div>
            <div class="passCountdownMetaItem">Status: Kein Countdown</div>
          </div>
        </div>
      ` : `
        <div class="passCountdownTop">
          <div class="passCountdownBadge">
            <div class="passCountdownIcon">?</div>
            <div class="passCountdownBadgeText">
              <div class="passCountdownLabel">Chapter 2</div>
              <div class="passCountdownTitle">${BATTLE_PASS_COUNTDOWN_ENABLED ? "VERMISCHUNG Countdown" : "VERMISCHUNG Status"}</div>
            </div>
          </div>
          <div class="passCountdownState">${BATTLE_PASS_COUNTDOWN_ENABLED ? "Aktiv" : "VERMISCHUNG"}</div>
        </div>
        <div class="passCountdownMain">
          <div>
            <div class="passCountdownTime">${BATTLE_PASS_COUNTDOWN_ENABLED ? formatRemainingTimeWithDays(BATTLE_PASS_END_AT) : "Kein Countdown"}</div>
            <div class="passCountdownSubtext">${
              BATTLE_PASS_COUNTDOWN_ENABLED
                ? withXpIcon(`Endet am <strong>${BATTLE_PASS_END_LABEL}</strong>. Fuer jede Stufe brauchst du <strong>${BATTLE_PASS_TIER_XP.toLocaleString("de-DE")} XP</strong>. Kostenlos und Premium laufen parallel.`)
                : withXpIcon(`Der VERMISCHUNG-Pass bleibt aktiv. Fuer jede Stufe brauchst du <strong>${BATTLE_PASS_TIER_XP.toLocaleString("de-DE")} XP</strong>. Kostenlos und Premium laufen parallel.`)
            }</div>
          </div>
          <div class="passCountdownMeta">
            <div class="passCountdownMetaItem">Status: Chapter 2 live</div>
            <div class="passCountdownMetaItem">${BATTLE_PASS_BASE_TIERS} Hauptstufen</div>
          </div>
        </div>
      `;
    }

    function buildComingSoonCardMarkup() {
      const expired = BATTLE_PASS_COUNTDOWN_ENABLED && Date.now() >= BATTLE_PASS_END_AT;
      const timerText = BATTLE_PASS_COUNTDOWN_ENABLED
        ? (expired ? "Nicht verfuegbar" : `? ${formatRemainingTimeWithDays(BATTLE_PASS_END_AT)}`)
        : "Kein Countdown";
      return `
        <div class="comingSoonCard">
          <div>
            <div class="comingSoonText">COMING SOON...</div>
            <div class="comingSoonTimer" data-coming-soon-countdown>${timerText}</div>
            <div class="comingSoonMeta">${BATTLE_PASS_COUNTDOWN_ENABLED ? `Endet am ${BATTLE_PASS_END_LABEL}` : "Release-Datum folgt"}</div>
          </div>
        </div>
      `;
    }

    function buildShopPlaceholderCard(options = {}) {
      const title = options.title || "Inhalt unbekannt";
      const message = options.message || SHOP_PLACEHOLDER_MESSAGE;
      const note = options.note ? `<div class="comingSoonMeta">${options.note}</div>` : "";
      return `
        <div class="comingSoonCard">
          <div>
            <div class="comingSoonText">${title}</div>
            <div class="comingSoonTimer">${message}</div>
            ${note}
          </div>
        </div>
      `;
    }

    function updateComingSoonCountdowns() {
      document.querySelectorAll("[data-coming-soon-countdown]").forEach((el) => {
        if (!BATTLE_PASS_COUNTDOWN_ENABLED) {
          el.textContent = "Kein Countdown";
          return;
        }
        const expired = Date.now() >= BATTLE_PASS_END_AT;
        el.textContent = expired ? "Nicht verfuegbar" : `? ${formatRemainingTimeWithDays(BATTLE_PASS_END_AT)}`;
      });
    }

    function getBattlePassCurrentTier() {
      return Math.min(battlePassRewards.length, Math.floor(battlePassState.xp / BATTLE_PASS_TIER_XP) + 1);
    }

    function getMiniPassUnlockedTierCount() {
      return Math.min(miniPassRewards.length, Math.floor(miniPassState.eggsCollected / MINI_PASS_EGGS_PER_TIER));
    }

    function getCommunityPassMilestones() {
      return [
        { percent: 25, reward: { type: "currency", amount: 1800, label: "+1.800 M-Bucks" } },
        { percent: 50, reward: { type: "currency", amount: 2200, label: "+2.200 M-Bucks" } },
        { percent: 75, reward: { type: "currency", amount: 2800, label: "+2.800 M-Bucks" } },
        { percent: 100, reward: { type: "combo", currency: 7777, skinId: "blitz", label: "Blitz Skin + 7.777 M-Bucks" } }
      ];
    }

    function claimCommunityPassReward(percent) {
      const milestone = getCommunityPassMilestones().find((entry) => entry.percent === percent);
      if (!milestone) return;
      const progress = getCommunityEventProgress();

      if (communityPassState.claimedMilestones.includes(percent)) {
        showMessage("Diese Community-Pass-Belohnung wurde schon abgeholt!", 2200);
        return;
      }
      if (progress < percent) {
        showMessage(`Die Community muss erst ${percent}% erreichen!`, 2200);
        return;
      }

      if (milestone.reward.type === "gold" || milestone.reward.type === "currency") {
        inventory[7] += milestone.reward.amount;
      }
      if (milestone.reward.type === "combo") {
        inventory[7] += milestone.reward.currency;
        if (!playerSkin.ownedSpecials.includes(milestone.reward.skinId)) {
          playerSkin.ownedSpecials.push(milestone.reward.skinId);
          ensureSkinStored("specials", milestone.reward.skinId);
        }
      }

      communityPassState.claimedMilestones.push(percent);
      renderBattlePass();
      renderShop();
      renderLocker();
      updateUI();
      saveGame();
      showMessage(percent === 100 ? "Community Pass komplett! Blitz Skin und 9.999 M-Bucks erhalten!" : `Community Pass: ${milestone.reward.label} erhalten!`, 2600);
    }

    function getNudelPassUnlockedTierCount() {
      return nudelPassRewards.length;
    }

    function isNudelPassTierUnlocked(tier) {
      return getNudelPassUnlockedTierCount() >= tier;
    }


    function isMiniPassTierUnlocked(tier) {
      return getMiniPassUnlockedTierCount() >= tier;
    }

    function isMiniPassExpired() {
      return MINI_PASS_DISABLED || Date.now() >= MINI_PASS_END_AT;
    }

    function grantBattlePassReward(reward) {
      if (!reward) return;

      if (reward.type === "gold" || reward.type === "currency") inventory[7] += reward.amount;
      if (reward.type === "xp") addXp(reward.amount);
      if (reward.type === "skillPoints") progression.skillPoints += reward.amount;
      if (reward.type === "loot") loot[reward.id] = (loot[reward.id] || 0) + reward.amount;
      if (reward.type === "eyeSkin" && !playerSkin.ownedEyes.includes(reward.id)) {
        playerSkin.ownedEyes.push(reward.id);
        ensureSkinStored("eyes", reward.id);
      }
      if (reward.type === "bodySkin" && !playerSkin.ownedBodies.includes(reward.id)) {
        playerSkin.ownedBodies.push(reward.id);
        ensureSkinStored("bodies", reward.id);
      }
      if (reward.type === "specialSkin" && !playerSkin.ownedSpecials.includes(reward.id)) {
        playerSkin.ownedSpecials.push(reward.id);
        ensureSkinStored("specials", reward.id);
      }
      if (reward.type === "rainColor" && !playerSkin.ownedRains.includes(reward.id)) {
        playerSkin.ownedRains.push(reward.id);
        ensureSkinStored("rains", reward.id);
      }
    }

    function renderPassRewardContent(reward) {
      if (!reward) return "";
      if (reward.type === "currency") {
        return `<span class="currencyInline"><img class="currencyIcon" src="${CURRENCY_ICON_PATH}" alt="${CURRENCY_NAME}">+${Number(reward.amount || 0).toLocaleString("de-DE")} ${CURRENCY_NAME}</span>`;
      }
      if (reward.type === "combo") {
        return `Blitz Skin + <span class="currencyInline"><img class="currencyIcon" src="${CURRENCY_ICON_PATH}" alt="${CURRENCY_NAME}">${Number(reward.currency || 0).toLocaleString("de-DE")} ${CURRENCY_NAME}</span>`;
      }
      return reward.label || "";
    }

    function getPassRewardRarity(reward, opts = {}) {
      if (!reward) return "common";
      if (reward.rarity) return String(reward.rarity).toLowerCase();
      if (Number.isFinite(opts.percent)) {
        const pct = opts.percent;
        if (pct >= 100) return "legendary";
        if (pct >= 75) return "epic";
        if (pct >= 50) return "rare";
        return "common";
      }
      if (Number.isFinite(opts.tier)) {
        const tier = opts.tier;
        if (tier >= 80) return "legendary";
        if (tier >= 50) return "epic";
        if (tier >= 20) return "rare";
      }
      if (reward.type === "specialSkin") return "legendary";
      if (reward.type === "rainColor") return "epic";
      if (reward.type === "combo") return "epic";
      if (reward.type === "currency") {
        const amount = Number(reward.amount || reward.currency || 0);
        if (amount >= 1000) return "legendary";
        if (amount >= 500) return "epic";
        if (amount >= 200) return "rare";
        return "common";
      }
      if (reward.type === "xp" || reward.type === "skill") return "rare";
      return "common";
    }

    function renderPassRewardPreview(reward) {
      if (!reward) return "";
      if (reward.type === "specialSkin") {
        const skin = getSpecialSkinData(reward.id);
        if (!skin) return "";
        return `
          <div class="passRewardPreview" style="--pass-preview-body:${skin.bodyColor}; --pass-preview-eye:${skin.eyeColor};">
            <div class="passRewardPreviewAura" style="background:${getAuraColorForSpecial(reward.id) || "rgba(255,255,255,0.18)"};"></div>
            <div class="passRewardPreviewAvatar">
              <div class="passRewardPreviewHead"></div>
              <div class="passRewardPreviewEye left"></div>
              <div class="passRewardPreviewEye right"></div>
              <div class="passRewardPreviewBody"></div>
            </div>
          </div>
        `;
      }
      if (reward.type === "rainColor") {
        const rain = getRainColorData(reward.id);
        if (!rain) return "";
        return `
          <div class="passRewardPreview rain">
            <div class="passRewardPreviewGlow" style="background:${rain.secondaryColor || rain.color};"></div>
            <div class="passRewardPreviewDrop one" style="background:${rain.color};"></div>
            <div class="passRewardPreviewDrop two" style="background:${rain.color};"></div>
            <div class="passRewardPreviewDrop three" style="background:${rain.secondaryColor || rain.color};"></div>
          </div>
        `;
      }
      return "";
    }

    function claimMiniPassReward(tier) {
      const entry = miniPassRewards.find(item => item.tier === tier);
      if (!entry) return;
      if (isMiniPassExpired()) {
        showMessage("Der Oster-Pass ist abgelaufen!");
        return;
      }
      if (!isMiniPassTierUnlocked(tier)) {
        showMessage("Du brauchst mehr Ostereier!");
        return;
      }
      if (miniPassState.claimedTiers.includes(tier)) {
        showMessage("Belohnung schon abgeholt!");
        return;
      }

      grantBattlePassReward(entry.reward);
      miniPassState.claimedTiers.push(tier);
      renderBattlePass();
      renderInventory();
      renderShop();
      renderSkills();
      updateUI();
