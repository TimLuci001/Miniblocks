        slot.style.setProperty("--slot-glow", toRgba(baseColor, 0.35));
        slot.style.setProperty("--slot-border", toRgba(baseColor, 0.55));
        const labelClass = BLOCKS[id].name.length > 10 ? "slotLabel isUltra"
          : (BLOCKS[id].name.length > 7 ? "slotLabel isLong" : "slotLabel");
