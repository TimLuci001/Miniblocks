    function playerIntersectsTile(tx, ty) {
      const tileX = tx * TILE;
      const tileY = ty * TILE;
      return !(
        player.x + player.w <= tileX ||
        player.x >= tileX + TILE ||
        player.y + player.h <= tileY ||
        player.y >= tileY + TILE
      );
    }

    function canReach(tx, ty) {
      const playerCenterX = player.x + player.w / 2;
      const playerCenterY = player.y + player.h / 2;
      const tileCenterX = tx * TILE + TILE / 2;
      const tileCenterY = ty * TILE + TILE / 2;
      const dx = tileCenterX - playerCenterX;
      const dy = tileCenterY - playerCenterY;
      return Math.sqrt(dx * dx + dy * dy) < 150;
    }

