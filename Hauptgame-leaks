    function renderLocker() {
      if (!lockerContent) return;

      ensureOwnedSkinsStored();
      const activeSpecialName = playerSkin.activeSpecial ? (getSpecialSkinData(playerSkin.activeSpecial)?.name || "Spezial") : "Kein Spezial-Skin";
