<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mini Mineblock V2</title>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Bangers&family=Sora:wght@400;600;700&display=swap");
    body {
      margin: 0;
      overflow: hidden;
      background: #87ceeb;
      font-family: "Sora", sans-serif;
    }

    canvas {
      display: block;
      background: linear-gradient(#87ceeb, #d7f2ff);
    }

    .hidden {
      display: none !important;
    }

    .hudRack {
      position: fixed;
      top: 10px;
      left: 12px;
      right: 12px;
      z-index: 80;
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: start;
      gap: 12px;
      pointer-events: none;
    }

    .hudRack > * {
      pointer-events: none;
    }

    .hudRack .hudRight,
    .hudRack .topMenuDock,
    .hudRack .topMenuDock *,
    .hudRack .returnLobbyBtn,
    .hudRack .hudCombo {
      pointer-events: auto;
    }

    .hudCombo {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(12, 18, 28, 0.82), rgba(8, 12, 20, 0.78));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 16px 34px rgba(0,0,0,0.3);
      backdrop-filter: blur(10px);
      max-width: min(360px, calc(100vw - 160px));
      opacity: 0.92;
    }

    .hudRight {
      display: grid;
      justify-items: end;
      align-items: start;
      gap: 10px;
    }

    .heartsHud,
    .xpHud {
      padding: 8px 10px;
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(28, 38, 56, 0.82), rgba(12, 18, 30, 0.82));
      border: 1px solid rgba(180, 219, 255, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05);
      color: white;
      user-select: none;
    }

    .heartsHud {
      display: grid;
      gap: 6px;
      min-width: 0;
    }

    .hudTitle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(226, 238, 255, 0.82);
    }

    .heartsRow {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .heartChip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 10px;
      font-size: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .heartChip.full {
      background:
        radial-gradient(circle at top, rgba(255, 190, 205, 0.28), transparent 58%),
        linear-gradient(180deg, rgba(255, 100, 132, 0.34), rgba(120, 20, 44, 0.2));
      border-color: rgba(255, 157, 180, 0.38);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 8px 18px rgba(255, 73, 120, 0.18);
    }

    .heartChip.empty {
      opacity: 0.72;
      color: rgba(232, 238, 246, 0.68);
    }

    .heartsMeta {
      color: rgba(230, 239, 248, 0.9);
      font-size: 12px;
      font-weight: 700;
    }

    .heartsExtra {
      margin-top: 2px;
      padding: 6px 8px;
      border-radius: 12px;
      border: 1px solid rgba(255, 185, 129, 0.22);
      background:
        radial-gradient(circle at top right, rgba(255, 199, 120, 0.16), transparent 28%),
        linear-gradient(180deg, rgba(73, 32, 19, 0.82), rgba(33, 16, 12, 0.9));
      color: #fff1e2;
      display: grid;
      gap: 4px;
    }

    .heartsExtraTitle {
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 221, 192, 0.78);
    }

    .heartsExtraValue {
      font-size: 16px;
      font-weight: 1000;
      color: #fff8ef;
    }

    .heartsExtraMeta {
      font-size: 11px;
      line-height: 1.45;
      color: rgba(255, 235, 220, 0.82);
    }

    .heartsWarning {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 8px;
      border-radius: 12px;
      background: rgba(255, 193, 93, 0.12);
      border: 1px solid rgba(255, 193, 93, 0.45);
      color: #fff6db;
      font-size: 11px;
      font-weight: 700;
    }

    .heartsWarning .warningIcon {
      font-size: 14px;
      line-height: 1;
    }

    .lobbyHeartsWarning {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background:
        radial-gradient(circle at top left, rgba(255, 214, 140, 0.22), transparent 55%),
        linear-gradient(180deg, rgba(73, 32, 19, 0.86), rgba(33, 16, 12, 0.92));
      border: 1px solid rgba(255, 193, 93, 0.55);
      color: #fff6db;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.5;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow:
        0 14px 28px rgba(0,0,0,0.35),
        inset 0 1px 0 rgba(255,255,255,0.08),
        0 0 18px rgba(255, 176, 86, 0.18);
      animation: lobbyWarnFlicker 2.6s ease-in-out infinite;
    }

    .lobbyHeartsWarning .warningIcon {
      font-size: 14px;
      line-height: 1;
      width: 24px;
      height: 24px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      background: rgba(255, 171, 77, 0.24);
      border: 1px solid rgba(255, 193, 93, 0.65);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.18),
        0 6px 12px rgba(255, 166, 70, 0.28);
      animation: lobbyWarnIconPulse 1.4s ease-in-out infinite;
    }

    .lobbyHeartsWarning::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #ffb24f;
      box-shadow: 0 0 10px rgba(255, 176, 86, 0.8);
      animation: lobbyWarnPulse 1.8s ease-in-out infinite;
    }

    @keyframes lobbyWarnPulse {
      0% { transform: scale(0.9); opacity: 0.65; }
      50% { transform: scale(1.12); opacity: 1; }
      100% { transform: scale(0.9); opacity: 0.65; }
    }

    @keyframes lobbyWarnIconPulse {
      0% { transform: scale(0.98); filter: brightness(1); }
      50% { transform: scale(1.06); filter: brightness(1.1); }
      100% { transform: scale(0.98); filter: brightness(1); }
    }

    @keyframes lobbyWarnFlicker {
      0% { box-shadow: 0 14px 28px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08), 0 0 14px rgba(255, 176, 86, 0.14); }
      45% { box-shadow: 0 16px 32px rgba(0,0,0,0.38), inset 0 1px 0 rgba(255,255,255,0.1), 0 0 22px rgba(255, 176, 86, 0.26); }
      100% { box-shadow: 0 14px 28px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08), 0 0 14px rgba(255, 176, 86, 0.14); }
    }

    .adminHeartsWarningPreview {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(255, 193, 93, 0.12);
      border: 1px solid rgba(255, 193, 93, 0.45);
      color: #fff6db;
      font-size: 12px;
      font-weight: 700;
    }

    .xpHud {
      min-width: 0;
      width: 100%;
      max-width: 300px;
      display: grid;
      gap: 6px;
    }

    .xpTop {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .xpLevelBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 78px;
      padding: 6px 10px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(162, 255, 100, 0.95), rgba(255, 226, 91, 0.92));
      color: #253000;
      font-size: 12px;
      font-weight: 900;
      box-shadow: 0 10px 22px rgba(171, 255, 88, 0.18);
    }

    .xpPassBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 88px;
      padding: 6px 10px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255, 214, 104, 0.95), rgba(255, 143, 67, 0.92));
      color: #4f2100;
      font-size: 12px;
      font-weight: 900;
      box-shadow: 0 10px 22px rgba(255, 180, 77, 0.18);
    }

    .xpText {
      color: #f7fbff;
      font-size: 12px;
      font-weight: 800;
      line-height: 1.45;
    }

    .xpInlineIcon {
      display: inline-block;
      width: 16px;
      height: 16px;
      margin: 0 4px;
      vertical-align: -3px;
      background: url("assets/ui/xpicon.png") center/contain no-repeat;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.25));
    }

    .xpBarWrap {
      width: 100%;
      max-width: 240px;
      height: 9px;
      padding: 2px;
      border-radius: 999px;
      background: rgba(255,255,255,0.09);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow: inset 0 2px 10px rgba(0,0,0,0.2);
    }

    .xpBarWrap.xpWithIcon {
      position: relative;
      padding-left: 22px;
    }

    .xpBarWrap.xpWithIcon::before {
      content: "";
      position: absolute;
      left: 5px;
      top: 50%;
      transform: translateY(-50%);
      width: 14px;
      height: 14px;
      border-radius: 5px;
      background: url("assets/ui/xpicon.png") center/contain no-repeat;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.25));
    }

    .boostIcon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      margin-right: 6px;
      border-radius: 7px;
      background: rgba(120, 255, 170, 0.2);
      border: 1px solid rgba(140, 255, 190, 0.5);
    }

    .boostIcon.boostXp {
      background:
        url("assets/ui/xpboost.png") center/contain no-repeat,
        rgba(120, 255, 170, 0.2);
    }

    .xpBar {
      width: 0%;
      height: 100%;
      max-width: 100%;
      border-radius: inherit;
      background:
        linear-gradient(90deg, #7dff4d 0%, #c9ff53 42%, #ffe76d 100%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.28);
    }

    .helpBtn,
    .adminBtn,
    .achBtn,
    .craftBtn,
    .creatorBtn,
    .shopBtn,
    .skillBtn,
    .passBtn,
    .communityEventBtn,
    .lockerBtn,
    .loreBtn,
    .moreBtn {
      position: static;
      z-index: 50;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 58px;
      padding: 12px 20px;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(42, 65, 97, 0.94), rgba(20, 30, 47, 0.96));
      color: #f8fbff;
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.02em;
      cursor: pointer;
      text-shadow: none;
      backdrop-filter: blur(14px);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.1);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease, border-color 0.18s ease;
    }

    .menuBadge {
      margin-left: 8px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(87, 173, 255, 0.95);
      color: #0c1a2c;
      border: 1px solid rgba(255,255,255,0.6);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.25),
        0 6px 12px rgba(0,0,0,0.18);
      line-height: 1;
    }

    .communityEventBtn {
      flex-direction: column;
      gap: 2px;
      min-width: 150px;
      padding: 10px 18px;
      border-color: rgba(120, 255, 210, 0.45);
      background:
        linear-gradient(135deg, rgba(40, 110, 90, 0.85), rgba(20, 45, 40, 0.95));
      box-shadow:
        0 16px 32px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 0 18px rgba(120, 255, 210, 0.18);
    }

    .communityEventLabel {
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .communityEventSub {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      opacity: 0.75;
    }

    .topMenuDock {
      position: relative;
      z-index: 80;
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 10px;
      width: fit-content;
      max-width: 100%;
      pointer-events: auto;
    }

    .topMenuDock > * {
      pointer-events: auto;
    }

    .lobbyBoostBar {
      position: fixed;
      top: 92px;
      left: 50%;
      transform: translateX(-50%);
      display: none;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: min(920px, calc(100vw - 32px));
      padding: 12px 18px;
      border-radius: 18px;
      border: 1px solid rgba(255, 235, 189, 0.22);
      background: linear-gradient(135deg, rgba(30, 49, 27, 0.9), rgba(16, 26, 21, 0.92));
      box-shadow: 0 16px 34px rgba(0,0,0,0.24);
      color: #fff6da;
      text-align: center;
      z-index: 79;
    }

    .lobbyBoostBar.active {
      display: flex;
    }

    .lobbyBoostBar strong {
      flex: 0 0 auto;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #7ef6aa;
    }

    .lobbyBoostBar span {
      font-size: 15px;
      font-weight: 800;
      color: #fff8e7;
    }

    .topMenuDock .passBtn {
      min-width: 220px;
    }

    .topMenuPrimary {
      display: grid;
      justify-items: center;
      width: 100%;
    }

    .topMenuFrame {
      width: min(1320px, 100%);
      padding: 12px 14px;
      border-radius: 999px;
      border: 1px solid rgba(117, 178, 255, 0.28);
      background:
        radial-gradient(circle at top right, rgba(76, 162, 255, 0.16), transparent 46%),
        linear-gradient(180deg, rgba(6, 19, 40, 0.96), rgba(4, 12, 28, 0.97));
      box-shadow:
        0 26px 48px rgba(0,0,0,0.35),
        inset 0 1px 0 rgba(193, 224, 255, 0.16),
        inset 0 0 0 1px rgba(13, 31, 56, 0.9);
      display: grid;
      gap: 10px;
    }

    .topMenuLane {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,0.18);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.04)),
        linear-gradient(135deg, rgba(61, 46, 27, 0.86), rgba(30, 22, 13, 0.9));
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 12px 26px rgba(0,0,0,0.28);
    }

    .topMenuLaneCore {
      width: fit-content;
      margin-inline: auto;
    }

    .topMenuLaneMeta {
      justify-content: center;
    }

    .topMenuTag {
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(255,255,255,0.16);
      border: 1px solid rgba(255,255,255,0.24);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(235, 242, 255, 0.9);
    }

    .topMenuTag.core {
      background: rgba(77, 168, 255, 0.2);
      border-color: rgba(155, 214, 255, 0.35);
    }

    .topMenuTag.progress {
      background: rgba(107, 255, 168, 0.18);
      border-color: rgba(168, 255, 206, 0.35);
    }

    .topMenuTag.universe {
      background: rgba(255, 165, 128, 0.2);
      border-color: rgba(255, 213, 191, 0.35);
    }

    .topMenuLane .helpBtn,
    .topMenuLane .lockerBtn,
    .topMenuLane .shopBtn,
    .topMenuLane .passBtn,
    .topMenuLane .skillBtn,
    .topMenuLane .roadmapBtn,
    .topMenuLane .blogBtn,
    .topMenuLane .loreBtn,
    .topMenuLane .creatorBtn,
    .topMenuLane .moreBtn {
      min-height: 56px;
      padding: 10px 20px;
      border-radius: 999px;
      box-shadow:
        0 14px 24px rgba(0,0,0,0.26),
        inset 0 1px 0 rgba(255,255,255,0.1);
    }

    .topMenuMoreWrap {
      position: relative;
      display: flex;
      justify-content: center;
    }

    .moreBtn {
      min-width: 108px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(111, 123, 148, 0.96), rgba(63, 73, 96, 0.96));
      border-color: rgba(226, 234, 244, 0.28);
    }

    .topMenuMorePanel {
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      display: grid;
      gap: 10px;
      min-width: 220px;
      max-height: min(72vh, 460px);
      padding: 14px;
      border-radius: 22px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.1), transparent 38%),
        linear-gradient(180deg, rgba(22, 30, 45, 0.98), rgba(12, 18, 28, 0.98));
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow:
        0 24px 44px rgba(0,0,0,0.32),
        inset 0 1px 0 rgba(255,255,255,0.08);
      backdrop-filter: blur(14px);
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-width: thin;
      scrollbar-color: rgba(163, 196, 255, 0.65) rgba(255,255,255,0.08);
    }

    .topMenuMorePanel::-webkit-scrollbar {
      width: 10px;
    }

    .topMenuMorePanel::-webkit-scrollbar-track {
      background: rgba(255,255,255,0.06);
      border-radius: 999px;
    }

    .topMenuMorePanel::-webkit-scrollbar-thumb {
      background: linear-gradient(180deg, rgba(160, 200, 255, 0.85), rgba(105, 150, 220, 0.82));
      border-radius: 999px;
      border: 2px solid rgba(14, 20, 34, 0.7);
    }

    .topMenuMorePanel.hidden {
      display: none;
    }

    .topMenuMorePanel button {
      width: 100%;
      justify-content: center;
    }

    .helpBtn:hover,
    .adminBtn:hover,
    .achBtn:hover,
    .craftBtn:hover,
    .creatorBtn:hover,
    .shopBtn:hover,
    .blogBtn:hover,
    .skillBtn:hover,
    .passBtn:hover,
    .lockerBtn:hover,
    .moreBtn:hover,
    .achievementCloseBtn:hover,
    .shopActionBtn:hover,
    .skillActionBtn:hover {
      transform: translateY(-2px);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.1);
      filter: brightness(1.05);
    }

    .helpBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(83, 159, 255, 0.96), rgba(34, 82, 164, 0.94));
      border-color: rgba(203, 229, 255, 0.42);
    }
    .shopBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(80, 173, 125, 0.95), rgba(33, 94, 72, 0.95));
      border-color: rgba(190, 255, 218, 0.28);
    }

    .blogBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(90, 150, 255, 0.95), rgba(35, 70, 160, 0.95));
      border-color: rgba(190, 215, 255, 0.35);
    }
    .craftBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(255, 151, 82, 0.95), rgba(129, 66, 24, 0.95));
      border-color: rgba(255, 219, 188, 0.3);
    }
    .creatorBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(255, 116, 170, 0.95), rgba(143, 45, 102, 0.95));
      border-color: rgba(255, 214, 232, 0.3);
    }
    .loreBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(120, 170, 255, 0.95), rgba(58, 86, 168, 0.95));
      border-color: rgba(196, 216, 255, 0.34);
      color: #f1f6ff;
    }
    .skillBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(129, 109, 255, 0.95), rgba(66, 54, 142, 0.95));
      border-color: rgba(214, 206, 255, 0.3);
    }
    .roadmapBtn {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(120, 230, 180, 0.95), rgba(46, 140, 118, 0.95));
      border-color: rgba(172, 255, 215, 0.3);
      color: #effff8;
    }
