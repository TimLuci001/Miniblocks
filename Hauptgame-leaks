    function handleShopContentClick(event) {
      const passBtn = event.target.closest("[data-pass-offer]");
      if (passBtn) {
        event.preventDefault();
        event.stopPropagation();
        openPassPurchaseModal(passBtn.dataset.passOffer || "riss_plus1", "shop");
        return;
      }

      const skinActionBtn = event.target.closest("[data-new-skin-action]");
      if (skinActionBtn) {
        event.preventDefault();
        event.stopPropagation();
        const [type, id] = (skinActionBtn.dataset.newSkinAction || "").split(":");
        if (type && id) handleNewShopSkinAction(type, id);
        renderShop();
        return;
      }

      const skinCard = event.target.closest("[data-new-skin-type]");
      if (skinCard) {
        const type = skinCard.dataset.newSkinType || "";
        const id = skinCard.dataset.newSkinId || "";
        if (type && id) {
          newShopPreviewSelection = { type, id };
          renderNewShopSkinGrid();
          renderNewShopPreviewPanel();
        }
        return;
      }

      const buyBtn = event.target.closest("[data-new-shop-buy]");
      if (!buyBtn) return;
      event.preventDefault();
      event.stopPropagation();
      buyNewShopItem(buyBtn.dataset.newShopBuy || "");
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && ytBgDialog && !ytBgDialog.classList.contains("hidden")) {
        closeYoutubeLobbyBgDialog();
        return;
      }
      const key = e.key.toLowerCase();
      keys[key] = true;

      if (/^[1-9]$/.test(e.key)) {
        const index = Number(e.key) - 1;
        const nextBlock = hotbarSlots[index];
        if (nextBlock) selectedBlock = nextBlock;
        renderHotbar();
      }

      const potionKeys = { q: 0, e: 1, r: 2, f: 3 };
      if (potionKeys[key] !== undefined) {
