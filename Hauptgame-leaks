    function clampAuthRisk(value) {
      return Math.max(0, Math.min(100, Number(value) || 0));
    }

    function setAuthShieldUi(state = "ok", detail = "") {
      if (!captchaStatus || !captchaMeterFill || !captchaDetail) return;
      captchaStatus.classList.remove("ok", "warn", "risk");
      const riskScore = clampAuthRisk(authShieldState.riskScore);
      captchaMeterFill.style.width = `${riskScore}%`;

      if (state === "risk") {
        captchaStatus.classList.add("risk");
        captchaStatus.textContent = "Pruefung";
      } else if (state === "warn") {
        captchaStatus.classList.add("warn");
        captchaStatus.textContent = "Erhoeht";
      } else {
        captchaStatus.classList.add("ok");
        captchaStatus.textContent = "Bereit";
      }

      captchaDetail.textContent = detail || "Hintergrundpruefung aktiv. Bei auffaelligem Verhalten wird eine Zusatzbestaetigung noetig.";
    }

    function clearAuthLockTimer() {
      if (authShieldState.lockTimer) clearInterval(authShieldState.lockTimer);
      authShieldState.lockTimer = null;
    }

    function startAuthLockCountdown() {
      if (!captchaDetail) return;
      clearAuthLockTimer();
      authShieldState.lockTimer = setInterval(() => {
        const remainingMs = authShieldState.lockedUntil - Date.now();
        if (remainingMs <= 0) {
          clearAuthLockTimer();
          authShieldState.lockedUntil = 0;
          authShieldState.riskScore = clampAuthRisk(authShieldState.riskScore - 20);
          setAuthShieldUi("ok", "Pruefung abgeschlossen. Du kannst es erneut versuchen.");
          if (captchaVerifyBtn) captchaVerifyBtn.classList.add("hidden");
          return;
        }
        const remainingSeconds = Math.ceil(remainingMs / 1000);
        setAuthShieldUi("risk", `Kurz gesperrt (${remainingSeconds}s). Bitte kurz warten und dann erneut anmelden.`);
      }, 1000);
    }

    function scoreAuthRisk(action, name, pin) {
      const now = Date.now();
      const dwellMs = now - authShieldState.sessionStartedAt;
      authShieldState.rapidAttempts = authShieldState.rapidAttempts.filter((at) => now - at < 90000);
      authShieldState.rapidAttempts.push(now);

      let riskIncrease = 0;
      if (dwellMs < 1400) riskIncrease += 45;
      else if (dwellMs < 2600) riskIncrease += 22;
      if (authShieldState.rapidAttempts.length >= 3) riskIncrease += 24;
      if (!name || name.length < 3) riskIncrease += 14;
      if (!pin || pin.length < 4) riskIncrease += 16;
      if (accountTrapInput && accountTrapInput.value.trim()) riskIncrease += 80;
      if (action === "login") riskIncrease += 5;
      if (authShieldState.manualVerified) riskIncrease -= 34;

      authShieldState.riskScore = clampAuthRisk(authShieldState.riskScore + riskIncrease);
      authShieldState.riskScore = clampAuthRisk(authShieldState.riskScore - 4);
    }

    function runInvisibleCaptchaCheck(action, name, pin) {
      const now = Date.now();
      if (authShieldState.lockedUntil > now) {
        const remainingSeconds = Math.ceil((authShieldState.lockedUntil - now) / 1000);
        setAuthShieldUi("risk", `Bitte ${remainingSeconds}s warten. Danach kannst du den ${action === "login" ? "Login" : "Konto-Start"} wiederholen.`);
        return { ok: false, reason: `Sicherheitswartezeit aktiv (${remainingSeconds}s).` };
      }

      scoreAuthRisk(action, name, pin);
      if (authShieldState.riskScore >= 82) {
        authShieldState.lockedUntil = Date.now() + 30000;
        authShieldState.manualVerified = false;
        if (captchaVerifyBtn) captchaVerifyBtn.classList.remove("hidden");
        startAuthLockCountdown();
        return { ok: false, reason: "Zu viele schnelle oder ungewoehnliche Versuche erkannt. Bitte bestaetige 'Ich bin ein Mensch' und warte kurz." };
      }

      if (authShieldState.riskScore >= 55 && !authShieldState.manualVerified) {
        if (captchaVerifyBtn) captchaVerifyBtn.classList.remove("hidden");
        setAuthShieldUi("warn", "Kurze Zusatzbestaetigung erforderlich: Bitte auf 'Ich bin ein Mensch' klicken.");
        return { ok: false, reason: "Invisible-CAPTCHA braucht eine kurze Zusatzbestaetigung." };
      }

      if (captchaVerifyBtn && authShieldState.riskScore < 55) {
        captchaVerifyBtn.classList.add("hidden");
      }
      if (authShieldState.manualVerified) {
        authShieldState.riskScore = clampAuthRisk(authShieldState.riskScore - 14);
      }

      if (authShieldState.riskScore >= 45) {
        setAuthShieldUi("warn", "Pruefung okay, aber erhoehtes Risiko erkannt. Bitte normal weitermachen.");
      } else {
        setAuthShieldUi("ok", "Pruefung erfolgreich. Du kannst normal anmelden oder registrieren.");
      }
      return { ok: true };
    }

    function handleManualCaptchaVerify() {
      authShieldState.manualVerified = true;
      authShieldState.riskScore = clampAuthRisk(authShieldState.riskScore - 40);
      if (captchaVerifyBtn) captchaVerifyBtn.classList.add("hidden");
      setAuthShieldUi("ok", "Bestaetigt. Schutz bleibt aktiv und Login ist wieder frei.");
    }

