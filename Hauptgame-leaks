    function confirmPassPurchase() {
      let success = false;
      const offerType = passPurchaseState.offerType || "riss_plus1";
      const priceValue = offerType === "riss_25" ? BATTLE_PASS_25_PACKAGE_PRICE : BATTLE_PASS_PREMIUM_PRICE;
      let errorText = "";

      if (isBattlePassFeatureDisabled()) errorText = "Battle Pass ist deaktiviert.";
      else if (BATTLE_PASS_MAIN_TRACK_DISABLED) errorText = "Kostenlos & Premium sind voruebergehend entfernt.";
      else if (isBattlePassExpired()) errorText = "Battle Pass ist abgelaufen.";
      else if (battlePassState.premiumUnlocked && offerType === "riss_plus1") errorText = "Premium ist bereits aktiv.";
      else if ((inventory[7] || 0) < priceValue) errorText = `Nicht genug M-Bucks (${formatCurrency(priceValue)}).`;

      if (!errorText) {
        if (offerType === "riss_plus1") success = buyBattlePassPremium();
