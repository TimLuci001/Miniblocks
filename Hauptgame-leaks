    function updateLobbyUi() {
      const startScreenActive = !!startScreen && startScreen.style.display !== "none";
      const activeLiveEvents = getActiveLiveEventEntries();
      const activeBoostEntries = activeLiveEvents.filter((entry) => ["xpBoost", "passBoost", "communityBoost", "shopDiscount"].includes(entry.key));
      document.body.classList.toggle("lobbyMode", inLobby);
      document.body.classList.toggle("startScreenActive", startScreenActive);
      if (lobbyScreen) lobbyScreen.classList.toggle("hidden", !inLobby);
      const hideHud = inLobby || startScreenActive || isCreativeHudHidden();
      if (hudRack) hudRack.style.display = startScreenActive ? "none" : "grid";
      if (hudCombo) hudCombo.style.display = hideHud ? "none" : "grid";
      if (xpHud) xpHud.style.display = hideHud ? "none" : "grid";
      if (hotbar) hotbar.style.display = hideHud ? "none" : "flex";
      if (topMenuDock) topMenuDock.style.display = startScreenActive ? "none" : "flex";
      setCreativeTopMenuLayout(isCreativeHudHidden());
      const creativeActive = isCreativeHudHidden();
      if (returnLobbyBtn) returnLobbyBtn.classList.toggle("hidden", inLobby || startScreenActive || creativeActive);
      if (returnLobbyMoreBtn) returnLobbyMoreBtn.classList.toggle("hidden", !creativeActive || inLobby || startScreenActive);
      if (helpBtn) {
        helpBtn.textContent = inLobby ? "Spielen" : "Tutorial!";
        helpBtn.classList.toggle("hidden", inLobby);
      }
      if (lockerBtn) lockerBtn.classList.toggle("hidden", !inLobby && !creativeActive);
      if (passBtn) passBtn.classList.toggle("hidden", !inLobby && !creativeActive);
      if (communityBtn) communityBtn.classList.add("hidden");
      if (shopBtn) {
        shopBtn.classList.toggle("hidden", !inLobby && !creativeActive);
        shopBtn.disabled = inLobby && isShopFeatureDisabled();
        shopBtn.textContent = isShopFeatureDisabled() ? "Shop AUS" : "Shop";
      }
      if (questBtn) {
        questBtn.classList.toggle("hidden", !inLobby && !creativeActive);
        questBtn.disabled = inLobby && isQuestFeatureDisabled();
        questBtn.textContent = isQuestFeatureDisabled() ? "Quests AUS" : "Quests";
      }
      if (leakBtn) {
        leakBtn.classList.toggle("hidden", !inLobby && !creativeActive);
      }
      if (crewBtn) {
        crewBtn.classList.toggle("hidden", !inLobby && !creativeActive);
        crewBtn.disabled = !MINECRAFT_CREW_ENABLED;
        crewBtn.textContent = MINECRAFT_CREW_ENABLED ? "Minecraft Crew" : "Minecraft Crew AUS";
      }
      if (skillBtn) {
        const skillHidden = !inLobby && areSkillsDisabledInCurrentMode() && !creativeActive;
        skillBtn.classList.toggle("hidden", skillHidden);
        skillBtn.disabled = !inLobby && areSkillsDisabledInCurrentMode();
      }
      if (creatorBtn) {
        creatorBtn.classList.toggle("hidden", !inLobby && !creativeActive);
        creatorBtn.disabled = inLobby && isCreatorFeatureDisabled();
        creatorBtn.textContent = isCreatorFeatureDisabled() ? "Creator AUS" : "Creator";
      }
      if (twitchBtn) {
        twitchBtn.classList.toggle("hidden", !inLobby && !creativeActive);
        twitchBtn.disabled = inLobby && isTwitchFeatureDisabled();
        twitchBtn.textContent = isTwitchFeatureDisabled() ? "Twitch AUS" : "Twitch";
      }
      if (lobbyBoostBar) {
        if (inLobby && activeBoostEntries.length) {
          lobbyBoostBar.classList.add("active");
          lobbyBoostBar.innerHTML = `<strong>Boost aktiv</strong><span>${activeBoostEntries.map((entry) => entry.labelHtml || entry.label).join(" • ")}</span>`;
        } else {
          lobbyBoostBar.classList.remove("active");
          lobbyBoostBar.innerHTML = "";
        }
      }
      if (lobbyEventBadge) {
        lobbyEventBadge.classList.add("hidden");
        lobbyEventBadge.innerHTML = "";
      }

      if (isThreeDMode) {
        if (threeRoot) threeRoot.classList.toggle("hidden", inLobby);
        canvas.style.display = "none";
      } else if (canvas) {
        canvas.style.display = inLobby ? "none" : "block";
      }
