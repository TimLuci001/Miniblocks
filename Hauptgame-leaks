        const skin = getSkinData(type, id);
        if (!skin) return "";
        const rarityMeta = getRarityMeta(skin.rarity || "common");
        const isActive = isActiveFn(id);

        const preview = type === "specials"
          ? `
            <div class="lockerTileMedia">
              <div class="lockerTileMediaSpecial">
                <div class="shopPreview" style="background:${skin.bodyColor};"></div>
                <div class="lockerTileSpark" style="background:${skin.eyeColor};"></div>
              </div>
            </div>
          `
          : type === "rains"
            ? `<div class="lockerTileMedia"><div class="shopPreview" style="background:linear-gradient(180deg, ${skin.secondaryColor || "#fff"}, ${skin.color});"></div></div>`
            : `<div class="lockerTileMedia"><div class="shopPreview" style="background:${skin.color};"></div></div>`;

        return `
          <div class="lockerTile ${isActive ? "active" : ""}">
            <div class="lockerTileHead">
              <div class="lockerTileStatus ${isActive ? "activeTag" : "storedTag"}">${isActive ? "Aktiv" : "Archiv"}</div>
              <div class="shopBadge ${rarityMeta.type}">${rarityMeta.label}</div>
            </div>
            ${preview}
            <div class="lockerTileBody">
              <div class="lockerTileName">${skin.name}</div>
              <div class="lockerTileMeta">${type === "specials"
                ? "Kompletter Spezial-Look mit eigener Farb-Kombination fuer Kopf, Koerper und Stil."
                : (type === "rains"
                  ? "Steuert Regen und Wettereffekte direkt im Match und im Lobby-Look."
                  : "Bleibt in deinem Archiv gespeichert und kann jederzeit wieder ausgeruestet werden.")}</div>
